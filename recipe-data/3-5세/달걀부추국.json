{"menu":"달걀부추국","title":"달걀부추국(동대문구)","band":"3-5세","dish_type":"soup","source":"standard","cook_min":10,"wait_min":0,"yield_g":44.7,"ings":[{"n":"달걀","raw":"달걀, 생것","g":17.3,"disp":null,"ssn":false,"na":24},{"n":"부추","raw":"부추, 재래종, 생것","g":11.5,"disp":null,"ssn":false,"na":0},{"n":"양파","raw":"양파, 생것","g":11.5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":2.3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":0.6,"disp":"약간","ssn":true,"na":46},{"n":"소금","raw":"소금","g":0.6,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":209},{"n":"참기름","raw":"참기름","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물 2컵과 국물용 멸치 4~5마리를 넣고 중불에서 5분간 우려 육수를 만든 뒤, 멸치는 아이가 삼키지 않도록 모두 건져낸다.","부추는 2cm 길이로 짧게, 양파는 얇게 채 썰고, 파는 잘게 다지듯 썰어 둔다.","육수가 팔팔 끓어오르면 양파와 부추를 넣고 1~2분 부드럽게 익힌다.","달걀 1개를 미리 풀어 빙 둘러 붓고 젓지 않은 채 30초 기다려 몽글하게 익힌다.","간장 조금과 소금 아주 약간으로 심심하게 간을 맞추고(후추는 기호에 따라 생략), 한 김 식혀 아이 국그릇에 담는다."],"steps_public":true,"nutri":{"kcal":36,"protein_g":2.5,"carb_g":2.2,"fat_g":1.9,"calcium_mg":16,"iron_mg":0.79,"sodium_mg":280,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀"]}