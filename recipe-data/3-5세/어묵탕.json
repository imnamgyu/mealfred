{"menu":"어묵탕","title":"어묵탕","band":"3-5세","dish_type":"soup","source":"standard","cook_min":25,"wait_min":0,"yield_g":33.6,"ings":[{"n":"어묵","raw":"어묵, 튀긴것","g":14.4,"disp":null,"ssn":false,"na":101},{"n":"무","raw":"무, 조선무, 생것","g":6.7,"disp":null,"ssn":false,"na":1},{"n":"쑥갓","raw":"쑥갓, 생것","g":6.7,"disp":null,"ssn":false,"na":10},{"n":"파","raw":"파, 생것","g":2.9,"disp":"1/2작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":1.9,"disp":null,"ssn":false,"na":42},{"n":"간장","raw":"간장, 재래","g":0.5,"disp":"약간","ssn":true,"na":38},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":137},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["작은 냄비에 물 2컵과 멸치 4~5마리를 넣고 중불에서 10분쯤 끓여 육수를 낸 뒤 멸치를 건져낸다.","어묵은 꼬치가 있으면 빼고 아이가 씹기 좋게 한입 크기(2cm 정도)로, 무는 0.5cm 두께의 얇은 나박모양으로 썰고 쑥갓과 파도 잘게 썬다.","육수에 무를 먼저 넣고 중불에서 5분쯤 투명해질 때까지 끓인 다음 어묵을 넣어 3분 더 끓인다.","쑥갓과 파를 넣고 1분만 더 끓인 뒤 소금과 간장으로 아주 연하게 간하고, 후춧가루는 살짝만 뿌려 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":34,"protein_g":3,"carb_g":3.8,"fat_g":0.8,"calcium_mg":56,"iron_mg":0.42,"sodium_mg":329,"na_flag":"ok"},"allergens":["대두","밀"]}