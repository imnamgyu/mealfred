{"menu":"오삼불고기","title":"오삼불고기","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":15,"yield_g":56.7,"ings":[{"n":"돼지고기","raw":"돼지고기, 앞다리(꾸리살), 생것","g":14.4,"disp":null,"ssn":false,"na":7},{"n":"오징어","raw":"오징어, 생것","g":14.4,"disp":null,"ssn":false,"na":29},{"n":"양파","raw":"양파, 생것","g":9.6,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":4.8,"disp":"1작은술","ssn":true,"na":1},{"n":"고추장","raw":"고추장, 개량","g":2.9,"disp":"1/2작은술","ssn":true,"na":72},{"n":"물엿","raw":"물엿","g":2.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":2.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":1.9,"disp":"1/2작은술","ssn":true,"na":154},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":1,"disp":"1/4작은술","ssn":true,"na":0}],"steps":["돼지고기와 손질한 오징어는 아이가 씹기 좋게 1~2cm 조각으로 자르고, 마늘은 곱게 다진다.","양파는 얇게 채로, 파는 비스듬히 얇게 썬다.","볼에 고기와 오징어를 담고 다진 마늘, 고추장(아이용은 아주 조금)·간장·물엿을 더해 고루 섞어 10분 재운다.","중불로 달군 팬에 식용유를 두르고 재운 재료를 4~5분 볶아 오징어가 뽀얗게 익도록 한다.","양파와 파를 넣고 2분 더 볶은 뒤 불을 끄고 참기름을 살짝 둘러 마무리한다. 한 김 식혀서 낸다."],"steps_public":true,"nutri":{"kcal":91,"protein_g":5.9,"carb_g":5.7,"fat_g":4.9,"calcium_mg":7,"iron_mg":0.29,"sodium_mg":262,"na_flag":"ok"},"allergens":["대두","밀","돼지고기","오징어"]}