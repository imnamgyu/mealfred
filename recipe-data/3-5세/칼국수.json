{"menu":"칼국수","title":"칼국수","band":"3-5세","dish_type":"noodle","source":"standard","cook_min":15,"wait_min":0,"yield_g":120.7,"ings":[{"n":"국수","raw":"국수_칼국수_생것","g":86.2,"disp":null,"ssn":false,"na":340},{"n":"양파","raw":"양파_생것","g":12.3,"disp":null,"ssn":false,"na":0},{"n":"호박","raw":"호박_애호박_생것","g":12.3,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파_대파_생것","g":3.7,"disp":"1작은술","ssn":true,"na":0},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":1.9,"disp":null,"ssn":false,"na":40},{"n":"간장","raw":"간장_재래","g":1.2,"disp":"1/4작은술","ssn":true,"na":98},{"n":"다시마","raw":"다시마, 말린것","g":1.2,"disp":null,"ssn":false,"na":38},{"n":"소금","raw":"소금","g":1.2,"disp":"1/4작은술","ssn":true,"na":443},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물 3컵과 멸치·다시마를 넣고 중불에서 5분 우려낸 뒤 건더기를 건져 육수를 만든다.","애호박과 당근은 3cm 길이로 가늘게 채 썰고, 대파는 송송 썬다.","끓는 육수에 칼국수 면과 애호박·당근을 넣고 중불에서 면이 부드러워질 때까지 5~6분 끓인다. 아이용 면은 먹기 전에 가위로 짧게 잘라 주면 좋다.","대파를 넣고 소금과 국간장으로 심심하게 간을 맞춘다. 후춧가루는 아이용이라면 생략하거나 아주 살짝만 넣는다.","한 김 식혀 국물 온도를 확인한 뒤 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":277,"protein_g":7.9,"carb_g":56.8,"fat_g":0.9,"calcium_mg":66,"iron_mg":0.76,"sodium_mg":961,"na_flag":"over"},"allergens":["대두","밀"]}