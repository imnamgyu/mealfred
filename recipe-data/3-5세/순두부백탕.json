{"menu":"순두부백탕","title":"순두부백탕","band":"3-5세","dish_type":"soup","source":"standard","cook_min":10,"wait_min":10,"yield_g":103.1,"ings":[{"n":"두부","raw":"두부, 순두부","g":80,"disp":null,"ssn":false,"na":3},{"n":"달걀","raw":"달걀, 생것","g":10,"disp":null,"ssn":false,"na":14},{"n":"양파","raw":"양파_생것","g":7,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":2,"disp":null,"ssn":false,"na":44},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["작은 냄비에 물 2컵과 멸치 5~6마리를 넣고 중불에서 10분 우려 육수를 만든 뒤 멸치는 건진다.","달걀 1개는 그릇에 곱게 풀고, 양파는 얇게 채 썬다.","파는 송송 썰고 마늘은 조금 다져 둔다.","육수에 순두부를 숟가락으로 큼직하게 떠 넣고 중불에서 끓이다가 양파·다진 마늘·파를 넣어 3~4분 더 끓인다.","풀어둔 달걀을 빙 둘러 붓고 30초 뒤 살살 저은 다음 소금으로 간하고, 후춧가루는 아주 살짝만 뿌려 마무리한다.","한 김 식혀 미지근할 때 아이에게 준다."],"steps_public":true,"nutri":{"kcal":59,"protein_g":8.1,"carb_g":1.5,"fat_g":2,"calcium_mg":61,"iron_mg":1.05,"sodium_mg":241,"na_flag":"ok"},"allergens":["난류(계란)","대두"]}