{"menu":"모듬버섯국","title":"모듬버섯국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":25,"wait_min":0,"yield_g":44.7,"ings":[{"n":"느타리버섯","raw":"느타리버섯, 생것","g":9.6,"disp":null,"ssn":false,"na":0},{"n":"무","raw":"무, 조선무, 생것","g":9.6,"disp":null,"ssn":false,"na":1},{"n":"팽이버섯","raw":"팽이버섯, 생것","g":9.6,"disp":null,"ssn":false,"na":0},{"n":"표고버섯","raw":"표고버섯, 배지재배, 대, 생것","g":9.6,"disp":null,"ssn":false,"na":0},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":1.9,"disp":null,"ssn":false,"na":42},{"n":"간장","raw":"간장, 재래","g":1.5,"disp":"1/4작은술","ssn":true,"na":116},{"n":"파","raw":"파, 대파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"다시마","raw":"다시마, 말린것","g":0.7,"disp":null,"ssn":false,"na":21},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.7,"disp":"약간","ssn":true,"na":0}],"steps":["국물용 멸치와 다시마를 찬물 2컵에 넣고 중불로 10분쯤 끓여 육수를 낸 뒤 건더기를 건져 낸다.","느타리·표고·팽이버섯은 물에 깨끗이 씻는다.","느타리는 결대로 가늘게 찢고, 표고는 0.5cm 두께로 썰고, 팽이는 2cm 길이로 짧게 잘라 아이가 삼키기 쉽게 한다.","무는 2cm 크기로 얇게 나박 썰고, 실파는 1cm 길이로 송송 썬다.","끓는 육수에 무와 버섯 세 가지를 넣고 중불에서 5~6분, 무가 투명해질 때까지 한소끔 끓인다.","다진 마늘과 실파를 넣고 국간장으로 심심하게 간한 뒤, 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":18,"protein_g":2.3,"carb_g":3.7,"fat_g":0.2,"calcium_mg":49,"iron_mg":0.53,"sodium_mg":181,"na_flag":"ok"},"allergens":["대두","밀"]}