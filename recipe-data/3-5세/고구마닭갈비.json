{"menu":"고구마닭갈비","title":"고구마닭갈비","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":20,"wait_min":10,"yield_g":99.8,"ings":[{"n":"닭고기","raw":"닭고기_가슴(껍질 제거)_생것","g":48.5,"disp":null,"ssn":false,"na":22},{"n":"고구마","raw":"고구마_분질(밤) 고구마_생것","g":13.9,"disp":null,"ssn":false,"na":1},{"n":"떡볶이","raw":"떡볶이","g":6.9,"disp":null,"ssn":false,"na":null},{"n":"양파","raw":"양파_생것","g":6.9,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":4.2,"disp":null,"ssn":false,"na":1},{"n":"들깻잎","raw":"들깻잎, 생것","g":4.2,"disp":null,"ssn":false,"na":0},{"n":"양배추","raw":"양배추_생것","g":4.2,"disp":null,"ssn":false,"na":0},{"n":"간장","raw":"간장_재래","g":2.8,"disp":"1/2작은술","ssn":true,"na":222},{"n":"고추장","raw":"고추장, 재래","g":2.8,"disp":"1/2작은술","ssn":true,"na":83},{"n":"파","raw":"파_대파_생것","g":2.8,"disp":"1/2작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":1.4,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.7,"disp":"약간","ssn":true,"na":0},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"카레","raw":"카레, 가루","g":0.4,"disp":null,"ssn":false,"na":17}],"steps":["닭고기는 아이 한입에 맞게 새끼손톱보다 조금 큰 2cm 크기로 잘라, 끓는 물에 1분 데쳐 기름기와 잡내를 뺀다.","고추장 대신 순한 간장 양념(간장·다진 마늘·올리고당·참기름)에 데친 닭을 버무려 10분 재운다.","고구마·양배추·양파·깻잎은 2cm 네모로 썰고, 대파는 얇게 어슷 썬다.","팬에 기름을 두르고 양념한 닭을 중불에서 5~6분, 속까지 익도록 볶는다.","닭이 거의 익으면 고구마와 채소를 넣고 중불에서 4~5분 더 볶는다. 고구마는 젓가락이 쑥 들어가야 한다.","불을 끄기 직전 깻잎을 넣어 살짝 섞고, 한 김 식혀 담는다."],"steps_public":true,"nutri":{"kcal":124,"protein_g":13.8,"carb_g":11.4,"fat_g":2.5,"calcium_mg":28,"iron_mg":0.51,"sodium_mg":346,"na_flag":"ok"},"allergens":["대두","밀","닭고기"]}