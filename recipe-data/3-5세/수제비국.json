{"menu":"수제비국","title":"감자수제비국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":30,"wait_min":10,"yield_g":41.1,"ings":[{"n":"밀","raw":"밀, 중력밀가루","g":23,"disp":null,"ssn":false,"na":0},{"n":"감자","raw":"감자, 대지, 생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"호박","raw":"호박, 애호박, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":1,"disp":null,"ssn":false,"na":22},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["작은 냄비에 물 2컵과 국물용 멸치 4~5마리를 넣고 중불에서 10분쯤 우린 뒤 멸치를 건져낸다.","밀가루에 뜨거운 물을 조금씩 부어 말랑하게 반죽하고, 마르지 않게 젖은 면포나 랩으로 덮어 15분쯤 둔다.","애호박과 감자는 아이가 씹기 좋게 0.5cm 두께의 얇은 조각으로 썰고, 파는 잘게 썰고 마늘은 다진다.","육수에 다진 마늘을 넣고 센불로 끓이다가, 반죽을 새끼손톱 두 개 크기로 얇게 뜯어 하나씩 넣는다.","수제비가 떠오르면 애호박·감자·파를 넣고 중불에서 5~6분 더 끓인 뒤 소금으로 심심하게 간한다(아이용은 후추 생략 가능).","그릇에 담아 한 김 식힌 뒤 아이에게 준다."],"steps_public":true,"nutri":{"kcal":98,"protein_g":3.3,"carb_g":19.6,"fat_g":0.3,"calcium_mg":27,"iron_mg":0.39,"sodium_mg":95,"na_flag":"ok"},"allergens":["밀"]}