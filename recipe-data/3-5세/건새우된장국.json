{"menu":"건새우된장국","title":"건새우된장국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":10,"wait_min":10,"yield_g":49,"ings":[{"n":"아욱","raw":"아욱, 생것","g":33.7,"disp":null,"ssn":false,"na":13},{"n":"된장","raw":"된장, 개량","g":7.2,"disp":"0.5큰술","ssn":true,"na":313},{"n":"새우","raw":"새우, 꽃새우, 삶아서 말린것","g":2.9,"disp":null,"ssn":false,"na":101},{"n":"파","raw":"파, 생것","g":2.9,"disp":"1/2작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":1.9,"disp":null,"ssn":false,"na":42},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0}],"steps":["작은 냄비에 물 2컵과 멸치 4~5마리를 넣고 중불에서 10분 정도 우려 육수를 만든 뒤 멸치를 건진다.","육수에 된장 1작은술을 체에 걸러 풀고, 건새우 한 줌을 넣어 한소끔 끓인다.","아욱은 3cm 길이로 잘라 두고, 파는 얇게 송송 썰고 마늘 반 쪽은 곱게 다진다.","끓는 국물에 아욱·파·마늘을 넣고 중불에서 5분 정도 부드러워질 때까지 더 끓인다.","불을 끄고 한 김 식혀 아이 그릇에 담는다. 건새우가 크면 아이 입에서 걸리지 않게 잘게 부숴 준다."],"steps_public":true,"nutri":{"kcal":38,"protein_g":4.6,"carb_g":4.1,"fat_g":0.6,"calcium_mg":254,"iron_mg":1.38,"sodium_mg":469,"na_flag":"review"},"allergens":["대두","밀","새우"]}