{"menu":"치즈닭갈비","title":"안매운치즈닭갈비","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":20,"yield_g":85.1,"ings":[{"n":"닭고기","raw":"닭고기_가슴(껍질 제거)_생것","g":30,"disp":null,"ssn":false,"na":14},{"n":"감자","raw":"감자, 대지, 생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"양배추","raw":"양배추_생것","g":10,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"치즈","raw":"치즈, 모짜렐라","g":10,"disp":null,"ssn":false,"na":24},{"n":"물엿","raw":"물엿","g":5,"disp":"1작은술","ssn":true,"na":0},{"n":"들깻잎","raw":"들깻잎, 생것","g":2.5,"disp":null,"ssn":false,"na":0},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":2,"disp":"1/2작은술","ssn":true,"na":96},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["닭가슴살·감자·양배추·양파·깻잎·파는 아이가 씹기 좋게 새끼손톱~엄지손톱 크기로 작게 썰고, 마늘은 다진다.","볼에 썬 재료를 모두 담고 다진 마늘, 간장 1작은술, 물엿 반 큰술, 후춧가루 아주 조금을 넣어 조물조물 버무려 10분 재운다.","팬에 콩기름을 두르고 중불에서 재운 재료를 넣어 8~10분, 감자가 포슬하게 익을 때까지 뒤적이며 볶는다.","불을 약불로 줄이고 치즈를 올린 뒤 뚜껑을 덮어 1~2분, 치즈가 완전히 녹을 때까지 익힌다.","한 김 식혀 치즈가 너무 뜨겁지 않은지 확인한 뒤 아이에게 준다."],"steps_public":true,"nutri":{"kcal":118,"protein_g":10.5,"carb_g":8.6,"fat_g":4.5,"calcium_mg":113,"iron_mg":0.31,"sodium_mg":135,"na_flag":"ok"},"allergens":["우유","대두","밀","닭고기"]}