{"menu":"새송이버섯나물","title":"새송이버섯나물","band":"3-5세","dish_type":"side","source":"standard","cook_min":15,"wait_min":0,"yield_g":24.4,"ings":[{"n":"큰느타리버섯","raw":"큰느타리버섯(새송이버섯), 생것","g":20,"disp":null,"ssn":false,"na":1},{"n":"참기름","raw":"참기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":1,"disp":"1/4작은술","ssn":true,"na":80},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금, 정제염","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":36},{"n":"참깨","raw":"참깨, 흰깨, 볶은것","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["끓는 물에 새송이버섯을 1~2분 데친 뒤 찬물에 담가 식히고 물기를 꼭 짠다.","버섯은 아이가 씹기 좋게 새끼손가락 굵기로 가늘게 결대로 찢고, 길면 3cm 정도로 짧게 자른다.","쪽파 조금과 마늘 반쪽을 곱게 다져 둔다.","볼에 버섯과 다진 파·마늘을 담고 소금 한 꼬집, 간장 반 작은술을 넣어 조물조물 무친다.","참기름 반 작은술과 통깨 약간을 뿌려 마무리한다. 통깨가 걱정되면 손으로 비벼 부숴 넣는다."],"steps_public":true,"nutri":{"kcal":20,"protein_g":0.7,"carb_g":1.7,"fat_g":1.6,"calcium_mg":2,"iron_mg":0.12,"sodium_mg":117,"na_flag":"ok"},"allergens":["대두","밀"]}