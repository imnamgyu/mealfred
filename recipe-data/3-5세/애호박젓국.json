{"menu":"애호박젓국","title":"애호박젓국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":20,"wait_min":0,"yield_g":32.5,"ings":[{"n":"호박","raw":"호박_애호박_생것","g":20,"disp":null,"ssn":false,"na":0},{"n":"양파","raw":"양파_생것","g":7,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"다시마","raw":"다시마, 말린것","g":1,"disp":null,"ssn":false,"na":31},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":0.5,"disp":null,"ssn":false,"na":11},{"n":"새우젓","raw":"새우젓, 추젓, 토굴, 염절임","g":0.5,"disp":"약간","ssn":true,"na":null},{"n":"참기름","raw":"참기름","g":0.5,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물 2컵과 다시마 한 조각, 멸치 서너 마리를 넣고 중불에서 10분 끓여 육수를 내고 건더기는 건진다.","애호박은 0.5cm 두께의 부채꼴로 납작하게 썰고, 양파는 아이 한입 크기로 썬다.","파는 송송 썰고 마늘은 곱게 다진다.","끓는 육수에 다진 마늘을 먼저 넣고, 애호박·양파·파를 넣어 중불에서 5분 정도 애호박이 말갛게 익을 때까지 끓인다.","새우젓을 아주 조금(1/3작은술)만 넣어 슴슴하게 간하고, 한 김 식혀 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":16,"protein_g":0.8,"carb_g":2.4,"fat_g":0.6,"calcium_mg":25,"iron_mg":0.22,"sodium_mg":42,"na_flag":"ok"},"allergens":["새우"]}