{"menu":"새우살채소볶음밥","title":"채소볶음밥","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":40,"wait_min":0,"yield_g":87.8,"ings":[{"n":"멥쌀","raw":"멥쌀_백미_생것","g":40,"disp":null,"ssn":false,"na":1},{"n":"당근","raw":"당근_뿌리_생것","g":12,"disp":null,"ssn":false,"na":3},{"n":"양파","raw":"양파_생것","g":12,"disp":null,"ssn":false,"na":0},{"n":"호박","raw":"호박_애호박_생것","g":12,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["쌀은 30분 불려 평소보다 물을 약간 적게 잡아 고슬하게 밥을 지어 둔다(있는 밥을 써도 좋다).","애호박·양파·당근·파는 아이 새끼손톱 크기로 잘게 썰고, 마늘은 곱게 다진다.","작은 그릇에 간장 약간, 참기름 반 작은술을 섞어 양념을 만들어 둔다(후추는 아주 조금만).","팬에 식용유를 두르고 중불에서 다진 마늘을 30초 볶아 향을 낸 뒤, 썰어 둔 채소를 넣고 2~3분간 부드러워질 때까지 볶는다.","밥을 넣고 주걱으로 풀어가며 섞은 다음 양념을 둘러 넣고 중불에서 1~2분 고루 볶아, 한 김 식혀 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":187,"protein_g":3.5,"carb_g":34.9,"fat_g":3.1,"calcium_mg":12,"iron_mg":0.3,"sodium_mg":149,"na_flag":"ok"},"allergens":["대두","밀"]}