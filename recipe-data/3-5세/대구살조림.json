{"menu":"대구살조림","title":"대구살조림","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":62.8,"ings":[{"n":"대구","raw":"대구, 생것","g":40,"disp":null,"ssn":false,"na":0},{"n":"양파","raw":"양파, 생것","g":15,"disp":null,"ssn":false,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":2.5,"disp":"1/2작은술","ssn":true,"na":120},{"n":"설탕","raw":"설탕, 백설탕","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"청주","raw":"청주, 알코올 16%","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["대구살은 가시가 없는지 손으로 만져 확인하고 아이 한입 크기(2~3cm)로 썰어 후춧가루를 아주 살짝 뿌려 밑간한다.","양파는 0.5cm 두께로 채 썰고 마늘은 다진다.","작은 그릇에 다진 마늘·간장 1큰술·청주 1작은술·설탕 반 작은술·참기름 약간·물 반 컵을 섞어 조림장을 만든다.","냄비 바닥에 양파를 깔고 조림장의 절반을 끼얹은 뒤 대구살을 올리고 남은 조림장을 붓는다.","뚜껑을 덮고 중약불에서 8~10분간 국물을 끼얹어 가며 조린 뒤, 한 김 식혀 살을 잘게 발라 준다."],"steps_public":true,"nutri":{"kcal":55,"protein_g":8.3,"carb_g":4,"fat_g":0.3,"calcium_mg":18,"iron_mg":0.26,"sodium_mg":120,"na_flag":"ok"},"allergens":["대두","밀"]}