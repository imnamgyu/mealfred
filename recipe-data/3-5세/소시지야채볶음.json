{"menu":"소시지야채볶음","title":"소시지채소볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":43.3,"ings":[{"n":"소시지","raw":"소시지, 위너(비엔나)소시지","g":18.5,"disp":null,"ssn":false,"na":135},{"n":"당근","raw":"당근_뿌리_생것","g":6.2,"disp":null,"ssn":false,"na":2},{"n":"양파","raw":"양파_생것","g":6.2,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":6.2,"disp":"0.4큰술","ssn":true,"na":1},{"n":"콩기름","raw":"콩기름","g":3.1,"disp":"1작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":1.9,"disp":"1/2작은술","ssn":true,"na":89},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.2,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.3,"disp":"약간","ssn":true,"na":0}],"steps":["소시지는 통째로 주면 위험하니 0.5cm 두께로 동글게 썰고 얕은 칼집을 낸다. 당근과 양파는 아이 입 크기에 맞춰 2cm 정도로 얇게 썬다.","대파는 송송 썰고 마늘 반 쪽은 곱게 다진다.","팬에 콩기름 1작은술을 두르고 중불에서 다진 마늘을 30초간 향이 나게 볶는다.","당근과 양파를 넣어 2~3분간 숨이 죽도록 볶는다.","소시지와 파를 넣고 2분 더 볶다가 간장 반 작은술로 심심하게 간하고, 불을 끈 뒤 참기름 몇 방울로 마무리한다.","한 김 식혀 접시에 담아 준다."],"steps_public":true,"nutri":{"kcal":96,"protein_g":3.7,"carb_g":4.1,"fat_g":7.2,"calcium_mg":11,"iron_mg":0.31,"sodium_mg":226,"na_flag":"ok"},"allergens":["대두","밀","돼지고기","닭고기","쇠고기"]}