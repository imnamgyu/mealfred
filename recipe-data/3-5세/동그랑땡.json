{"menu":"동그랑땡","title":"(수제)동그랑땡(경남)","band":"3-5세","dish_type":"etc","source":"standard","cook_min":10,"wait_min":0,"yield_g":83.2,"ings":[{"n":"돼지고기","raw":"돼지고기_등심_생것","g":30,"disp":null,"ssn":false,"na":13},{"n":"두부","raw":"두부","g":20,"disp":null,"ssn":false,"na":0},{"n":"달걀","raw":"달걀, 생것","g":10,"disp":null,"ssn":false,"na":14},{"n":"양파","raw":"양파_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"밀","raw":"밀, 중력밀가루","g":5,"disp":null,"ssn":false,"na":0},{"n":"콩기름","raw":"콩기름","g":3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"소금","raw":"소금, 정제염","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72}],"steps":["다진 돼지고기는 키친타월로 눌러 핏물을 빼고, 두부 한 조각은 면포나 키친타월로 꾹 짜서 물기를 없앤 뒤 포크로 곱게 으깬다.","양파와 당근은 새끼손톱보다 작게 잘게 다져 아이가 씹기 편하게 준비한다.","볼에 돼지고기·으깬 두부·다진 양파·당근을 모두 넣고 소금 한 꼬집으로 간해 끈기가 생길 때까지 치대듯 섞는다.","반죽을 아이 한입 크기(지름 3cm 정도)로 동글납작하게 빚어 밀가루를 얇게 묻히고 풀어둔 달걀물을 입힌다.","팬에 식용유를 두르고 중약불에서 앞뒤로 3~4분씩, 속까지 익도록 노릇하게 굽는다.","접시에 옮겨 한 김 식힌 뒤 아이에게 낸다."],"steps_public":true,"nutri":{"kcal":126,"protein_g":10.9,"carb_g":5.7,"fat_g":6.2,"calcium_mg":22,"iron_mg":0.69,"sodium_mg":100,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","돼지고기"]}