{"menu":"브로콜리된장무침","title":"브로콜리된장무침","band":"3-5세","dish_type":"side","source":"standard","cook_min":10,"wait_min":0,"yield_g":38.7,"ings":[{"n":"브로콜리","raw":"브로콜리_생것","g":35,"disp":null,"ssn":false,"na":1},{"n":"된장","raw":"된장, 개량","g":1.8,"disp":"1/2작은술","ssn":true,"na":78},{"n":"파","raw":"파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["브로콜리는 아이 한입 크기(새끼손톱 두 개 정도)의 작은 송이로 자른다.","끓는 물에 넣고 1~2분 데친 뒤 찬물에 헹궈 식히고 체에 밭쳐 물기를 뺀다.","파와 마늘은 곱게 다진다.","볼에 브로콜리, 파, 마늘을 담고 된장 반 작은술과 참기름 몇 방울을 넣어 골고루 버무려 낸다."],"steps_public":true,"nutri":{"kcal":17,"protein_g":1.4,"carb_g":2.7,"fat_g":0.4,"calcium_mg":16,"iron_mg":0.33,"sodium_mg":80,"na_flag":"ok"},"allergens":["대두","밀"]}