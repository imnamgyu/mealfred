{"menu":"콘샐러드","title":"콘샐러드(경남)","band":"3-5세","dish_type":"side","source":"standard","cook_min":10,"wait_min":0,"yield_g":57.7,"ings":[{"n":"옥수수","raw":"옥수수, 가당, 통조림","g":40.4,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":5.8,"disp":null,"ssn":false,"na":1},{"n":"마요네즈","raw":"마요네즈, 난황","g":5.8,"disp":"1작은술","ssn":true,"na":28},{"n":"양파","raw":"양파_생것","g":5.8,"disp":null,"ssn":false,"na":0}],"steps":["통조림 옥수수는 체에 밭쳐 국물을 빼고, 한 번 헹궈 짠기를 덜어낸다.","양파와 당근은 새끼손톱보다 작게 잘게 썬다(생양파가 매우면 찬물에 5분 담갔다 물기를 짠다).","볼에 옥수수, 양파, 당근을 담고 마요네즈 1작은술을 넣어 고루 버무린다.","옥수수 알갱이가 목에 걸릴 수 있으니 어린 아이는 숟가락으로 살짝 으깨 주고, 작은 그릇에 담아낸다."],"steps_public":true,"nutri":{"kcal":86,"protein_g":1,"carb_g":10.1,"fat_g":4.7,"calcium_mg":4,"iron_mg":0.18,"sodium_mg":29,"na_flag":"ok"},"allergens":["난류(계란)","대두"]}