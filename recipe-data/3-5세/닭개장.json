{"menu":"닭개장","title":"닭개장","band":"3-5세","dish_type":"etc","source":"standard","cook_min":25,"wait_min":0,"yield_g":48.7,"ings":[{"n":"닭고기","raw":"닭고기, 가슴(껍질 제거), 생것","g":24,"disp":null,"ssn":false,"na":11},{"n":"고사리","raw":"고사리, 데친것","g":5,"disp":null,"ssn":false,"na":0},{"n":"무","raw":"무, 조선무, 생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"숙주나물","raw":"숙주나물, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"토란대","raw":"토란대, 줄기, 데친것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 재래","g":0.5,"disp":"약간","ssn":true,"na":40},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":144},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물을 붓고 닭가슴살 1쪽을 넣어 중불에서 15분 정도 삶은 뒤, 익은 살을 건져 아이가 씹기 쉽게 잘게 찢는다. 국물은 육수로 쓴다.","숙주·고사리·토란대는 끓는 물에 데쳐 물기를 짜고 2~3cm 길이로 짧게 썬다.","무는 새끼손톱 크기로 얇게 나박썰고, 파는 송송 썰고, 마늘은 조금 다진다.","육수에 무를 넣고 중불에서 5분 끓이다가 찢은 닭살·고사리·토란대·숙주·파 순서로 넣어 한소끔 더 끓인다.","다진 마늘을 넣고 소금과 간장으로 심심하게 간한다. 아이용이라 고춧가루와 후추는 빼거나 아주 조금만 쓴다.","그릇에 담아 한 김 식혀서 낸다."],"steps_public":true,"nutri":{"kcal":32,"protein_g":5.9,"carb_g":1.4,"fat_g":0.3,"calcium_mg":10,"iron_mg":0.18,"sodium_mg":197,"na_flag":"ok"},"allergens":["대두","밀","닭고기"]}