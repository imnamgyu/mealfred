{"menu":"마늘종볶음","title":"마늘종볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":26.8,"ings":[{"n":"마늘종","raw":"마늘종, 꽃줄기, 생것","g":15,"disp":"1큰술","ssn":true,"na":0},{"n":"양파","raw":"양파, 생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":0.6,"disp":"약간","ssn":true,"na":29},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":36},{"n":"참기름","raw":"참기름","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["마늘종은 질긴 끝부분을 잘라내고 아이가 집기 좋은 3cm 길이로 썬다.","양파는 얇게 채 썰고, 마늘은 곱게 다진다.","팬에 식용유를 두르고 중불에서 다진 마늘을 30초 볶아 향을 낸다.","마늘종과 양파를 넣고 3~4분, 마늘종이 아이 이로도 쉽게 끊어질 만큼 부드러워질 때까지 볶는다.","소금 한 꼬집과 간장 몇 방울로 간을 맞추고, 불을 끈 뒤 참기름을 살짝 둘러 마무리한다."],"steps_public":true,"nutri":{"kcal":17,"protein_g":0.5,"carb_g":2.9,"fat_g":0.6,"calcium_mg":9,"iron_mg":0.11,"sodium_mg":65,"na_flag":"ok"},"allergens":["대두","밀"]}