{"menu":"돼지고기김치찌개","title":"돈육김치찌개","band":"3-5세","dish_type":"soup","source":"standard","cook_min":25,"wait_min":0,"yield_g":51.2,"ings":[{"n":"돼지고기","raw":"돼지고기_등심_생것","g":30,"disp":null,"ssn":false,"na":13},{"n":"김치","raw":"김치, 배추 김치","g":10,"disp":null,"ssn":false,"na":55},{"n":"양파","raw":"양파_생것","g":7,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 산분해","g":0.5,"disp":"약간","ssn":true,"na":27},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72}],"steps":["돼지고기와 잘 익은 배추김치는 아이가 씹기 좋게 새끼손톱 크기로, 양파는 얇게 썰어 준비한다.","대파는 송송 썰고 마늘은 곱게 다져 둔다.","냄비를 중불로 달군 뒤 돼지고기를 먼저 2~3분 볶고, 김치·다진 마늘·양파를 넣어 3분쯤 더 볶아 김치의 신맛을 부드럽게 만든다.","물을 재료가 잠길 만큼 붓고 센불에서 끓어오르면 중약불로 줄여 10분 정도 푹 끓인다.","대파를 넣고 소금과 간장으로 아이 입맛에 맞게 심심하게 간을 한 뒤, 한 김 식혀 그릇에 담아낸다."],"steps_public":true,"nutri":{"kcal":50,"protein_g":7.4,"carb_g":1.5,"fat_g":1.4,"calcium_mg":8,"iron_mg":0.23,"sodium_mg":168,"na_flag":"ok"},"allergens":["대두","밀","새우","돼지고기"]}