{"menu":"닭죽","title":"닭죽","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":45,"wait_min":30,"yield_g":46.9,"ings":[{"n":"멥쌀","raw":"멥쌀_백미_생것","g":25,"disp":null,"ssn":false,"na":1},{"n":"닭고기","raw":"닭고기_가슴(껍질 제거)_생것","g":20,"disp":null,"ssn":false,"na":9},{"n":"참기름","raw":"참기름","g":1.2,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["쌀은 30분 이상 물에 불리고, 마늘은 곱게 다진다.","닭가슴살은 냄비에 물을 넉넉히 붓고 15분쯤 삶아 속까지 익힌 뒤, 아이가 삼키기 쉽게 잘게 찢고 삶은 물은 육수로 남겨 둔다.","냄비에 참기름을 살짝 두르고 약한 중불에서 불린 쌀을 1~2분 투명해질 때까지 볶다가, 육수를 쌀의 5~6배로 붓고 끓인다.","끓어오르면 약불로 줄여 15분쯤 저어가며 퍼지게 익히고, 다진 마늘 약간과 찢은 닭고기를 넣어 5분 더 끓인 뒤 소금으로 연하게 간해 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":124,"protein_g":6.3,"carb_g":19.7,"fat_g":1.7,"calcium_mg":3,"iron_mg":0.13,"sodium_mg":190,"na_flag":"ok"},"allergens":["닭고기"]}