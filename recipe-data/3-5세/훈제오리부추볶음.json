{"menu":"훈제오리부추볶음","title":"오리부추볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":57.9,"ings":[{"n":"오리고기","raw":"오리고기, 집오리, 생것","g":28.9,"disp":null,"ssn":false,"na":24},{"n":"부추","raw":"부추, 재래종, 생것","g":9.6,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근, 뿌리, 생것","g":4.8,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파, 생것","g":4.8,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":4.8,"disp":"1작은술","ssn":true,"na":1},{"n":"콩기름","raw":"콩기름","g":2.4,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":1.5,"disp":"1/4작은술","ssn":true,"na":69},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["당근·양파는 얇게 채 썰고 부추는 3cm 길이로 자른다. 파는 송송 썰고 마늘 반쪽은 다진다.","훈제오리도 아이 한입 크기(새끼손톱 두 배 정도)로 얇게 썬다.","팬에 식용유를 살짝 두르고 중불에서 다진 마늘을 30초 볶아 향을 낸다.","당근·양파를 먼저 2분 볶고, 부추를 넣어 30초 더 볶는다.","오리고기와 파를 넣고 1~2분 볶다가 간장 반 작은술로 간한 뒤 참기름 몇 방울로 마무리한다.","접시에 덜어 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":124,"protein_g":5.2,"carb_g":1.9,"fat_g":10.6,"calcium_mg":11,"iron_mg":0.92,"sodium_mg":96,"na_flag":"ok"},"allergens":["대두","밀"]}