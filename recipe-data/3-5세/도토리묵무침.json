{"menu":"도토리묵무침","title":"도토리묵무침","band":"3-5세","dish_type":"side","source":"standard","cook_min":15,"wait_min":0,"yield_g":66.2,"ings":[{"n":"도토리묵","raw":"도토리묵","g":60,"disp":null,"ssn":false,"na":46},{"n":"당근","raw":"당근_뿌리_생것","g":2,"disp":null,"ssn":false,"na":1},{"n":"상추","raw":"상추, 적상추, 생것","g":2,"disp":null,"ssn":false,"na":0},{"n":"간장","raw":"간장_재래","g":1,"disp":"1/4작은술","ssn":true,"na":80},{"n":"파","raw":"파, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"참깨","raw":"참깨_흰깨_볶은것","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["도토리묵은 아이가 씹기 좋게 1.5cm 크기의 얇은 네모로 썬다.","상추는 한입 크기로 손으로 찢고, 당근은 3cm 길이로 가늘게 채 썬다.","파는 잘게 썰고 마늘은 곱게 다진다.","작은 그릇에 파, 마늘, 간장, 참기름, 참깨를 섞어 양념장을 만든다. 고춧가루는 아이용이면 빼거나 아주 조금만 넣는다.","큰 그릇에 묵, 상추, 당근을 담고 양념장을 끼얹어 묵이 부서지지 않게 살살 버무린다."],"steps_public":true,"nutri":{"kcal":32,"protein_g":0.3,"carb_g":6.7,"fat_g":0.5,"calcium_mg":12,"iron_mg":0.07,"sodium_mg":126,"na_flag":"ok"},"allergens":["대두","밀"]}