{"menu":"오징어채소볶음","title":"오징어채소볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":59.4,"ings":[{"n":"오징어","raw":"오징어, 생것","g":38.5,"disp":null,"ssn":false,"na":77},{"n":"당근","raw":"당근, 뿌리, 생것","g":4.8,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파, 생것","g":4.8,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":4.8,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":2.9,"disp":"1/2작은술","ssn":true,"na":138},{"n":"콩기름","raw":"콩기름","g":2.4,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["오징어는 껍질 쪽에 잔 칼집을 내고 아이가 씹기 쉽게 1.5cm 폭의 작은 조각으로 썰고, 양파·당근·파도 새끼손톱 크기로 얇게 썰고 마늘은 다진다.","팬에 식용유를 두르고 중불에서 다진 마늘과 당근을 1~2분 볶는다.","오징어를 넣고 2분 정도, 뽀얗게 익을 때까지만 빠르게 볶는다(오래 볶으면 질겨진다).","양파와 파를 넣어 1~2분 더 볶다가 간장을 조금 넣어 심심하게 간한다.","불을 끄고 참기름과 후춧가루를 아주 살짝 둘러 마무리한 뒤 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":69,"protein_g":7.7,"carb_g":1.8,"fat_g":3.1,"calcium_mg":8,"iron_mg":0.18,"sodium_mg":217,"na_flag":"ok"},"allergens":["대두","밀","오징어"]}