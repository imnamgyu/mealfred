{"menu":"미역죽","title":"미역죽","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":30,"wait_min":40,"yield_g":31.1,"ings":[{"n":"멥쌀","raw":"멥쌀, 백미, 생것","g":25,"disp":null,"ssn":false,"na":1},{"n":"미역","raw":"미역, 말린것","g":3,"disp":null,"ssn":false,"na":226},{"n":"간장","raw":"간장, 재래","g":1.2,"disp":"1/4작은술","ssn":true,"na":96},{"n":"참기름","raw":"참기름","g":1.2,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["쌀은 30분 이상 물에 불리고, 미역도 찬물에 10분 불려 잘게 가위로 자르고, 마늘은 곱게 다진다.","냄비에 참기름 반 스푼을 두르고 불린 쌀과 미역을 중불에서 2분 볶다가 다진 마늘을 넣어 함께 볶는다.","쌀 양의 5~6배 물을 붓고 센불로 끓인 뒤, 끓어오르면 약불로 줄인다.","가끔 저어 가며 15~20분, 쌀알이 푹 퍼질 때까지 끓인다.","소금이나 간장 몇 방울로 아주 연하게 간하고, 한 김 식혀 미지근할 때 담아 준다."],"steps_public":true,"nutri":{"kcal":107,"protein_g":2.3,"carb_g":21.4,"fat_g":1.4,"calcium_mg":36,"iron_mg":0.53,"sodium_mg":503,"na_flag":"review"},"allergens":["대두","밀"]}