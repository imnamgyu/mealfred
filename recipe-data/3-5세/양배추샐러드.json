{"menu":"양배추샐러드","title":"양배추샐러드(딸기드레싱)","band":"3-5세","dish_type":"side","source":"standard","cook_min":10,"wait_min":0,"yield_g":26.4,"ings":[{"n":"양배추","raw":"양배추_생것","g":20,"disp":null,"ssn":false,"na":2},{"n":"딸기","raw":"딸기_설향_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"올리브유","raw":"올리브유","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"레몬과즙","raw":"레몬 과즙","g":0.2,"disp":null,"ssn":false,"na":null},{"n":"설탕","raw":"설탕_백설탕","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["양배추 잎 1~2장을 씻어 3cm 길이의 가는 채로 썰고, 찬물에 5분 담갔다 건져 아삭하게 준비한다.","딸기 2~3알은 포크로 곱게 으깨고, 레몬은 반 개를 짜서 즙을 낸다.","으깬 딸기에 레몬즙, 설탕 반 티스푼, 올리브유 1티스푼을 넣고 잘 섞어 드레싱을 만든다.","그릇에 양배추 채를 담고 딸기드레싱을 끼얹어 살살 버무려 낸다."],"steps_public":true,"nutri":{"kcal":18,"protein_g":0.4,"carb_g":2.2,"fat_g":1,"calcium_mg":10,"iron_mg":0.07,"sodium_mg":2,"na_flag":"ok"},"allergens":[]}