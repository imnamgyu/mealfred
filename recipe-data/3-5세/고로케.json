{"menu":"고로케","title":"고로케","band":"3-5세","dish_type":"etc","source":"standard","cook_min":30,"wait_min":0,"yield_g":102.2,"ings":[{"n":"감자","raw":"감자, 대지, 생것","g":67.3,"disp":null,"ssn":false,"na":1},{"n":"콩기름","raw":"콩기름","g":9.6,"disp":"0.6큰술","ssn":true,"na":0},{"n":"달걀","raw":"달걀, 생것","g":4.8,"disp":null,"ssn":false,"na":7},{"n":"당근","raw":"당근, 뿌리, 생것","g":4.8,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파, 생것","g":4.8,"disp":null,"ssn":false,"na":0},{"n":"옥수수","raw":"옥수수, 가당, 통조림","g":4.8,"disp":null,"ssn":false,"na":0},{"n":"밀","raw":"밀, 빵가루","g":2.9,"disp":null,"ssn":false,"na":9},{"n":"밀","raw":"밀, 중력밀가루","g":2.9,"disp":null,"ssn":false,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":68},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["당근과 양파는 새끼손톱 크기보다 작게 다지고, 캔 옥수수는 체에 밭쳐 물기를 뺀다.","감자는 껍질째 김 오른 찜기에 20분쯤 푹 찐 뒤 껍질을 벗기고 볼에서 곱게 으깬다.","으깬 감자에 당근·양파·옥수수와 소금·후추를 아주 조금 넣어 골고루 섞는다.","반죽을 아이 주먹의 반 크기로 동글납작하게 빚어 밀가루→달걀물→빵가루 순서로 옷을 입힌다.","냄비에 기름을 붓고 중불(170도, 빵가루를 떨어뜨리면 바로 떠오르는 정도)에서 2~3분 노릇하게 튀긴 뒤 기름을 빼고, 한 김 식혀 아이에게 준다. 기름이 부담스러우면 팬에 기름을 자작하게 두르고 굴려 가며 구워도 좋다."],"steps_public":true,"nutri":{"kcal":170,"protein_g":2.8,"carb_g":16.6,"fat_g":10,"calcium_mg":12,"iron_mg":0.55,"sodium_mg":86,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀"]}