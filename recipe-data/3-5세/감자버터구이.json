{"menu":"감자버터구이","title":"알감자버터구이","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":25,"wait_min":0,"yield_g":48,"ings":[{"n":"감자","raw":"감자, 대지, 생것","g":40,"disp":null,"ssn":false,"na":0},{"n":"콩기름","raw":"콩기름","g":5,"disp":"1작은술","ssn":true,"na":0},{"n":"버터","raw":"버터","g":2,"disp":"1/2작은술","ssn":true,"na":7},{"n":"설탕","raw":"설탕_백설탕","g":1,"disp":"1/4작은술","ssn":true,"na":0}],"steps":["알감자는 껍질째 깨끗이 문질러 씻고, 소금 약간을 넣은 물에 넣어 중불에서 12~15분, 젓가락이 쑥 들어갈 때까지 삶는다.","삶은 감자는 아이 입 크기에 맞게 반 또는 4등분으로 잘라 둔다.","팬에 버터 1작은술과 식용유 약간을 두르고 약불에서 감자를 굴려 가며 5분쯤 노릇하게 굽는다.","설탕을 아주 조금 뿌려 버무린 뒤 한 김 식혀 접시에 담는다."],"steps_public":true,"nutri":{"kcal":92,"protein_g":0.8,"carb_g":7.1,"fat_g":6.6,"calcium_mg":4,"iron_mg":0.23,"sodium_mg":8,"na_flag":"ok"},"allergens":["우유","대두"]}