{"menu":"계란야채죽","title":"달걀채소죽","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":30,"wait_min":30,"yield_g":67.9,"ings":[{"n":"달걀","raw":"달걀, 생것","g":30,"disp":null,"ssn":false,"na":41},{"n":"멥쌀","raw":"멥쌀_백미_생것","g":25,"disp":null,"ssn":false,"na":1},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"참기름","raw":"참기름","g":1.2,"disp":"1/4작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["쌀은 물에 30분쯤 담가 불리고, 파·마늘·양파·당근은 새끼손톱보다 작게 잘게 다진다.","냄비에 참기름을 살짝 두르고 중불에서 다진 채소를 2~3분 볶아 향을 낸다.","불린 쌀을 넣고 물을 넉넉히(쌀의 5~6배) 부은 뒤, 약불로 줄여 눌지 않게 저어가며 15~20분 끓인다.","달걀 1개를 그릇에 잘 풀어 죽에 빙 둘러 넣고 저으면서 1분 더 끓인다.","소금 아주 조금으로 간하고 참기름 한 방울을 떨어뜨린 뒤, 한 김 식혀 담아 준다."],"steps_public":true,"nutri":{"kcal":147,"protein_g":5.7,"carb_g":20.7,"fat_g":3.9,"calcium_mg":19,"iron_mg":0.69,"sodium_mg":223,"na_flag":"ok"},"allergens":["난류(계란)"]}