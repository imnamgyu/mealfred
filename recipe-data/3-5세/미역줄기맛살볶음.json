{"menu":"미역줄기맛살볶음","title":"맛살볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":35.2,"ings":[{"n":"게맛살","raw":"게맛살","g":15,"disp":null,"ssn":false,"na":100},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":1.5,"disp":"1/4작은술","ssn":true,"na":72},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["맛살은 결대로 찢거나 1cm 폭으로 짧게 썰고, 당근과 양파는 새끼손톱 크기로 얇게 썬다.","대파는 송송 썰고 마늘은 다져 둔다.","팬에 식용유 1큰술을 두르고 약불에서 다진 마늘을 30초 볶아 향을 낸 뒤, 당근·양파를 넣고 중불에서 2~3분 부드러워질 때까지 볶는다.","맛살과 파를 넣고 1분 더 볶다가 간장 반 작은술로 살짝 간을 하고, 불을 끄고 참기름 몇 방울로 마무리해 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":50,"protein_g":2,"carb_g":4.3,"fat_g":2.7,"calcium_mg":36,"iron_mg":0.22,"sodium_mg":174,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","게"]}