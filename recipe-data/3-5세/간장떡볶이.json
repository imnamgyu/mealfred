{"menu":"간장떡볶이","title":"간장떡볶이","band":"3-5세","dish_type":"snack","source":"standard","cook_min":15,"wait_min":10,"yield_g":66.6,"ings":[{"n":"멥쌀떡","raw":"멥쌀떡, 가래떡","g":50,"disp":null,"ssn":false,"na":131},{"n":"양배추","raw":"양배추_생것","g":7,"disp":null,"ssn":false,"na":1},{"n":"어묵","raw":"어묵, 튀긴것","g":6,"disp":null,"ssn":false,"na":42},{"n":"간장","raw":"간장, 개량, 양조","g":1.5,"disp":"1/4작은술","ssn":true,"na":72},{"n":"파","raw":"파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":36},{"n":"참기름","raw":"참기름","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["떡볶이 떡은 미지근한 물에 10분쯤 담가 말랑하게 불려 둔다.","양배추는 아이 한입 크기(3cm 정도)로, 어묵은 0.5cm 폭으로 얇게, 파는 송송 썰고 마늘 약간은 곱게 다진다.","작은 그릇에 다진 마늘, 간장 1작은술, 설탕 반 작은술, 소금 한 꼬집, 참기름 약간을 섞어 양념을 만들어 둔다.","냄비에 물 반 컵과 양념을 넣고 중불에서 끓어오르면 불린 떡과 어묵을 넣어 3분 정도 익힌다.","양배추와 파를 더해 센불에서 2~3분 국물이 자작해질 때까지 저어 가며 졸이고, 떡은 새끼손톱 크기로 잘라 한 김 식혀 내준다."],"steps_public":true,"nutri":{"kcal":123,"protein_g":2.8,"carb_g":26.8,"fat_g":0.6,"calcium_mg":12,"iron_mg":0.16,"sodium_mg":281,"na_flag":"ok"},"allergens":["대두","밀"]}