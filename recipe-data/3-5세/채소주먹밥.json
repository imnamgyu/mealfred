{"menu":"채소주먹밥","title":"채소주먹밥","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":40,"wait_min":0,"yield_g":57.6,"ings":[{"n":"멥쌀","raw":"멥쌀, 백미, 생것","g":40,"disp":null,"ssn":false,"na":1},{"n":"당근","raw":"당근, 뿌리, 생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파프리카","raw":"파프리카, 초록색, 생것","g":5,"disp":"1작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"참기름","raw":"참기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["쌀을 30분쯤 불렸다가 평소보다 물을 조금 적게 잡아 밥을 고슬하게 짓는다.","양파, 당근, 파프리카를 새끼손톱보다 작게 잘게 다진다.","중불 팬에 식용유를 얇게 두르고 다진 채소를 2~3분, 향이 나고 부드러워질 때까지 볶는다.","큰 볼에 따뜻한 밥과 볶은 채소를 넣고 소금 한 꼬집, 후춧가루 아주 조금, 참기름 반 작은술을 더해 고루 섞는다.","밥이 한 김 식으면 아이 한입 크기의 작은 공 모양으로 꼭꼭 뭉쳐 담는다."],"steps_public":true,"nutri":{"kcal":167,"protein_g":2.7,"carb_g":32.7,"fat_g":2.2,"calcium_mg":6,"iron_mg":0.63,"sodium_mg":182,"na_flag":"ok"},"allergens":["대두"]}