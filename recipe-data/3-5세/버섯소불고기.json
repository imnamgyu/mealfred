{"menu":"버섯소불고기","title":"소불고기(경남)","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":13,"yield_g":64.1,"ings":[{"n":"소고기","raw":"소고기_한우(1등급)_목심(목심살)_생것","g":40,"disp":null,"ssn":false,"na":27},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["불고기용 소고기는 새끼손톱 크기로 잘게 자르고, 양파·당근은 얇게(0.3cm) 채 썰고, 버섯도 아이 한입 크기로 찢어 둔다.","파는 잘게 송송, 마늘은 곱게 다져 준비한다.","볼에 고기를 넣고 다진 마늘, 간장 1큰술, 설탕 반 큰술, 참기름 약간, 후추 아주 조금을 더해 조물조물 무친 뒤 10분쯤 재운다.","팬에 식용유를 살짝 두르고 중불에서 재운 고기를 먼저 2~3분 볶는다.","고기 색이 변하면 당근·양파·버섯·파를 더해 3~4분 더 볶아 채소가 부드러워지게 익히고, 한 김 식혀 아이에게 준다."],"steps_public":true,"nutri":{"kcal":134,"protein_g":9.2,"carb_g":2.4,"fat_g":9.3,"calcium_mg":9,"iron_mg":1.23,"sodium_mg":173,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}