{"menu":"채소달걀찜","title":"채소달걀찜","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":20,"wait_min":0,"yield_g":45.3,"ings":[{"n":"달걀","raw":"달걀, 생것","g":30,"disp":null,"ssn":false,"na":41},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["당근, 양파, 파를 각각 새끼손톱보다 작게 곱게 다진다.","작은 그릇에 달걀 1개를 풀고, 달걀과 같은 양의 물(껍데기로 재면 편하다)과 소금 한 꼬집을 넣어 잘 섞는다. 후추는 아주 살짝만 넣거나 생략한다.","다진 채소를 달걀물에 넣고 고루 섞은 뒤, 김이 오른 찜기에 그릇째 넣고 중불에서 10~12분 부드럽게 찐다.","젓가락으로 찔러 맑은 물이 나오면 꺼내서 한 김 식힌 뒤 숟가락으로 떠먹기 좋게 담아준다."],"steps_public":true,"nutri":{"kcal":46,"protein_g":4,"carb_g":1.3,"fat_g":2.5,"calcium_mg":18,"iron_mg":0.66,"sodium_mg":116,"na_flag":"ok"},"allergens":["난류(계란)"]}