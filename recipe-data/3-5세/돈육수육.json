{"menu":"돈육수육","title":"돼지고기수육","band":"3-5세","dish_type":"etc","source":"standard","cook_min":55,"wait_min":0,"yield_g":62,"ings":[{"n":"돼지고기","raw":"돼지고기_사태_생것","g":45,"disp":null,"ssn":false,"na":32},{"n":"파","raw":"파, 생것","g":10,"disp":"0.7큰술","ssn":true,"na":2},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"생강","raw":"생강, 뿌리줄기, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":1,"disp":"1/4작은술","ssn":true,"na":0}],"steps":["대파는 큼직하게 두세 토막 내고, 마늘 2~3쪽은 칼등으로 눌러 으깨고, 생강은 동전만 하게 저며 둔다.","냄비에 고기가 잠길 만큼 물을 붓고 손질한 향신채와 돼지고기 덩어리, 후춧가루 약간을 넣어 센불에서 끓인다.","물이 끓어오르면 중불로 줄여 40~50분간 푹 삶고, 젓가락으로 찔러 맑은 육즙이 나오면 건진다.","고기를 한 김 식힌 뒤 아이가 씹기 좋게 0.5cm 두께로 얇게 썰어, 다시 새끼손톱 크기로 잘라 접시에 담는다."],"steps_public":true,"nutri":{"kcal":82,"protein_g":9.4,"carb_g":2.4,"fat_g":3.6,"calcium_mg":12,"iron_mg":0.65,"sodium_mg":34,"na_flag":"ok"},"allergens":["돼지고기"]}