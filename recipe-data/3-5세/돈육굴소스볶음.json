{"menu":"돈육굴소스볶음","title":"돼지고기굴소스볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":14,"yield_g":92.5,"ings":[{"n":"돼지고기","raw":"돼지고기_등심_생것","g":55.4,"disp":null,"ssn":false,"na":23},{"n":"양파","raw":"양파_생것","g":13.9,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":6.9,"disp":null,"ssn":false,"na":2},{"n":"파","raw":"파, 생것","g":6.9,"disp":"0.5큰술","ssn":true,"na":1},{"n":"굴소스","raw":"굴 소스","g":4.2,"disp":null,"ssn":false,"na":191},{"n":"콩기름","raw":"콩기름","g":3.5,"disp":"1작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.4,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["돼지고기는 아이가 씹기 좋게 얇고 작게(2cm 크기) 썰고, 양파·당근·파도 잘게 썰고 마늘은 다진다.","볼에 돼지고기를 담고 다진 마늘, 굴소스 반 큰술, 참기름 약간을 넣어 버무린 뒤 10분쯤 재워 둔다(후추는 아주 조금만).","팬에 식용유를 두르고 중불에서 재운 고기를 3~4분, 속까지 하얗게 익을 때까지 볶는다.","당근·양파·파를 넣고 2~3분 더 볶아 채소가 부드러워지면 불을 끄고 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":147,"protein_g":14.9,"carb_g":5,"fat_g":7,"calcium_mg":10,"iron_mg":0.43,"sodium_mg":218,"na_flag":"ok"},"allergens":["대두","돼지고기","조개류"]}