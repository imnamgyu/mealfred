{"menu":"쑥갓어묵국","title":"쑥갓어묵국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":20,"wait_min":0,"yield_g":33.6,"ings":[{"n":"어묵","raw":"어묵, 튀긴것","g":15,"disp":null,"ssn":false,"na":105},{"n":"무","raw":"무, 조선무, 생것","g":10,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":3,"disp":null,"ssn":false,"na":0},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":2,"disp":null,"ssn":false,"na":44},{"n":"쑥갓","raw":"쑥갓_생것","g":2,"disp":null,"ssn":false,"na":3},{"n":"다시마","raw":"다시마, 말린것","g":1,"disp":null,"ssn":false,"na":31},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금_천일염_소금꽃","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":122}],"steps":["어묵은 뜨거운 물을 한 번 끼얹어 기름기를 걷어내고, 아이가 삼키기 좋게 2cm 정도의 납작한 조각으로 자른다(꼬치 어묵이면 꼬치는 반드시 빼고 자른다).","무·양파는 새끼손톱 크기로 얇게 썰고, 쑥갓은 씻어 2~3cm 길이로 썬다.","냄비에 찬물 3컵과 국물용 멸치·다시마 한 조각을 넣고 중불에서 10분 끓여 육수를 만든 뒤 건더기를 건진다.","육수에 무와 양파를 넣고 무가 투명해질 때까지 5분쯤 끓인다.","어묵을 넣어 한 번 더 끓어오르면 쑥갓·다진 마늘을 넣고 소금으로 심심하게 간한 뒤, 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":36,"protein_g":3.1,"carb_g":4.3,"fat_g":0.8,"calcium_mg":61,"iron_mg":0.44,"sodium_mg":306,"na_flag":"ok"},"allergens":["대두","밀"]}