{"menu":"소고기가지볶음","title":"쇠고기가지볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":25,"wait_min":0,"yield_g":56.8,"ings":[{"n":"소고기","raw":"소고기, 한우(1등급), 사태(앞사태), 생것","g":30,"disp":null,"ssn":false,"na":20},{"n":"가지","raw":"가지_생것","g":15,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["쇠고기는 새끼손톱 크기로 잘게 썰고, 가지는 0.5cm 두께 반달 모양으로 썬다.","대파는 송송 썰고 마늘은 곱게 다진다.","볼에 쇠고기를 담고 다진 마늘, 간장 반 작은술, 참기름, 후춧가루 아주 조금을 넣어 조물조물 밑간해 10분 둔다.","팬에 기름을 두르고 중불에서 밑간한 고기를 2~3분 볶아 겉면이 익으면 파와 가지를 넣는다.","가지가 말랑해질 때까지 3분쯤 더 볶고, 한 김 식혀 고기가 속까지 익었는지 확인한 뒤 낸다."],"steps_public":true,"nutri":{"kcal":78,"protein_g":7.5,"carb_g":1.8,"fat_g":4.3,"calcium_mg":7,"iron_mg":0.96,"sodium_mg":164,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}