{"menu":"소세지야채볶음","title":"소세지채소볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":100,"ings":[{"n":"소시지","raw":"소시지, 위너(비엔나)소시지","g":62.3,"disp":null,"ssn":false,"na":456},{"n":"양파","raw":"양파, 생것","g":13.9,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근, 뿌리, 생것","g":9.7,"disp":null,"ssn":false,"na":2},{"n":"파","raw":"파, 생것","g":6.9,"disp":"0.5큰술","ssn":true,"na":1},{"n":"콩기름","raw":"콩기름","g":3.5,"disp":"1작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":2.1,"disp":"1/2작은술","ssn":true,"na":100},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.4,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.3,"disp":"약간","ssn":true,"na":0}],"steps":["소시지는 통째로 주면 목에 걸릴 수 있으니 세로로 반 가른 뒤 0.5cm 두께로 얇게 어슷 썬다. 당근과 양파는 아이 한입 크기로 얇게 썬다.","파는 송송 썰고 마늘은 곱게 다져 둔다.","팬에 식용유를 한 큰술 두르고 약불에서 다진 마늘을 30초쯤 볶아 향을 낸 뒤, 당근과 양파를 넣고 중불로 2~3분 볶아 부드럽게 익힌다.","썰어둔 소시지와 파를 넣고 1~2분 더 볶다가 간장 반 작은술로 심심하게 간을 하고, 불을 끄고 참기름을 몇 방울 둘러 마무리한다. 한 김 식혀 아이에게 준다."],"steps_public":true,"nutri":{"kcal":205,"protein_g":10.1,"carb_g":8.6,"fat_g":14.3,"calcium_mg":26,"iron_mg":0.62,"sodium_mg":560,"na_flag":"over"},"allergens":["대두","밀","돼지고기"]}