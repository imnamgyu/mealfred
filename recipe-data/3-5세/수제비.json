{"menu":"수제비","title":"수제비","band":"3-5세","dish_type":"noodle","source":"standard","cook_min":40,"wait_min":0,"yield_g":36.2,"ings":[{"n":"밀","raw":"밀, 중력밀가루","g":23,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"호박","raw":"호박_애호박_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":1,"disp":null,"ssn":false,"na":22},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":108},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물을 붓고 멸치를 넣어 중불에서 10분쯤 끓여 육수를 낸 뒤 멸치는 건져 낸다.","밀가루에 뜨거운 물을 조금씩 부어 반죽하고, 젖은 면포나 랩으로 덮어 20분 쉬게 둔다.","애호박과 당근은 0.5cm 두께로 얇게 썰고, 파는 송송, 마늘은 다진다.","육수에 다진 마늘을 넣고 끓어오르면 반죽을 새끼손톱 두께로 얇게 뜯어 넣는다.","수제비가 떠오르면 애호박·당근·파를 넣고 5분 더 끓인 뒤 소금으로 심심하게 간하고 후춧가루는 아주 살짝만 뿌린다.","그릇에 담아 한 김 식혀, 큰 조각은 숟가락으로 잘라 준다."],"steps_public":true,"nutri":{"kcal":93,"protein_g":3.1,"carb_g":18.5,"fat_g":0.3,"calcium_mg":28,"iron_mg":0.34,"sodium_mg":132,"na_flag":"ok"},"allergens":["밀"]}