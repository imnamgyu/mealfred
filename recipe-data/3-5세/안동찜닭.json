{"menu":"안동찜닭","title":"안동찜닭","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":30,"wait_min":10,"yield_g":95.3,"ings":[{"n":"닭고기","raw":"닭고기_가슴(껍질 제거)_생것","g":50,"disp":null,"ssn":false,"na":23},{"n":"감자","raw":"감자, 대지, 생것","g":15,"disp":null,"ssn":false,"na":0},{"n":"양파","raw":"양파_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"당면","raw":"당면_고구마_말린것","g":7,"disp":null,"ssn":false,"na":1},{"n":"간장","raw":"간장, 개량, 산분해","g":5,"disp":"1작은술","ssn":true,"na":274},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"생강","raw":"생강, 뿌리줄기, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_황설탕","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금_천일염","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["감자·양파·당근을 아이가 씹기 좋게 2cm 크기로 깍둑 썬다.","닭고기는 한입 크기로 토막 내 끓는 물에 2~3분 데쳐 건진 뒤, 생강즙 약간과 소금·후추 아주 조금으로 밑간한다.","간장·황설탕·다진 마늘·참기름을 섞어 양념장을 만들고, 밑간한 닭에 부어 10분쯤 재워 둔다.","냄비에 닭과 채소를 담고 재료가 자작하게 잠길 만큼 물을 부어 중불에서 15분 정도 끓인다.","미리 물에 불려 둔 당면을 넣고 5분 더 끓인 뒤, 한 김 식혀 아이에게 준다. 당면은 길면 가위로 3cm 길이로 잘라 준다."],"steps_public":true,"nutri":{"kcal":105,"protein_g":12.4,"carb_g":11.1,"fat_g":1,"calcium_mg":15,"iron_mg":0.68,"sodium_mg":371,"na_flag":"review"},"allergens":["대두","밀","닭고기"]}