{"menu":"청포묵김무침","title":"청포묵김무침","band":"3-5세","dish_type":"side","source":"standard","cook_min":10,"wait_min":0,"yield_g":26.5,"ings":[{"n":"녹두묵","raw":"녹두묵","g":25,"disp":null,"ssn":false,"na":23},{"n":"간장","raw":"간장_재래","g":1,"disp":"1/4작은술","ssn":true,"na":80},{"n":"김","raw":"김, 참김, 말린것","g":0.3,"disp":null,"ssn":false,"na":4},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.1,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.1,"disp":"약간","ssn":true,"na":0},{"n":"참깨","raw":"참깨_흰깨_볶은것","g":0,"disp":"약간","ssn":true,"na":0}],"steps":["청포묵은 아이가 삼키기 좋게 3cm 길이, 1cm 두께 막대 모양으로 썬다.","끓는 물에 묵을 1분 데쳐 투명해지면 건져 찬물에 헹구고 물기를 뺀다.","작은 그릇에 다진 마늘 약간, 진간장 1작은술, 올리고당 1작은술, 참기름·깨소금 조금씩을 섞어 양념장을 만든다.","김은 마른 팬에 약불로 앞뒤 10초씩 구운 뒤 봉지에 넣고 부숴 김가루를 만든다.","큰 볼에 묵과 김가루를 담고 양념장을 부어 묵이 부서지지 않게 살살 버무려 낸다."],"steps_public":true,"nutri":{"kcal":12,"protein_g":0.2,"carb_g":2.6,"fat_g":0.1,"calcium_mg":3,"iron_mg":0.07,"sodium_mg":107,"na_flag":"ok"},"allergens":["대두","밀"]}