{"menu":"소고기무국","title":"쇠고기뭇국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":20,"wait_min":0,"yield_g":49.6,"ings":[{"n":"소고기","raw":"소고기_한우_양지_생것","g":30,"disp":null,"ssn":false,"na":17},{"n":"무","raw":"무, 조선무, 생것","g":14,"disp":null,"ssn":false,"na":2},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"참기름","raw":"참기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["소고기는 아이 한입 크기(새끼손톱 크기)로 썰고, 무는 0.5cm 두께의 얇은 네모 모양으로 나박나박 썬다.","파는 얇게 송송 썰고, 마늘은 곱게 다져 둔다.","냄비에 참기름을 조금 두르고 중불에서 소고기와 무를 2~3분 볶다가, 물을 붓고 센불로 끓어오르면 중약불로 낮춰 10분 정도 무가 투명해질 때까지 끓인다.","파와 마늘을 넣고 소금으로 아주 연하게 간을 맞춘 뒤 2분 더 끓인다(후추는 아이 국이라 생략하거나 아주 살짝만).","한 김 식혀 미지근할 때 그릇에 담아낸다."],"steps_public":true,"nutri":{"kcal":94,"protein_g":5.8,"carb_g":1,"fat_g":7.1,"calcium_mg":7,"iron_mg":0.67,"sodium_mg":199,"na_flag":"ok"},"allergens":["쇠고기"]}