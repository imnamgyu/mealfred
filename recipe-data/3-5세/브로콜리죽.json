{"menu":"브로콜리죽","title":"브로콜리죽","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":25,"wait_min":30,"yield_g":43.1,"ings":[{"n":"멥쌀","raw":"멥쌀_백미_생것","g":25,"disp":null,"ssn":false,"na":1},{"n":"브로콜리","raw":"브로콜리_생것","g":15,"disp":null,"ssn":false,"na":1},{"n":"간장","raw":"간장_재래","g":1.2,"disp":"1/4작은술","ssn":true,"na":96},{"n":"참기름","raw":"참기름","g":1.2,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["쌀 3큰술을 30분 이상 물에 불리고, 브로콜리 두세 송이와 마늘 반 쪽은 아이가 씹기 쉽게 잘게 다진다.","냄비에 참기름을 약간 두르고 중불에서 불린 쌀을 1~2분 볶아 고소한 향을 낸다.","다진 마늘과 브로콜리를 넣고 30초 정도 함께 볶는다.","물을 쌀의 5배쯤 붓고 센불에서 끓어오르면 약불로 줄여, 저어가며 15분 정도 푹 끓인다.","쌀알이 퍼지면 소금과 간장을 아주 조금씩 넣어 심심하게 간하고, 한 김 식혀 아이에게 준다."],"steps_public":true,"nutri":{"kcal":108,"protein_g":2.3,"carb_g":20.7,"fat_g":1.5,"calcium_mg":9,"iron_mg":0.21,"sodium_mg":277,"na_flag":"ok"},"allergens":["대두","밀"]}