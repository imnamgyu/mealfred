{"menu":"느타리버섯볶음","title":"느타리버섯볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":33.9,"ings":[{"n":"느타리버섯","raw":"느타리버섯_생것","g":20,"disp":null,"ssn":false,"na":0},{"n":"양파","raw":"양파_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"파","raw":"파_대파_생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72},{"n":"참깨","raw":"참깨, 흰색, 볶은것","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["느타리버섯은 밑동을 잘라내고 가늘게 찢은 뒤 끓는 물에 30초만 살짝 데쳐 건진다.","양파는 아이가 먹기 좋게 3cm 길이로 가늘게 채 썬다.","팬에 식용유를 두르고 중불에서 다진 마늘과 파를 먼저 볶아 향을 낸 다음 버섯과 양파를 넣어 3~4분 볶는다.","채소가 부드럽게 익으면 소금으로 심심하게 간하고 참기름과 참깨를 뿌린다.","아이 몫은 버섯을 새끼손톱 크기로 짧게 잘라 한 김 식혀서 준다."],"steps_public":true,"nutri":{"kcal":22,"protein_g":0.8,"carb_g":2,"fat_g":1.6,"calcium_mg":20,"iron_mg":0.21,"sodium_mg":73,"na_flag":"ok"},"allergens":["대두"]}