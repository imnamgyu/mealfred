{"menu":"두부소보로덮밥","title":"두부소보로덮밥","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":45,"wait_min":0,"yield_g":94.8,"ings":[{"n":"멥쌀","raw":"멥쌀, 백미, 생것","g":50,"disp":null,"ssn":false,"na":1},{"n":"두부","raw":"두부","g":30,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근, 뿌리, 생것","g":10,"disp":null,"ssn":false,"na":3},{"n":"파","raw":"파, 생것","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":1,"disp":"1/4작은술","ssn":true,"na":48},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"설탕","raw":"설탕, 백설탕","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"깨소금","raw":"깨소금, 가루, 볶은것","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["쌀을 30분 불려 밥을 짓고, 두부는 키친타월로 물기를 눌러 뺀 뒤 포크로 곱게 으깬다.","당근은 새끼손톱보다 작게 다지고, 간장·설탕 약간·다진 마늘·깨소금을 섞어 양념장을 만들어 둔다.","팬에 기름을 조금 두르고 중불에서 다진 파를 30초 볶아 향을 낸 뒤 두부와 당근을 넣고 3~4분 볶는다.","두부의 수분이 보슬보슬하게 날아가면 양념장을 넣고 약불에서 1~2분 더 볶는다.","따뜻한 밥 위에 두부소보로를 얹고 한 김 식혀서 아이 숟가락으로 비벼 준다."],"steps_public":true,"nutri":{"kcal":224,"protein_g":6.4,"carb_g":42.6,"fat_g":2.2,"calcium_mg":29,"iron_mg":1.23,"sodium_mg":52,"na_flag":"ok"},"allergens":["대두","밀"]}