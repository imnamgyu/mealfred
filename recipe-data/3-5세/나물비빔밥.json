{"menu":"나물비빔밥","title":"삼색나물비빔밥","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":40,"wait_min":0,"yield_g":65.2,"ings":[{"n":"멥쌀","raw":"멥쌀_백미_생것","g":40,"disp":null,"ssn":false,"na":1},{"n":"고사리","raw":"고사리, 말린것","g":7,"disp":null,"ssn":false,"na":1},{"n":"시금치","raw":"시금치_생것","g":7,"disp":null,"ssn":false,"na":2},{"n":"콩나물","raw":"콩나물_생것","g":7,"disp":null,"ssn":false,"na":0},{"n":"고추장","raw":"고추장, 개량","g":3,"disp":"1/2작은술","ssn":true,"na":75},{"n":"참기름","raw":"참기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72}],"steps":["쌀은 30분쯤 물에 불렸다가 평소보다 물을 약간 넉넉히 잡아 진밥으로 짓는다.","시금치와 콩나물은 끓는 물에 각각 1~2분 데친 뒤 찬물에 헹궈 물기를 꼭 짜고, 3cm 길이로 짧게 잘라 소금 한 꼬집과 참기름으로 조물조물 무친다.","고사리는 끓는 물에 푹 삶아 부드럽게 만든 뒤 물기를 빼고 2cm 길이로 잘게 썰어, 기름 두른 팬에 중불로 1~2분 살짝 볶고 소금·참기름으로 버무린다.","아이 그릇에 밥을 담고 세 가지 나물을 색깔별로 올린 뒤, 고추장 대신 간장 몇 방울이나 아주 적은 고추장과 참기름을 넣어 부드럽게 비벼준다."],"steps_public":true,"nutri":{"kcal":185,"protein_g":5.2,"carb_g":37.5,"fat_g":1.6,"calcium_mg":25,"iron_mg":0.8,"sodium_mg":150,"na_flag":"ok"},"allergens":["대두","밀"]}