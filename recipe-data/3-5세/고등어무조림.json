{"menu":"고등어무조림","title":"고등어무조림","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":25,"wait_min":0,"yield_g":65.7,"ings":[{"n":"고등어","raw":"고등어, 생것","g":45,"disp":null,"ssn":false,"na":34},{"n":"무","raw":"무, 조선무, 생것","g":15,"disp":null,"ssn":false,"na":2},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"청주","raw":"청주, 알코올 16%","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은색, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["고등어는 한 토막씩 먹기 좋게 자르고, 무는 새끼손톱보다 조금 큰 크기로 깍둑썰고, 대파는 어슷하게 썬다.","간장·다진 마늘·청주를 섞어 양념장을 만든다(청주는 끓이며 날아가고, 아이용은 후추를 빼도 좋다).","냄비 바닥에 무를 깔고 그 위에 고등어를 올린 뒤 양념장을 끼얹고 물을 자작하게 부어, 중불에서 15분 정도 무가 푹 무를 때까지 조린다.","무가 다 익으면 대파를 올리고 뚜껑을 덮어 약불에서 1~2분 숨을 죽인다.","한 김 식힌 뒤 고등어 살은 가시를 꼼꼼히 발라 잘게 부수어 내준다."],"steps_public":true,"nutri":{"kcal":90,"protein_g":9.5,"carb_g":1.5,"fat_g":4.7,"calcium_mg":17,"iron_mg":0.83,"sodium_mg":180,"na_flag":"ok"},"allergens":["대두","밀","고등어"]}