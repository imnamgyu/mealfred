{"menu":"참치마요주먹밥","title":"참치마요주먹밥","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":63.5,"ings":[{"n":"멥쌀","raw":"멥쌀, 백미, 생것","g":33.7,"disp":null,"ssn":false,"na":1},{"n":"다랑어","raw":"다랑어, 가다랑어, 통조림, 유지","g":14.4,"disp":null,"ssn":false,"na":23},{"n":"양파","raw":"양파, 생것","g":9.6,"disp":null,"ssn":false,"na":0},{"n":"김","raw":"김, 참김, 구운것","g":2.9,"disp":null,"ssn":false,"na":14},{"n":"마요네즈","raw":"마요네즈, 난황","g":1.9,"disp":"1/2작은술","ssn":true,"na":9},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":173},{"n":"참깨","raw":"참깨, 흰깨, 볶은것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은색, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["통조림 참치는 체에 밭쳐 기름을 충분히 뺀 뒤, 마른 팬에 중불로 1~2분 살짝 볶아 식힌다.","양파는 새끼손톱보다 작게 잘게 다진다(매운맛이 걱정되면 살짝 볶아 식혀도 좋다).","쌀에 찹쌀을 조금 섞어 밥을 짓고, 뜨거울 때 참기름·깨·소금 약간을 섞은 뒤 한 김 식힌다.","식힌 참치에 마요네즈와 다진 양파를 섞어 속을 만들고, 밥과 고루 섞는다.","아이 한입 크기(탁구공보다 작게)로 동글동글 뭉쳐 김가루에 굴려 낸다."],"steps_public":true,"nutri":{"kcal":174,"protein_g":6.8,"carb_g":28.8,"fat_g":3.5,"calcium_mg":16,"iron_mg":1.15,"sodium_mg":220,"na_flag":"ok"},"allergens":["난류(계란)","대두"]}