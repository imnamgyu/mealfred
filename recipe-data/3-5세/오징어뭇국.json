{"menu":"오징어뭇국","title":"오징어뭇국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":25,"wait_min":0,"yield_g":47.1,"ings":[{"n":"오징어","raw":"오징어, 생것","g":30,"disp":null,"ssn":false,"na":60},{"n":"무","raw":"무, 조선무, 생것","g":10,"disp":null,"ssn":false,"na":1},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 재래","g":2,"disp":"1/2작은술","ssn":true,"na":160},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":1,"disp":null,"ssn":false,"na":22},{"n":"다시마","raw":"다시마, 말린것","g":0.5,"disp":null,"ssn":false,"na":16},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물 2컵, 국물용 멸치 서너 마리, 다시마 한 조각을 넣고 10분쯤 끓여 육수를 낸 뒤 건더기는 건져낸다.","무는 2×1cm 크기의 얇은 나박썰기로, 대파는 0.5cm 두께로 썬다.","오징어는 깨끗이 씻어 아이가 씹기 좋게 새끼손톱 크기로 잘게 썬다. 질기지 않도록 얇게 저미면 좋다.","육수에 무를 넣고 중불에서 5분쯤 끓여 무가 반쯤 투명해지면 오징어를 넣는다.","다진 마늘 약간, 대파, 국간장 조금을 넣고 2~3분 더 끓인 뒤, 한 김 식혀 담아낸다."],"steps_public":true,"nutri":{"kcal":37,"protein_g":6.5,"carb_g":1.4,"fat_g":0.5,"calcium_mg":32,"iron_mg":0.28,"sodium_mg":259,"na_flag":"ok"},"allergens":["대두","밀","오징어"]}