{"menu":"탕수육","title":"탕수육","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":73.5,"ings":[{"n":"돼지고기","raw":"돼지고기_등심_생것","g":30,"disp":null,"ssn":false,"na":13},{"n":"콩기름","raw":"콩기름","g":10,"disp":"0.7큰술","ssn":true,"na":0},{"n":"달걀","raw":"달걀, 생것","g":5,"disp":null,"ssn":false,"na":7},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"밀","raw":"밀, 튀김가루","g":5,"disp":null,"ssn":false,"na":44},{"n":"양파","raw":"양파_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"오이","raw":"오이, 다다기, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"전분","raw":"전분, 감자, 가루","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"식초","raw":"식초, 사과식초","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["돼지고기는 아이 한입 크기(2cm 정도)로 썰고, 당근·양파·오이는 얇고 잘게 썬다.","볼에 튀김가루, 달걀, 물을 섞어 걸쭉한 튀김옷을 만들어 고기에 고루 입힌다(아이용은 후추 생략).","냄비에 기름을 붓고 중불에서 170도쯤(반죽을 떨어뜨리면 바로 떠오르는 정도) 달군 뒤 고기를 3~4분간 노릇하게 튀겨 키친타월에 기름을 뺀다.","작은 그릇에 간장, 설탕, 소금 약간, 식초, 물을 섞어 소스 물을 만들어 둔다.","팬에 기름을 살짝 두르고 중불에서 당근·양파·오이를 1~2분 볶다가 소스 물을 부어 끓이고, 감자전분과 물을 1:1로 섞은 녹말물을 조금씩 넣어 걸쭉하게 만든다.","튀긴 고기에 소스를 끼얹고 한 김 식혀, 아이가 먹기 전에 큰 조각은 한 번 더 잘라 준다."],"steps_public":true,"nutri":{"kcal":177,"protein_g":8.5,"carb_g":8.2,"fat_g":11.8,"calcium_mg":11,"iron_mg":0.37,"sodium_mg":281,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","돼지고기"]}