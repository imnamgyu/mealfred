{"menu":"팽이버섯맑은국","title":"팽이버섯맑은국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":30,"wait_min":0,"yield_g":27.9,"ings":[{"n":"팽이버섯","raw":"팽이버섯_생것","g":15,"disp":null,"ssn":false,"na":1},{"n":"두부","raw":"두부","g":10,"disp":null,"ssn":false,"na":0},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":1,"disp":null,"ssn":false,"na":22},{"n":"파","raw":"파, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"다시마","raw":"다시마, 말린것","g":0.5,"disp":null,"ssn":false,"na":16},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":144}],"steps":["냄비에 물 2컵, 멸치 4~5마리, 다시마 한 조각을 넣고 중불에서 15분 끓인 뒤 건더기를 모두 건져낸다.","팽이버섯은 밑동을 잘라내고 가닥가닥 잘게 찢은 뒤, 어린 아이라면 2cm 길이로 짧게 자른다(다른 버섯으로 바꿔도 좋다).","다른 냄비에 참기름 1작은술을 두르고 중불에서 버섯을 1~2분 볶는다.","만들어 둔 육수를 붓고 3~4분 끓인다.","송송 썬 대파와 소금 한 꼬집을 넣어 심심하게 간을 맞추고, 한 김 식혀 담아 준다."],"steps_public":true,"nutri":{"kcal":17,"protein_g":2,"carb_g":1.7,"fat_g":0.6,"calcium_mg":31,"iron_mg":0.47,"sodium_mg":182,"na_flag":"ok"},"allergens":["대두"]}