{"menu":"게살볶음밥","title":"게살볶음밥","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":10,"wait_min":30,"yield_g":80.7,"ings":[{"n":"멥쌀","raw":"멥쌀_백미_생것","g":40,"disp":null,"ssn":false,"na":1},{"n":"게맛살","raw":"게맛살","g":15,"disp":null,"ssn":false,"na":100},{"n":"달걀","raw":"달걀, 생것","g":10,"disp":null,"ssn":false,"na":14},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["쌀을 30분쯤 물에 담가두었다가 밥을 지어 준비한다(전날 남은 밥 반 공기여도 좋다).","게맛살은 아이가 씹기 좋게 결대로 잘게 찢고, 파와 당근은 새끼손톱보다 작게 다지고, 달걀 1개는 작은 그릇에 잘 풀어둔다.","팬에 식용유를 살짝 두르고 중불에서 파와 당근을 1~2분 볶아 향을 내고, 게맛살을 넣어 30초쯤 더 볶는다.","풀어둔 달걀을 부어 젓가락으로 저어가며 보슬보슬하게 익힌다.","밥을 넣고 중불에서 2분 정도 고루 섞어 볶다가 간장 약간으로 아이 입맛에 맞게 심심하게 간하고, 불을 끈 뒤 참기름 몇 방울로 마무리해 한 김 식혀 담는다."],"steps_public":true,"nutri":{"kcal":208,"protein_g":6,"carb_g":35.6,"fat_g":4,"calcium_mg":43,"iron_mg":0.52,"sodium_mg":260,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","게"]}