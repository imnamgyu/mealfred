{"menu":"차돌박이숙주볶음","title":"차돌박이숙주볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":15,"yield_g":95.7,"ings":[{"n":"소고기","raw":"소고기_한우(1++등급)_양지(차돌박이)_생것","g":40,"disp":null,"ssn":false,"na":25},{"n":"숙주나물","raw":"숙주나물_생것","g":20,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"배","raw":"배_신고_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"사과","raw":"사과, 부사(후지), 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"된장","raw":"된장_재래","g":3,"disp":"1/2작은술","ssn":true,"na":155},{"n":"간장","raw":"간장_재래","g":2,"disp":"1/2작은술","ssn":true,"na":160},{"n":"맛술","raw":"맛술","g":2,"disp":"1/2작은술","ssn":true,"na":1},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"생강","raw":"생강, 뿌리줄기, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참깨","raw":"참깨_흰깨_볶은것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["차돌박이는 아이가 씹기 좋게 2~3cm 폭으로 자르고, 다진 마늘·생강즙·미림 약간으로 밑간해 둔다.","숙주는 씻어 물기를 빼고, 당근과 양파는 새끼손톱 크기로 잘게 썬다.","사과와 배를 믹서에 곱게 갈고, 여기에 다진 마늘·미림·된장·간장·후춧가루 약간·참기름·참깨를 섞어 과일양념장을 만든다.","양념장에 밑간한 고기를 넣고 10~15분 재운다.","팬에 식용유를 두르고 중불에서 고기를 먼저 볶다가 숙주·당근·양파를 넣어 센불에서 2~3분 재빨리 볶는다.","한 김 식힌 뒤 긴 숙주는 가위로 짧게 잘라 아이 접시에 담는다."],"steps_public":true,"nutri":{"kcal":171,"protein_g":6.9,"carb_g":4.4,"fat_g":13.5,"calcium_mg":18,"iron_mg":1.12,"sodium_mg":343,"na_flag":"ok"},"allergens":["대두","밀"]}