{"menu":"돼지고기폭찹","title":"돼지고기폭찹(경남)","band":"3-5세","dish_type":"etc","source":"standard","cook_min":15,"wait_min":0,"yield_g":73.4,"ings":[{"n":"돼지고기","raw":"돼지고기_목심(목심살)_생것","g":40,"disp":null,"ssn":false,"na":26},{"n":"양파","raw":"양파_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"피망","raw":"피망, 초록색, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"고기소스","raw":"고기 소스, 소불고기양념","g":4,"disp":null,"ssn":false,"na":24},{"n":"토마토케첩","raw":"토마토 케첩","g":4,"disp":null,"ssn":false,"na":42},{"n":"콩기름","raw":"콩기름","g":3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"물엿","raw":"물엿","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금_천일염","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":36}],"steps":["돼지고기는 아이가 씹기 좋게 새끼손톱 크기(사방 1.5~2cm)로 자른다.","양파·청피망·당근도 고기와 비슷한 크기의 얇은 편(0.5cm 두께)으로 썬다.","작은 볼에 스테이크소스·케첩·설탕·물엿·다진 마늘을 조금씩 섞어 소스를 미리 만들어 둔다(후추·소금은 아이 입맛에 맞게 아주 조금만).","중불로 달군 팬에 기름을 살짝 두르고 돼지고기를 3~4분 볶아 겉면이 하얗게 익으면 채소를 넣어 2분 더 볶는다.","만들어 둔 소스를 붓고 약불에서 1~2분 졸이듯 버무린 뒤, 한 김 식혀 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":144,"protein_g":7.3,"carb_g":6,"fat_g":9.6,"calcium_mg":9,"iron_mg":0.42,"sodium_mg":130,"na_flag":"ok"},"allergens":["대두","돼지고기","토마토"]}