{"menu":"멸치볶음","title":"잔멸치볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":16,"ings":[{"n":"멸치","raw":"멸치, 잔멸치, 삶아서 말린것","g":10,"disp":null,"ssn":false,"na":265},{"n":"간장","raw":"간장_재래","g":2,"disp":"1/2작은술","ssn":true,"na":160},{"n":"물엿","raw":"물엿","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":1,"disp":"1/4작은술","ssn":true,"na":48},{"n":"설탕","raw":"설탕, 가루","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"참깨","raw":"참깨_흰깨_볶은것","g":0.5,"disp":"약간","ssn":true,"na":0}],"steps":["기름 없이 달군 팬에 잔멸치 한 줌을 넣고 센불에서 1분 정도 저어가며 볶은 뒤, 체에 쳐서 가루를 털어내면 비린내가 줄어든다.","팬을 다시 달궈 식용유를 조금 두르고 중불에서 멸치를 1~2분 바삭하게 볶아 접시에 덜어 둔다.","같은 팬에 간장 1작은술, 설탕 반 작은술, 올리고당 1작은술을 넣고 약불에서 보글보글 살짝 끓여 양념장을 만든다.","양념이 끓어오르면 볶아둔 멸치를 넣고 약불에서 1분간 재빨리 버무리듯 볶는다.","간이 배면 불을 끄고 통깨를 뿌린 뒤, 한 김 식혀 부드러워졌을 때 낸다."],"steps_public":true,"nutri":{"kcal":35,"protein_g":4.6,"carb_g":2.5,"fat_g":0.7,"calcium_mg":67,"iron_mg":0.15,"sodium_mg":472,"na_flag":"review"},"allergens":["대두","밀"]}