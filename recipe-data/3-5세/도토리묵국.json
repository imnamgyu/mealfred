{"menu":"도토리묵국","title":"온도토리묵국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":15,"wait_min":0,"yield_g":116,"ings":[{"n":"도토리묵","raw":"도토리묵","g":100,"disp":null,"ssn":false,"na":76},{"n":"김치","raw":"김치, 배추 김치","g":8,"disp":null,"ssn":false,"na":44},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":2,"disp":null,"ssn":false,"na":44},{"n":"참기름","raw":"참기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":0.5,"disp":"약간","ssn":true,"na":40},{"n":"김","raw":"김, 참김, 말린것","g":0.5,"disp":null,"ssn":false,"na":7},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물을 붓고 멸치를 넣어 중불에서 10분쯤 끓여 육수를 낸 뒤, 멸치를 건지고 간장으로 심심하게 간한다.","도토리묵은 아이가 삼키기 좋게 1cm 두께의 짧은 막대 모양으로 썰고, 김은 살짝 구워 잘게 부숴 김가루를 만든다.","배추김치는 씻어 잘게 썰고(아이용은 매운 양념을 물에 헹궈낸다) 파도 잘게 썰고 마늘은 다진다.","썰어둔 김치·파·마늘을 참기름에 조물조물 무쳐 고명을 만든다.","그릇에 묵을 담고 따뜻한 육수를 부은 뒤 고명과 김가루를 올려, 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":72,"protein_g":1.9,"carb_g":12.2,"fat_g":1.7,"calcium_mg":65,"iron_mg":0.68,"sodium_mg":211,"na_flag":"ok"},"allergens":["대두","밀","새우"]}