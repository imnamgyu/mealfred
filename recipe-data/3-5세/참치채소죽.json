{"menu":"참치채소죽","title":"참치채소죽","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":20,"wait_min":30,"yield_g":65.9,"ings":[{"n":"가다랑어","raw":"가다랑어, 유지통조림","g":28,"disp":null,"ssn":false,"na":12},{"n":"멥쌀","raw":"멥쌀_백미_생것","g":25,"disp":null,"ssn":false,"na":1},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"참기름","raw":"참기름","g":1.2,"disp":"1/4작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["쌀 1/4컵은 30분 이상 물에 불리고, 파·마늘·양파·당근은 모두 새끼손톱보다 작게 다진다.","캔 참치는 체에 밭쳐 기름을 빼고, 뜨거운 물을 한 번 부어 주면 더 담백해진다.","냄비에 참기름 1작은술을 두르고 약불에서 다진 채소를 1~2분 볶다가, 불린 쌀을 넣고 물 1.5컵을 부어 중불로 끓인다.","쌀알이 퍼지기 시작하면 참치를 넣고 약불로 10분쯤 저어 가며 뭉근히 끓인다.","소금 한 꼬집으로 간을 맞추고 참기름 몇 방울로 마무리한 뒤, 한 김 식혀 아이에게 준다."],"steps_public":true,"nutri":{"kcal":153,"protein_g":9.9,"carb_g":20.6,"fat_g":2.8,"calcium_mg":11,"iron_mg":2.35,"sodium_mg":195,"na_flag":"ok"},"allergens":[]}