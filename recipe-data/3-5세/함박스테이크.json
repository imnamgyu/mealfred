{"menu":"함박스테이크","title":"함박스테이크","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":25,"wait_min":0,"yield_g":64.5,"ings":[{"n":"돼지고기","raw":"돼지고기, 뒷다리(볼기살), 생것","g":15,"disp":null,"ssn":false,"na":8},{"n":"소고기","raw":"소고기, 한우(1++등급), 앞다리(꾸리살), 생것","g":15,"disp":null,"ssn":false,"na":8},{"n":"양파","raw":"양파, 생것","g":8,"disp":null,"ssn":false,"na":0},{"n":"달걀","raw":"달걀, 생것","g":7,"disp":null,"ssn":false,"na":10},{"n":"당근","raw":"당근, 뿌리, 생것","g":6,"disp":null,"ssn":false,"na":2},{"n":"돈까스소스","raw":"돈까스 소스","g":4,"disp":null,"ssn":false,"na":null},{"n":"밀","raw":"밀, 빵가루","g":4,"disp":null,"ssn":false,"na":12},{"n":"콩기름","raw":"콩기름","g":3.5,"disp":"1작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금, 정제염","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.5,"disp":"약간","ssn":true,"na":0}],"steps":["양파 4분의 1개와 당근 한 토막을 새끼손톱보다 작게 곱게 다진다.","볼에 다진 돼지고기와 쇠고기를 담고 다진 양파·당근·마늘을 넣어 섞는다.","달걀 반 개, 빵가루 2큰술, 소금 한 꼬집, 후추 아주 조금을 더해 끈기가 생길 때까지 5분 정도 치댄 뒤, 아이 손바닥만 하게 1.5cm 두께로 납작 둥글게 빚는다.","팬에 기름을 두르고 중불에서 앞뒤 2분씩 굽고, 약불로 줄여 뚜껑을 덮고 4~5분 더 익혀 속까지 완전히 익힌다. 갈라 봤을 때 붉은 기가 없어야 한다.","돈가스 소스를 살짝 뿌리고 한 김 식힌 뒤, 아이가 포크로 먹기 좋게 한입 크기로 잘라 준다."],"steps_public":true,"nutri":{"kcal":115,"protein_g":7.7,"carb_g":6.2,"fat_g":6.3,"calcium_mg":21,"iron_mg":0.36,"sodium_mg":219,"na_flag":"ok"},"allergens":["대두","돼지고기"]}