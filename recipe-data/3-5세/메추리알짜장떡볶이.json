{"menu":"메추리알짜장떡볶이","title":"짜장떡볶이","band":"3-5세","dish_type":"snack","source":"standard","cook_min":15,"wait_min":10,"yield_g":108,"ings":[{"n":"멥쌀떡","raw":"멥쌀떡, 가래떡","g":76.9,"disp":null,"ssn":false,"na":201},{"n":"양파","raw":"양파, 생것","g":10.8,"disp":null,"ssn":false,"na":0},{"n":"어묵","raw":"어묵, 튀긴것","g":9.2,"disp":null,"ssn":false,"na":65},{"n":"짜장소스","raw":"짜장 소스","g":7.7,"disp":null,"ssn":false,"na":404},{"n":"파","raw":"파, 생것","g":2.3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":0.8,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0}],"steps":["떡볶이떡은 미지근한 물에 10분쯤 담가 말랑하게 불리고, 굳은 떡은 아이가 씹기 좋게 2cm 길이로 잘라 둔다.","어묵은 꼬치를 빼고 한입 크기로, 양파와 파는 잘게 썰고 마늘은 다진다. 메추리알은 반으로 잘라 준비한다.","팬에 식용유를 두르고 중불에서 어묵·양파·파·마늘을 2분쯤 볶는다.","짜장가루와 물 반 컵을 넣고 잘 풀어가며 끓이다가 떡과 메추리알을 넣고 약불로 3~4분, 소스가 걸쭉해질 때까지 저어가며 익힌 뒤 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":235,"protein_g":5.8,"carb_g":48.6,"fat_g":2,"calcium_mg":22,"iron_mg":0.42,"sodium_mg":670,"na_flag":"over"},"allergens":["대두","밀"]}