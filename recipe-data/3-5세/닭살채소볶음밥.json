{"menu":"닭살채소볶음밥","title":"채소볶음밥","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":87.8,"ings":[{"n":"멥쌀","raw":"멥쌀_백미_생것","g":40,"disp":null,"ssn":false,"na":1},{"n":"당근","raw":"당근_뿌리_생것","g":12,"disp":null,"ssn":false,"na":3},{"n":"양파","raw":"양파_생것","g":12,"disp":null,"ssn":false,"na":0},{"n":"호박","raw":"호박_애호박_생것","g":12,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["쌀을 불려 밥을 지어 두거나, 미리 지어 둔 밥 한 공기를 준비한다.","애호박·양파·당근·파는 새끼손톱보다 작게 잘게 썰고, 마늘은 다진다.","작은 그릇에 간장 1작은술, 참기름 반 작은술, 후춧가루 살짝을 섞어 양념장을 만든다.","팬에 식용유를 두르고 중불에서 마늘을 30초쯤 볶아 향을 내고, 썰어 둔 채소를 넣어 3~4분간 부드러워질 때까지 볶는다.","밥을 넣어 골고루 섞으며 볶다가 양념장을 둘러 1~2분 더 볶고, 한 김 식혀 담아낸다."],"steps_public":true,"nutri":{"kcal":187,"protein_g":3.5,"carb_g":34.9,"fat_g":3.1,"calcium_mg":12,"iron_mg":0.3,"sodium_mg":149,"na_flag":"ok"},"allergens":["대두","밀"]}