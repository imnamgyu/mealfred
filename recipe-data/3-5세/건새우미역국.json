{"menu":"건새우미역국","title":"건새우미역국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":30,"wait_min":0,"yield_g":7,"ings":[{"n":"미역","raw":"미역, 말린것","g":3,"disp":null,"ssn":false,"na":226},{"n":"새우","raw":"새우, 꽃새우, 삶아서 말린것","g":2,"disp":null,"ssn":false,"na":70},{"n":"간장","raw":"간장, 재래","g":1,"disp":"1/4작은술","ssn":true,"na":80},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.5,"disp":"약간","ssn":true,"na":0}],"steps":["마른 미역 한 줌을 물에 10분쯤 불린 뒤, 아이가 먹기 좋게 2~3cm 길이로 자르고 마늘은 곱게 다진다.","냄비에 참기름을 한 작은술 두르고 중불에서 다진 마늘과 미역을 1~2분 볶아 고소한 향을 낸다.","물 두 컵을 붓고 건새우를 넣어 센불로 끓이다가, 끓어오르면 약불로 줄여 10분 정도 뭉근히 끓인다.","국간장으로 심심하게 간을 맞추고, 한 김 식혀 아이에게 담아준다."],"steps_public":true,"nutri":{"kcal":17,"protein_g":1.8,"carb_g":1.7,"fat_g":0.8,"calcium_mg":115,"iron_mg":0.5,"sodium_mg":376,"na_flag":"review"},"allergens":["대두","밀","새우"]}