{"menu":"오징어볶음","title":"오징어볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":51.8,"ings":[{"n":"오징어","raw":"오징어, 생것","g":40,"disp":null,"ssn":false,"na":80},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["오징어는 껍질을 벗겨 아이가 씹기 좋게 1.5cm 폭으로 잘게 썰고, 파는 송송 썰고, 마늘은 다진다.","중불로 달군 팬에 식용유를 두르고 다진 마늘을 30초 볶아 향을 낸다.","오징어를 넣고 센불에서 2~3분, 하얗게 익고 살짝 오그라들 때까지 재빨리 볶는다.","파를 넣고 30초 더 볶다가 간장 1작은술로 심심하게 간한다. 아이용이라 후춧가루는 빼거나 아주 조금만 쓴다.","불을 끄고 참기름 몇 방울을 두른 뒤 한 김 식혀, 질기지 않은지 한 조각 확인하고 내어준다."],"steps_public":true,"nutri":{"kcal":68,"protein_g":8,"carb_g":1.2,"fat_g":3.3,"calcium_mg":7,"iron_mg":0.19,"sodium_mg":224,"na_flag":"ok"},"allergens":["대두","밀","오징어"]}