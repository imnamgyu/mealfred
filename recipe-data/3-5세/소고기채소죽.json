{"menu":"소고기채소죽","title":"쇠고기채소죽","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":60,"wait_min":10,"yield_g":62.9,"ings":[{"n":"멥쌀","raw":"멥쌀_백미_생것","g":25,"disp":null,"ssn":false,"na":1},{"n":"소고기","raw":"소고기, 한우(1++등급), 앞다리(앞다리살), 생것","g":25,"disp":null,"ssn":false,"na":14},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"참기름","raw":"참기름","g":1.2,"disp":"1/4작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["쌀 반 컵은 30분 이상 물에 불려 두고, 파·마늘·양파·당근은 쌀알만큼 잘게 다진다.","다진 소고기는 찬물에 10분 담가 핏물을 빼고 체에 밭쳐 물기를 제거한다.","냄비에 참기름 1작은술을 두르고 약불에서 다진 채소를 1~2분 볶다가, 불린 쌀을 넣고 함께 볶은 뒤 물 3컵을 붓고 센불에서 끓인다.","끓어오르면 소고기를 넣고 약불로 낮춰 15~20분, 쌀알이 푹 퍼질 때까지 저어가며 끓인다.","소금으로 아주 약하게 간하고 참기름 몇 방울로 마무리한 뒤, 한 김 식혀 미지근할 때 아이에게 준다."],"steps_public":true,"nutri":{"kcal":159,"protein_g":6.6,"carb_g":20.5,"fat_g":5,"calcium_mg":6,"iron_mg":0.9,"sodium_mg":197,"na_flag":"ok"},"allergens":["쇠고기"]}