{"menu":"맑은육개장","title":"육개장","band":"3-5세","dish_type":"etc","source":"standard","cook_min":30,"wait_min":0,"yield_g":48.7,"ings":[{"n":"소고기","raw":"소고기, 한우, 양지, 생것","g":24,"disp":null,"ssn":false,"na":13},{"n":"고사리","raw":"고사리, 데친것","g":5,"disp":null,"ssn":false,"na":0},{"n":"무","raw":"무, 조선무, 생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"숙주나물","raw":"숙주나물, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"토란대","raw":"토란대, 줄기, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 재래","g":0.5,"disp":"약간","ssn":true,"na":40},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":144},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물 3컵과 국거리용 쇠고기 한 줌을 넣고 중불에서 20분 정도 푹 끓여 국물을 낸 뒤, 익은 고기는 건져 한 김 식혀 아이가 씹기 좋게 잘게 찢는다.","숙주·고사리·토란대는 끓는 물에 살짝 데쳐 물기를 짜고, 질긴 나물은 3cm 길이로 짧게 썬다.","무는 새끼손톱 크기로 얇게 나박썰고, 파는 송송 썰고, 마늘은 곱게 다진다.","육수에 무를 먼저 넣어 5분쯤 끓이다가 찢어 둔 고기와 고사리·토란대·숙주·파를 순서대로 넣고 중불에서 한 번 더 끓어오르게 한다.","다진 마늘과 고춧가루 아주 조금(아이용이라면 생략 가능)을 넣고 소금·간장으로 심심하게 간한 뒤, 한 김 식혀 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":66,"protein_g":4.9,"carb_g":1.3,"fat_g":4.5,"calcium_mg":9,"iron_mg":0.58,"sodium_mg":199,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}