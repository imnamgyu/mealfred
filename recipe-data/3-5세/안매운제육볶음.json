{"menu":"안매운제육볶음","title":"제육볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":15,"yield_g":61.3,"ings":[{"n":"돼지고기","raw":"돼지고기_삼겹살(삼겹살)_생것","g":41.5,"disp":null,"ssn":false,"na":23},{"n":"양파","raw":"양파_생것","g":6.9,"disp":null,"ssn":false,"na":0},{"n":"고추장","raw":"고추장, 개량","g":4.2,"disp":"1작은술","ssn":true,"na":103},{"n":"간장","raw":"간장_재래","g":2.8,"disp":"1/2작은술","ssn":true,"na":222},{"n":"물엿","raw":"물엿","g":2.8,"disp":"1/2작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":1.4,"disp":"1/4작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":1.4,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["돼지고기는 아이가 씹기 좋게 새끼손톱 두 배 정도 크기로 얇게 썰고, 마늘 반 쪽은 곱게 다진다.","양파 1/4개는 가늘게 채 썰고, 파는 얇고 비스듬하게 썬다.","볼에 고기를 담고 다진 마늘, 고추장 아주 조금(또는 순한 고추장), 간장 1작은술, 물엿 1작은술을 넣어 조물조물 무쳐 10분 재운다.","달군 팬에 식용유를 두르고 중불에서 재운 고기를 4~5분 볶아 속까지 익힌다.","양파와 파를 넣어 2분 더 볶고, 불을 끈 뒤 참기름 몇 방울로 마무리해 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":198,"protein_g":5.9,"carb_g":5.2,"fat_g":16.4,"calcium_mg":6,"iron_mg":0.26,"sodium_mg":348,"na_flag":"ok"},"allergens":["대두","밀","돼지고기"]}