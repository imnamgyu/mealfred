{"menu":"쇠고기육전","title":"쇠고기육전","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":41.8,"ings":[{"n":"소고기","raw":"소고기, 한우, 등심, 생것","g":30,"disp":null,"ssn":false,"na":17},{"n":"달걀","raw":"달걀, 생것","g":5,"disp":null,"ssn":false,"na":7},{"n":"찹쌀","raw":"찹쌀, 가루","g":5,"disp":null,"ssn":false,"na":0},{"n":"콩기름","raw":"콩기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["쇠고기(육전용 얇은 것) 2~3장은 아이 입 크기인 4cm 정도로 자르고, 오그라들지 않게 앞뒤로 잔칼집을 살짝 넣는다.","소금·후춧가루를 아주 조금씩 뿌려 밑간한 뒤, 찹쌀가루를 앞뒤로 얇게 묻힌다.","그릇에 달걀 1개를 풀어 두고, 팬에 식용유 1큰술을 둘러 중약불로 달군다.","고기를 달걀물에 적셔 팬에 올리고 한 면당 1~2분씩, 앞뒤가 노릇해질 때까지 부친다.","한 김 식힌 뒤 새끼손톱 크기로 잘라 아이 접시에 담는다."],"steps_public":true,"nutri":{"kcal":131,"protein_g":5.6,"carb_g":4.4,"fat_g":9.8,"calcium_mg":7,"iron_mg":0.78,"sodium_mg":96,"na_flag":"ok"},"allergens":["난류(계란)","대두","쇠고기"]}