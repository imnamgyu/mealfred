{"menu":"김치콩나물국","title":"콩나물국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":15,"wait_min":0,"yield_g":22.7,"ings":[{"n":"콩나물","raw":"콩나물_생것","g":14,"disp":null,"ssn":false,"na":0},{"n":"무","raw":"무, 조선무, 생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"파","raw":"파, 생것","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":0.1,"disp":null,"ssn":false,"na":2}],"steps":["무는 3cm 길이로 얇게 채 썰고, 콩나물 한 줌은 흐르는 물에 헹궈 체에 밭쳐 물기를 턴다.","파는 잘게 송송 썰고 마늘 반 쪽은 곱게 다져 둔다.","냄비에 참기름을 반 큰술 두르고 중불에서 무를 2분 정도 볶아 살짝 투명해지게 한다.","물 2컵을 붓고 끓어오르면 콩나물을 넣은 뒤 뚜껑을 덮고 중불로 4~5분 더 끓인다.","간장과 소금으로 아이 입에 심심할 정도로만 간을 하고 파를 넣은 뒤, 한 김 식혀 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":17,"protein_g":0.8,"carb_g":1,"fat_g":1.2,"calcium_mg":11,"iron_mg":0.15,"sodium_mg":76,"na_flag":"ok"},"allergens":["대두"]}