{"menu":"스파게티","title":"토마토스파게티(간식)","band":"3-5세","dish_type":"noodle","source":"standard","cook_min":25,"wait_min":0,"yield_g":83,"ings":[{"n":"파스타","raw":"파스타_스파게티_말린것","g":35,"disp":null,"ssn":true,"na":null},{"n":"토마토소스","raw":"토마토 소스","g":30,"disp":null,"ssn":false,"na":72},{"n":"양파","raw":"양파_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"양송이버섯","raw":"양송이버섯_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"버터","raw":"버터","g":3,"disp":"1/2작은술","ssn":true,"na":11}],"steps":["끓는 물에 스파게티 면을 넣고 10분간 삶은 뒤 체에 밭쳐 물기를 뺀다(아이용은 3~4cm 길이로 잘라 주면 먹기 좋다).","양파는 잘게 다지고 양송이버섯은 얇게 저민다.","냄비에 버터를 녹여 중불에서 양파와 버섯을 2~3분 볶다가 토마토스파게티소스를 넣고 함께 3분쯤 더 볶아 소스를 만든다.","버터를 살짝 두른 팬에 삶은 면을 넣고 약불에서 1분간 가볍게 볶는다.","접시에 면을 담고 소스를 끼얹은 뒤, 한 김 식혀 아이에게 준다."],"steps_public":true,"nutri":{"kcal":172,"protein_g":5.3,"carb_g":29.5,"fat_g":3.1,"calcium_mg":16,"iron_mg":0.78,"sodium_mg":83,"na_flag":"ok"},"allergens":["우유","대두","밀","토마토","닭고기","쇠고기","조개류"]}