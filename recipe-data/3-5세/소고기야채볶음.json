{"menu":"소고기야채볶음","title":"쇠고기채소볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":20,"wait_min":16,"yield_g":70.7,"ings":[{"n":"소고기","raw":"소고기, 한우(1등급), 사태(앞사태), 생것","g":45,"disp":null,"ssn":false,"na":30},{"n":"당근","raw":"당근, 뿌리, 생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"물엿","raw":"물엿","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"맛술","raw":"맛술","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"참깨","raw":"참깨_흰깨_볶은것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["소고기는 새끼손톱 크기로 얇게 썰고, 양파와 당근도 아이가 씹기 쉽게 얇고 잘게 썬다.","파는 송송 썰고, 마늘은 곱게 다진다.","볼에 소고기를 담고 다진 마늘, 간장 1작은술, 참기름 몇 방울을 넣어 조물조물 버무려 10분쯤 재운다. 후추는 아주 살짝만 쓰거나 생략한다.","팬에 식용유를 두르고 중불에서 재운 고기를 2~3분 볶아 겉면 색이 변하면, 당근·양파·파를 넣고 3분 정도 더 볶아 채소가 부드러워지면 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":115,"protein_g":11,"carb_g":3.9,"fat_g":5.8,"calcium_mg":10,"iron_mg":1.37,"sodium_mg":176,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}