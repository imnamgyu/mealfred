{"menu":"봄동무침","title":"봄동무침","band":"3-5세","dish_type":"side","source":"standard","cook_min":10,"wait_min":0,"yield_g":37.5,"ings":[{"n":"배추","raw":"배추, 봄동, 생것","g":35,"disp":null,"ssn":false,"na":11},{"n":"파","raw":"파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":0.5,"disp":"약간","ssn":true,"na":40},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":36}],"steps":["봄동 잎을 한 장씩 떼어 흐르는 물에 씻는다.","끓는 물에 소금을 조금 넣고 봄동을 30초~1분만 데친 뒤 바로 찬물에 헹궈 물기를 꼭 짠다.","아이가 씹기 좋게 2~3cm 길이로 썰고, 파와 마늘은 곱게 다진다.","볼에 봄동·다진 파·마늘을 담고 간장 조금, 소금 한 꼬집, 참기름 1작은술을 넣어 손으로 조물조물 무쳐 낸다."],"steps_public":true,"nutri":{"kcal":11,"protein_g":0.8,"carb_g":1.9,"fat_g":0.3,"calcium_mg":36,"iron_mg":0.32,"sodium_mg":87,"na_flag":"ok"},"allergens":["대두","밀"]}