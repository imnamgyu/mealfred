{"menu":"소고기무우죽","title":"소고기무죽","band":"3-5세","dish_type":"rice_main","source":"ai_generated","cook_min":30,"wait_min":30,"yield_g":53.5,"ings":[{"n":"멥쌀","raw":"멥쌀, 백미, 생것","g":25,"disp":null,"ssn":false,"na":1},{"n":"소고기","raw":"소고기, 한우, 양지, 생것","g":15,"disp":null,"ssn":false,"na":8},{"n":"무","raw":"무, 조선무, 생것","g":10,"disp":null,"ssn":false,"na":1},{"n":"참기름","raw":"참기름","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":1,"disp":"1/4작은술","ssn":true,"na":80},{"n":"파","raw":"파, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금, 정제염","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":108},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["쌀은 씻어 30분 이상 불리고, 소고기는 키친타월로 핏물을 닦아낸 뒤 잘게 다진다.","무는 새끼손톱 크기(0.5cm)로 잘게 썰고, 파와 마늘은 곱게 다진다.","냄비에 참기름을 두르고 중불에서 소고기와 다진 마늘을 1~2분간 볶다가, 고기 색이 변하면 불린 쌀과 무를 넣고 30초 더 볶는다.","물 170ml(쌀 무게의 6~7배)를 붓고 센불에서 끓어오르면 약불로 줄인 뒤, 뚜껑을 비스듬히 덮고 15~20분간 바닥이 눋지 않게 가끔 저어가며 끓인다. 너무 되직해지면 물을 조금씩 더한다.","쌀알이 푹 퍼지고 무가 투명해지면 간장과 소금으로 심심하게 간하고, 다진 파를 넣어 한소끔 더 끓여 마무리한다."],"steps_public":true,"nutri":{"kcal":142,"protein_g":null,"carb_g":null,"fat_g":null,"calcium_mg":null,"iron_mg":null,"sodium_mg":198,"na_flag":"ok"},"allergens":["소고기","대두"]}