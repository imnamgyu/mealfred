{"menu":"잔멸치주먹밥","title":"잔멸치주먹밥","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":40,"wait_min":0,"yield_g":30.5,"ings":[{"n":"멥쌀","raw":"멥쌀_백미_생것","g":20,"disp":null,"ssn":false,"na":0},{"n":"멸치","raw":"멸치, 잔멸치, 삶아서 말린것","g":3.5,"disp":null,"ssn":false,"na":93},{"n":"당근","raw":"당근_뿌리_생것","g":3,"disp":null,"ssn":false,"na":1},{"n":"참기름","raw":"참기름","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"김","raw":"김, 참김, 구운것","g":0.4,"disp":null,"ssn":false,"na":2},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["쌀을 30분쯤 물에 불렸다가 평소보다 살짝 적은 물로 밥을 고슬하게 짓는다.","당근과 피망을 새끼손톱 크기보다 작게 잘게 다진다.","중불 팬에 식용유를 얇게 두르고 잔멸치를 1분 볶다가, 다진 당근과 피망을 넣고 1~2분 더 볶아 채소가 부드러워지게 한다.","큰 볼에 따뜻한 밥과 볶은 재료를 넣고 소금 한 꼬집, 후춧가루 아주 조금, 참기름 반 작은술을 더해 고루 섞는다.","밥이 한 김 식으면 아이가 한입에 먹기 좋은 탁구공보다 작은 크기로 동글동글 뭉친다."],"steps_public":true,"nutri":{"kcal":110,"protein_g":3.1,"carb_g":16.2,"fat_g":3.4,"calcium_mg":26,"iron_mg":0.2,"sodium_mg":276,"na_flag":"ok"},"allergens":["대두"]}