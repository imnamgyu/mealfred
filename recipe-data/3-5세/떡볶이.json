{"menu":"떡볶이","title":"떡볶이","band":"3-5세","dish_type":"snack","source":"standard","cook_min":15,"wait_min":10,"yield_g":102.5,"ings":[{"n":"멥쌀떡","raw":"멥쌀떡, 가래떡","g":76.9,"disp":null,"ssn":false,"na":201},{"n":"양배추","raw":"양배추_생것","g":10.8,"disp":null,"ssn":false,"na":1},{"n":"어묵","raw":"어묵, 튀긴것","g":9.2,"disp":null,"ssn":false,"na":65},{"n":"파","raw":"파, 생것","g":2.3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"고추장","raw":"고추장, 개량","g":1.5,"disp":"1/2작은술","ssn":true,"na":38},{"n":"간장","raw":"간장, 개량, 양조","g":0.8,"disp":"1/4작은술","ssn":true,"na":37},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":54},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["떡은 미지근한 물에 10분쯤 담가 말랑하게 불린다.","양배추는 한입 크기로, 어묵은 아이가 씹기 좋게 1~2cm 폭으로 썰고(꼬치 어묵이면 꼬치는 반드시 빼기), 파도 잘게 썰고 마늘은 다진다.","작은 그릇에 다진 마늘·고추장 아주 조금·간장·소금·설탕·참기름을 섞어 순한 양념을 만든다.","냄비에 물을 붓고 양념을 풀어 끓어오르면 떡과 어묵을 넣고 중불에서 5분 정도 끓인다.","양배추와 파를 넣어 익힌 뒤 센불에서 1~2분 국물을 졸이고, 떡은 새끼손톱 크기로 잘라 한 김 식혀 내준다."],"steps_public":true,"nutri":{"kcal":152,"protein_g":3.4,"carb_g":33.4,"fat_g":0.7,"calcium_mg":15,"iron_mg":0.18,"sodium_mg":396,"na_flag":"review"},"allergens":["대두","밀"]}