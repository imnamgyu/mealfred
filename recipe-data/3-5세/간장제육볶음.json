{"menu":"간장제육볶음","title":"간장제육볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":14,"yield_g":44.3,"ings":[{"n":"돼지고기","raw":"돼지고기_삼겹살(삼겹살)_생것","g":30,"disp":null,"ssn":false,"na":17},{"n":"간장","raw":"간장_재래","g":5,"disp":"1작은술","ssn":true,"na":400},{"n":"양파","raw":"양파_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"물엿","raw":"물엿","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["돼지고기는 아이가 씹기 좋게 새끼손톱 크기로 얇게 썰고, 마늘은 곱게 다진다.","양파는 가늘게 채 썰고, 파는 얇게 송송 썬다.","볼에 돼지고기, 다진 마늘, 간장 1작은술, 물엿(또는 올리고당) 반 작은술을 넣고 조물조물 버무려 10분쯤 재운다.","팬에 식용유를 두르고 중불에서 재운 고기를 3~4분간 속까지 완전히 익도록 볶는다.","양파와 파를 넣어 1~2분 더 볶아 숨을 죽이고, 불을 끈 뒤 참기름 몇 방울을 둘러 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":138,"protein_g":4.4,"carb_g":2.2,"fat_g":11.8,"calcium_mg":5,"iron_mg":0.18,"sodium_mg":417,"na_flag":"review"},"allergens":["대두","밀","돼지고기"]}