{"menu":"토마토달걀볶음","title":"토마토달걀볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":78.2,"ings":[{"n":"달걀","raw":"달걀, 생것","g":40,"disp":null,"ssn":false,"na":55},{"n":"토마토","raw":"토마토, 생것","g":25,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파, 생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"콩기름","raw":"콩기름","g":3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"소금","raw":"소금, 정제염","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72}],"steps":["양파와 방울토마토는 깨끗이 씻고, 방울토마토는 통째로 주면 위험하니 반드시 4등분으로 자르고 양파는 잘게 썬다.","달걀 1개를 그릇에 깨서 잘 풀어 둔다.","팬에 식용유를 두르고 중불에서 양파를 1~2분 투명해질 때까지 볶는다.","자른 토마토를 넣고 1분쯤 함께 볶는다.","토마토와 양파를 팬 한쪽으로 밀어두고 빈 자리에 달걀물을 붓는다.","달걀 가장자리가 익기 시작하면 부드럽게 저어가며 토마토와 섞어 볶고, 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":89,"protein_g":5.3,"carb_g":3.1,"fat_g":6,"calcium_mg":25,"iron_mg":0.78,"sodium_mg":128,"na_flag":"ok"},"allergens":["난류(계란)","대두","토마토"]}