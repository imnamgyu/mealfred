{"menu":"버섯볶음","title":"표고버섯볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":43,"ings":[{"n":"표고버섯","raw":"표고버섯, 참나무재배, 생것","g":35,"disp":null,"ssn":false,"na":2},{"n":"브로콜리","raw":"브로콜리, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":0.6,"disp":"약간","ssn":true,"na":29},{"n":"콩기름","raw":"콩기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":36},{"n":"참기름","raw":"참기름","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["브로콜리는 새끼손톱 크기의 작은 송이로 나눠 끓는 물에 1분만 데친 뒤 찬물에 헹구고 체에 밭쳐 물기를 뺀다.","표고버섯은 기둥을 떼고 0.5cm 두께로 얇게 썰고, 파와 마늘은 곱게 다진다.","팬에 식용유를 조금 두르고 중불에서 다진 파·마늘을 30초쯤 볶아 향을 낸 뒤, 브로콜리와 표고버섯을 넣어 2~3분 볶는다.","소금 한 꼬집과 간장 약간으로 아이 입맛에 맞게 심심하게 간을 맞춘다.","불을 끄고 참기름 몇 방울을 둘러 섞은 뒤 한 김 식혀 담아낸다."],"steps_public":true,"nutri":{"kcal":15,"protein_g":0.9,"carb_g":2.7,"fat_g":0.7,"calcium_mg":5,"iron_mg":0.27,"sodium_mg":67,"na_flag":"ok"},"allergens":["대두","밀"]}