{"menu":"찜닭","title":"찜닭","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":25,"wait_min":12,"yield_g":63.3,"ings":[{"n":"닭고기","raw":"닭고기_성계_생것","g":40,"disp":null,"ssn":false,"na":26},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":4,"disp":"1작은술","ssn":true,"na":191},{"n":"설탕","raw":"설탕_백설탕","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"청주","raw":"청주, 알코올 16%","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["닭고기는 찬물에 10분쯤 담가 핏물을 빼고, 끓는 물에 1~2분 데쳐 건져 물기를 뺀다.","양파와 당근은 아이 한입 크기(2cm 정도)로 썰고, 파는 송송 썰고, 마늘은 곱게 다진다.","작은 그릇에 다진 마늘, 간장 1큰술, 설탕 조금, 참기름 약간, 물 반 컵을 섞어 순한 양념장을 만든다. (아이용이라 후추·청주는 빼거나 아주 조금만 쓴다.)","냄비에 닭과 양파·당근을 담고 양념을 골고루 버무린 뒤 뚜껑을 덮고 중약불에서 15~20분, 닭이 푹 익을 때까지 익힌다.","뼈가 있으면 살만 발라내고, 한 김 식혀 잘게 찢어 준다."],"steps_public":true,"nutri":{"kcal":93,"protein_g":8.2,"carb_g":4.1,"fat_g":4.5,"calcium_mg":9,"iron_mg":0.52,"sodium_mg":220,"na_flag":"ok"},"allergens":["대두","밀","닭고기"]}