{"menu":"소불고기","title":"소불고기(경남)","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":20,"wait_min":17,"yield_g":64.1,"ings":[{"n":"소고기","raw":"소고기_한우(1등급)_목심(목심살)_생것","g":40,"disp":null,"ssn":false,"na":27},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["불고기용 소고기는 3cm 정도로 짧게 자르고, 양파와 당근은 얇게 채 썬다. 당근은 0.3cm 두께로 얇아야 아이가 씹기 편하다.","파는 송송 썰고, 마늘은 곱게 다진다.","볼에 소고기를 담고 다진 마늘, 간장 1큰술, 설탕 반 큰술, 참기름 조금을 넣어 조물조물 무친 뒤 10분쯤 재워 둔다. 후추는 생략하거나 아주 살짝만.","팬에 식용유를 두르고 중불에서 재운 고기를 3분 정도 볶다가, 당근·양파·파를 넣고 채소가 부드러워질 때까지 3~4분 더 볶는다.","고기가 완전히 익었는지 확인하고 한 김 식힌 뒤 잘게 잘라 담아준다."],"steps_public":true,"nutri":{"kcal":134,"protein_g":9.2,"carb_g":2.4,"fat_g":9.3,"calcium_mg":9,"iron_mg":1.23,"sodium_mg":173,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}