{"menu":"간장닭갈비","title":"간장닭갈비","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":20,"wait_min":0,"yield_g":75.6,"ings":[{"n":"닭고기","raw":"닭고기_가슴(껍질 제거)_생것","g":30,"disp":null,"ssn":false,"na":14},{"n":"감자","raw":"감자, 대지, 생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"양배추","raw":"양배추_생것","g":10,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":4,"disp":"1작은술","ssn":true,"na":191},{"n":"들깻잎","raw":"들깻잎, 생것","g":2.5,"disp":null,"ssn":false,"na":0},{"n":"물엿","raw":"물엿","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"청주","raw":"청주, 알코올 16%","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["닭가슴살은 힘줄을 떼고 아이 한입 크기(2cm)로, 감자·양배추·양파는 얇고 작게 썬다. 깻잎과 파도 잘게 썰고 마늘은 조금 다진다.","볼에 손질한 재료를 모두 담고 간장 1큰술, 청주 1작은술, 물엿 1작은술, 다진 마늘을 넣어 버무린다. 후추는 아주 살짝만 하거나 생략한다.","팬에 식용유 1큰술을 두르고 중불에서 닭고기가 하얗게 될 때까지 3~4분 볶는다.","약불로 낮춰 감자가 포크로 쉽게 들어갈 때까지 7~8분 더 볶는다.","한 김 식힌 뒤 큰 조각이 없는지 확인하고 담아낸다."],"steps_public":true,"nutri":{"kcal":80,"protein_g":7.9,"carb_g":6.3,"fat_g":2.3,"calcium_mg":17,"iron_mg":0.33,"sodium_mg":207,"na_flag":"ok"},"allergens":["대두","밀","닭고기"]}