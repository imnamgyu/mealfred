{"menu":"우엉채조림","title":"우엉채조림","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":24.7,"ings":[{"n":"우엉","raw":"우엉_생것","g":20,"disp":null,"ssn":false,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":2.5,"disp":"1/2작은술","ssn":true,"na":120},{"n":"물엿","raw":"물엿","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"식초","raw":"식초, 사과식초","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["우엉은 껍질을 벗기고 성냥개비 굵기로 가늘게 채 썬 뒤, 식초 몇 방울 넣은 끓는 물에 2~3분 데쳐 아린 맛을 빼고 체에 밭쳐 물기를 턴다.","작은 그릇에 간장 1작은술, 물엿 1작은술, 물 3큰술을 섞어 조림 양념을 미리 만들어 둔다.","냄비에 우엉과 양념을 넣고 중불에서 국물이 자작하게 줄어들 때까지 5~7분 조린다.","불을 끄고 참기름을 반 작은술 둘러 윤기를 낸 뒤, 한 김 식혀 아이 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":22,"protein_g":0.8,"carb_g":4.3,"fat_g":0.2,"calcium_mg":10,"iron_mg":0.2,"sodium_mg":121,"na_flag":"ok"},"allergens":["대두","밀"]}