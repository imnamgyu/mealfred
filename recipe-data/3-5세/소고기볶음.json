{"menu":"소고기볶음","title":"쇠고기볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":13,"yield_g":62.6,"ings":[{"n":"소고기","raw":"소고기_한우_등심_생것","g":30,"disp":null,"ssn":false,"na":17},{"n":"양배추","raw":"양배추_생것","g":10,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘페이스트","raw":"마늘 페이스트","g":0.5,"disp":"약간","ssn":true,"na":null},{"n":"설탕","raw":"설탕_백설탕","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"파","raw":"파_대파_생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"깨소금","raw":"깨소금_가루_볶은것","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.3,"disp":"약간","ssn":true,"na":0}],"steps":["소고기는 새끼손가락 길이(3cm)·0.5cm 두께의 얇은 조각으로 썰고, 질기지 않도록 칼등으로 가볍게 두드리거나 칼집을 낸다.","양파는 반 갈라 1cm 폭으로 채 썰고, 당근과 양배추는 아이 새끼손톱 두 개 크기(약 2cm)로 얇게 썬다.","다진 마늘·다진 파·간장·설탕 약간·참기름·깨소금을 섞은 양념장에 소고기를 넣고 10분쯤 재운다.","기름을 살짝 두른 팬을 중불로 달군 뒤 재운 소고기를 먼저 2~3분 볶는다.","고기가 거의 익으면 양파·당근·양배추를 넣고 3~4분 더 볶아 채소가 부드러워지면 불을 끄고 한 김 식혀 담는다."],"steps_public":true,"nutri":{"kcal":135,"protein_g":5.4,"carb_g":3.1,"fat_g":10.9,"calcium_mg":15,"iron_mg":0.85,"sodium_mg":163,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}