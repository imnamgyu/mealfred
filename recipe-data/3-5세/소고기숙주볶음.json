{"menu":"소고기숙주볶음","title":"쇠고기숙주볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":56.8,"ings":[{"n":"소고기","raw":"소고기, 한우(1등급), 사태(앞사태), 생것","g":30,"disp":null,"ssn":false,"na":20},{"n":"숙주나물","raw":"숙주나물, 생것","g":15,"disp":null,"ssn":false,"na":1},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["소고기는 아이가 씹기 좋게 새끼손톱 크기로 잘게 썰고, 숙주는 씻어서 체에 밭쳐 물기를 뺀다.","파는 얇게 송송 썰고 마늘은 곱게 다져 둔다.","볼에 소고기와 다진 마늘, 간장 약간, 참기름을 넣고 조물조물 무쳐 5분 정도 재운다(후추는 아주 조금 또는 생략).","팬에 식용유를 두르고 중불에서 소고기를 2~3분 볶아 겉이 익으면 숙주와 파를 넣는다.","센불로 올려 1~2분만 재빨리 볶아 숙주의 아삭함이 살아 있을 때 불을 끄고, 한 김 식혀 아이 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":77,"protein_g":7.6,"carb_g":1.5,"fat_g":4.3,"calcium_mg":7,"iron_mg":0.96,"sodium_mg":165,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}