{"menu":"고사리나물","title":"고사리나물","band":"3-5세","dish_type":"side","source":"standard","cook_min":30,"wait_min":0,"yield_g":38.8,"ings":[{"n":"고사리","raw":"고사리, 데친것","g":35,"disp":null,"ssn":false,"na":1},{"n":"참기름","raw":"참기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":0.5,"disp":"약간","ssn":true,"na":24},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"참깨","raw":"참깨_흰깨_볶은것","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["말린 고사리는 물에 충분히 불린 뒤 끓는 물에 20분 정도 푹 삶고, 찬물에 헹궈 물기를 꼭 짠 다음 아이가 씹기 좋게 3cm 길이로 짧게 자른다.","파와 마늘은 곱게 다져 둔다.","팬에 참기름을 살짝 두르고 중불에서 파와 마늘을 30초쯤 볶아 향을 낸 뒤, 고사리를 넣고 1~2분 더 볶는다.","물을 2~3큰술 부어 약불로 낮추고 3분 정도 뚜껑을 덮어 고사리가 부드러워질 때까지 익힌다.","간장을 조금 넣어 심심하게 간을 맞추고, 불을 끈 뒤 참깨를 뿌려 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":23,"protein_g":1.1,"carb_g":1.5,"fat_g":1.6,"calcium_mg":7,"iron_mg":0.22,"sodium_mg":25,"na_flag":"ok"},"allergens":["대두","밀"]}