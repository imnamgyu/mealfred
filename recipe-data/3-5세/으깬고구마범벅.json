{"menu":"으깬고구마범벅","title":"으깬고구마범벅","band":"3-5세","dish_type":"etc","source":"standard","cook_min":25,"wait_min":0,"yield_g":45,"ings":[{"n":"고구마","raw":"고구마_분질(밤) 고구마_생것","g":35,"disp":null,"ssn":false,"na":3},{"n":"마요네즈","raw":"마요네즈, 난황","g":5,"disp":"1작은술","ssn":true,"na":24},{"n":"당근","raw":"당근_뿌리_생것","g":3,"disp":null,"ssn":false,"na":1},{"n":"포도","raw":"포도, 건포도","g":2,"disp":null,"ssn":false,"na":1}],"steps":["고구마 껍질을 벗기고 큼직하게 잘라 15분 정도 푹 삶은 뒤, 뜨거울 때 포크로 곱게 으깬다.","당근은 새끼손톱보다 작게 깍둑 썰어 끓는 물에 2~3분 데쳐 부드럽게 만든다.","건포도는 그대로 주면 끈적하게 달라붙을 수 있으니 잘게 다지거나 반으로 자른다.","으깬 고구마에 당근과 건포도를 넣고 마요네즈 한 큰술을 더해 골고루 버무린 뒤, 한 김 식혀 담아낸다."],"steps_public":true,"nutri":{"kcal":96,"protein_g":0.5,"carb_g":15,"fat_g":3.8,"calcium_mg":8,"iron_mg":0.2,"sodium_mg":28,"na_flag":"ok"},"allergens":["난류(계란)","대두"]}