{"menu":"오징어맑은국","title":"오징어맑은국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":15,"wait_min":0,"yield_g":51.1,"ings":[{"n":"오징어","raw":"오징어, 생것","g":40,"disp":null,"ssn":false,"na":80},{"n":"무","raw":"무, 조선무, 생것","g":7,"disp":null,"ssn":false,"na":1},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["손질한 오징어 몸통 1/3마리는 껍질을 벗기고 아이가 씹기 좋게 1cm 폭으로 잘게 썰고, 무는 0.5cm 두께의 얇은 네모(나박) 모양으로 썬다.","대파는 송송 썰고 마늘은 곱게 다져 둔다.","냄비에 물 3컵을 붓고 무를 넣어 센불에 올린 뒤, 끓어오르면 중불로 줄여 5분쯤 무가 투명해질 때까지 끓인다.","오징어, 다진 마늘, 파를 넣고 2~3분만 더 끓인다. 오래 끓이면 오징어가 질겨져 아이가 씹기 어렵다.","소금으로 심심하게 간하고(후추는 생략 가능), 한 김 식혀 그릇에 담아낸다."],"steps_public":true,"nutri":{"kcal":50,"protein_g":9.4,"carb_g":0.9,"fat_g":0.7,"calcium_mg":9,"iron_mg":0.16,"sodium_mg":261,"na_flag":"ok"},"allergens":["오징어"]}