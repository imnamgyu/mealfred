{"menu":"건파래자반","title":"건파래자반(경남)","band":"3-5세","dish_type":"etc","source":"standard","cook_min":10,"wait_min":0,"yield_g":5.7,"ings":[{"n":"파래","raw":"파래, 말린것","g":3,"disp":"1/2작은술","ssn":true,"na":117},{"n":"설탕","raw":"설탕_백설탕","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"깨소금","raw":"깨소금_가루_볶은것","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":0},{"n":"올리브유","raw":"올리브유","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금_천일염","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72}],"steps":["건파래를 펼쳐 티끌이나 딱딱한 이물질을 골라내고, 아이가 먹기 좋게 새끼손톱 크기로 잘게 뜯는다.","뜯은 파래에 참기름과 올리브오일을 반 숟갈씩 넣고 조물조물 무쳐 기름을 고루 입힌다.","기름 없이 달군 팬에 파래를 넣고 약불에서 2~3분, 타지 않게 저어가며 바삭하게 볶는다.","불을 끄고 설탕과 소금을 아주 조금씩 넣어 고루 섞는다.","마지막에 깨소금을 솔솔 뿌리고 한 김 식혀 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":22,"protein_g":0.8,"carb_g":2.3,"fat_g":1.3,"calcium_mg":21,"iron_mg":0.26,"sodium_mg":189,"na_flag":"ok"},"allergens":[]}