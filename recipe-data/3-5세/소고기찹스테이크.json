{"menu":"소고기찹스테이크","title":"쇠고기찹스테이크","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":10,"yield_g":51.8,"ings":[{"n":"소고기","raw":"소고기, 한우, 등심, 생것","g":25,"disp":null,"ssn":false,"na":14},{"n":"당근","raw":"당근, 뿌리, 생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"피망","raw":"피망, 초록색, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"토마토케첩","raw":"토마토 케첩","g":2,"disp":null,"ssn":false,"na":21},{"n":"간장","raw":"간장, 개량, 양조","g":1,"disp":"1/4작은술","ssn":true,"na":48},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["소고기는 아이가 씹기 좋게 새끼손톱 크기로 썰고, 양파·당근·파프리카도 비슷한 크기로 썬다.","파는 송송 썰고 마늘은 곱게 다진다.","볼에 소고기를 담고 다진 마늘, 케첩 1큰술, 간장 반 큰술, 참기름 약간을 넣어 조물조물 버무린 뒤 10분 재운다(후춧가루는 생략하거나 아주 살짝).","팬에 기름을 두르고 중불에서 고기를 2~3분 볶다가 당근·양파·파프리카·파를 넣고 3~4분 더 볶아 채소가 부드러워지면 불을 끈다.","한 김 식혀 접시에 담아준다."],"steps_public":true,"nutri":{"kcal":111,"protein_g":4.3,"carb_g":2.4,"fat_g":9.3,"calcium_mg":8,"iron_mg":0.7,"sodium_mg":85,"na_flag":"ok"},"allergens":["대두","밀","토마토","쇠고기"]}