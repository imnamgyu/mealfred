{"menu":"꽃게탕","title":"꽃게탕","band":"3-5세","dish_type":"soup","source":"standard","cook_min":15,"wait_min":0,"yield_g":72.3,"ings":[{"n":"게","raw":"게, 꽃게, 생것","g":38.5,"disp":null,"ssn":false,"na":161},{"n":"무","raw":"무, 조선무, 생것","g":14.4,"disp":null,"ssn":false,"na":2},{"n":"양파","raw":"양파, 생것","g":4.8,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":4.8,"disp":"1작은술","ssn":true,"na":1},{"n":"호박","raw":"호박, 애호박, 생것","g":4.8,"disp":null,"ssn":false,"na":0},{"n":"된장","raw":"된장, 개량","g":2.9,"disp":"1/2작은술","ssn":true,"na":125},{"n":"고춧가루","raw":"고춧가루, 가루","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":68}],"steps":["손질한 꽃게는 4등분하고, 무는 아이가 먹기 좋게 새끼손톱 크기의 얇은 깍둑모양으로 썬다.","애호박은 0.5cm 두께 반달 모양으로, 양파는 한입 크기로 썰고, 파는 송송 썰고 마늘은 다진다.","작은 그릇에 다진 마늘, 된장, 소금을 섞어 양념을 만든다. 아이용이니 고춧가루는 빼거나 아주 조금만 넣는다.","냄비에 물을 붓고 무와 양념을 넣어 센불에서 끓이다가, 끓어오르면 꽃게를 넣고 중불로 5분 정도 더 끓인다.","애호박·양파·파를 넣고 5분쯤 더 끓인 뒤, 아이 그릇에는 게살만 껍데기에서 발라내고 한 김 식혀서 준다."],"steps_public":true,"nutri":{"kcal":44,"protein_g":7,"carb_g":2.9,"fat_g":0.5,"calcium_mg":58,"iron_mg":0.61,"sodium_mg":357,"na_flag":"review"},"allergens":["대두","밀","게"]}