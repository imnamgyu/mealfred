{"menu":"순두부국","title":"맑은순두부국(경남)","band":"3-5세","dish_type":"soup","source":"standard","cook_min":15,"wait_min":0,"yield_g":88.3,"ings":[{"n":"두부","raw":"두부, 순두부","g":57.7,"disp":null,"ssn":false,"na":2},{"n":"달걀","raw":"달걀, 생것","g":17.3,"disp":null,"ssn":false,"na":24},{"n":"양파","raw":"양파_생것","g":5.8,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3.5,"disp":"1작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":2.3,"disp":null,"ssn":false,"na":50},{"n":"간장","raw":"간장_재래","g":0.6,"disp":"약간","ssn":true,"na":46},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.6,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":209}],"steps":["냄비에 물 2컵과 국물용 멸치 4~5마리를 넣고 중불에서 5분 끓여 육수를 내고 멸치는 건져 낸다.","대파는 0.5cm 두께로 어슷하게, 양파는 2cm 크기로 썬다.","냄비에 양파를 넣고 살짝 볶다가 멸치 육수를 붓고 중불에서 끓인다.","순두부를 숟가락으로 큼직하게 잘라 넣고 2~3분 끓인 뒤, 달걀 하나를 풀어 돌려 넣고 완전히 익힌다.","대파와 다진 마늘 약간을 넣고 국간장이나 소금으로 심심하게 간을 맞춰 한 번 더 끓어오르면 불을 끄고, 한 김 식혀 담아 준다."],"steps_public":true,"nutri":{"kcal":59,"protein_g":7.7,"carb_g":1.3,"fat_g":2.3,"calcium_mg":67,"iron_mg":1.08,"sodium_mg":333,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀"]}