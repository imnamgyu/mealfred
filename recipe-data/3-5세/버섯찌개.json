{"menu":"버섯찌개","title":"버섯찌개","band":"3-5세","dish_type":"soup","source":"standard","cook_min":15,"wait_min":10,"yield_g":28.3,"ings":[{"n":"느타리버섯","raw":"느타리버섯, 생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"양파","raw":"양파, 생것","g":7,"disp":null,"ssn":false,"na":0},{"n":"표고버섯","raw":"표고버섯, 참나무재배, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":2,"disp":null,"ssn":false,"na":44},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["작은 냄비에 물 2컵과 멸치 4~5마리를 넣고 중불에서 10분 우린 뒤 멸치는 건져낸다.","느타리버섯은 아이 손가락 굵기로 가늘게 찢고, 표고버섯과 양파는 얇게 채 썰고, 파는 송송 썰고 마늘은 다져 둔다.","육수에 다진 마늘과 고춧가루(아이용은 아주 조금만)를 넣고 중불에서 끓이다 양파를 넣어 2~3분 더 끓인다.","느타리·표고버섯을 넣고 3분쯤 끓인 뒤 파를 넣고 소금으로 심심하게 간하고 후추는 살짝만 뿌린다.","그릇에 담아 한 김 식힌 뒤 국물이 미지근할 때 아이에게 준다."],"steps_public":true,"nutri":{"kcal":13,"protein_g":1.7,"carb_g":1.8,"fat_g":0.2,"calcium_mg":45,"iron_mg":0.43,"sodium_mg":225,"na_flag":"ok"},"allergens":[]}