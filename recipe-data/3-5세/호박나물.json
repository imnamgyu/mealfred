{"menu":"호박나물","title":"애호박나물","band":"3-5세","dish_type":"side","source":"standard","cook_min":15,"wait_min":0,"yield_g":38.9,"ings":[{"n":"호박","raw":"호박_애호박_생것","g":35,"disp":null,"ssn":false,"na":0},{"n":"참기름","raw":"참기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장_재래","g":0.5,"disp":"약간","ssn":true,"na":40},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":36},{"n":"참깨","raw":"참깨_흰깨_볶은것","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["애호박은 반달·부채꼴 모양으로 0.5cm 두께로 썰어 소금을 살짝 뿌려 5분 절였다가, 물에 헹구고 손으로 꼭 짜 물기를 뺀다.","파와 마늘은 곱게 다져 둔다.","달군 팬에 참기름을 두르고 중불에서 파·마늘을 30초 향이 나게 볶다가, 애호박을 넣고 색이 파랗게 살아 있도록 2~3분 재빨리 볶는다.","간장을 조금 넣어 연하게 간하고, 불을 끈 뒤 참깨를 손끝으로 살짝 부숴 뿌려 마무리한다.","한 김 식혀 아이 접시에 담아낸다."],"steps_public":true,"nutri":{"kcal":23,"protein_g":0.5,"carb_g":2,"fat_g":1.6,"calcium_mg":7,"iron_mg":0.13,"sodium_mg":76,"na_flag":"ok"},"allergens":["대두","밀"]}