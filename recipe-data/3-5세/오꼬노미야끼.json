{"menu":"오꼬노미야끼","title":"오꼬노미야끼 (유아 1인분)","band":"3-5세","dish_type":"etc","source":"ai_generated","cook_min":10,"wait_min":0,"yield_g":74.5,"ings":[{"n":"양배추","raw":"양배추, 생것","g":20,"disp":null,"ssn":false,"na":2},{"n":"밀","raw":"밀, 부침가루","g":15,"disp":null,"ssn":false,"na":118},{"n":"달걀","raw":"달걀, 전란, 생것","g":10,"disp":null,"ssn":false,"na":14},{"n":"숙주나물","raw":"숙주나물, 생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"오징어","raw":"오징어, 생것","g":10,"disp":null,"ssn":false,"na":20},{"n":"콩기름","raw":"콩기름","g":4,"disp":"1작은술","ssn":true,"na":0},{"n":"돈까스소스","raw":"돈까스 소스","g":2.5,"disp":null,"ssn":true,"na":null},{"n":"마요네즈","raw":"마요네즈, 전란","g":2,"disp":"1/2작은술","ssn":true,"na":10},{"n":"가다랑어","raw":"가다랑어, 반건(가쓰오부시)","g":1,"disp":null,"ssn":false,"na":4}],"steps":["오징어는 껍질을 벗기고 새끼손톱 크기(0.5~0.7cm)로 잘게 다진다.","양배추는 3cm 길이·0.3cm 두께로 가늘게 채 썰고, 숙주도 3cm 길이로 짧게 자른다.","볼에 부침가루와 달걀, 물 2큰술(30ml)을 넣어 멍울 없이 푼 뒤 다진 오징어·양배추·숙주를 넣고 고루 섞는다.","중불로 달군 팬에 콩기름을 두르고 반죽을 지름 8cm·두께 1cm 정도로 둥글게 편 다음, 앞뒤로 3분씩 노릇하게 부치고 약불로 줄여 2분 더 익혀 속까지 완전히 익힌다.","한 김 식힌 뒤 아이가 먹기 좋은 2cm 한입 크기로 자르고, 돈까스 소스와 마요네즈를 가늘게 조금만 뿌린 후 가쓰오부시를 살짝 올려 낸다."],"steps_public":true,"nutri":{"kcal":136,"protein_g":null,"carb_g":null,"fat_g":null,"calcium_mg":null,"iron_mg":null,"sodium_mg":168,"na_flag":"ok"},"allergens":["밀","달걀","오징어","대두","토마토"]}