{"menu":"소고기메추리알장조림","title":"(저염·저당)메추리알장조림","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":35.3,"ings":[{"n":"메추리알","raw":"메추리알, 생것","g":30,"disp":null,"ssn":false,"na":41},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕, 백설탕","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["메추리알을 끓는 물에 5분 삶아 완전히 익힌 뒤 찬물에 담가 식히고 껍질을 깐다.","작은 그릇에 간장 1큰술, 설탕 반 작은술, 다진 마늘 조금, 참기름 몇 방울, 후춧가루 아주 조금, 물 반 컵을 섞어 순한 양념장을 만든다.","냄비에 메추리알과 양념장을 넣고 중약불에서 10분 정도, 국물이 자작해질 때까지 뒤적이며 조린다.","통째로 주면 목에 걸릴 수 있으니 메추리알을 반으로 잘라, 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":54,"protein_g":4.2,"carb_g":2.3,"fat_g":2.9,"calcium_mg":19,"iron_mg":0.82,"sodium_mg":185,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀"]}