{"menu":"우엉주먹밥","title":"우엉주먹밥","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":45,"wait_min":0,"yield_g":99.4,"ings":[{"n":"멥쌀","raw":"멥쌀, 백미, 생것","g":61.5,"disp":null,"ssn":false,"na":1},{"n":"우엉","raw":"우엉, 생것","g":30.8,"disp":null,"ssn":false,"na":2},{"n":"간장","raw":"간장, 개량, 양조","g":4.6,"disp":"1작은술","ssn":true,"na":221},{"n":"설탕","raw":"설탕, 백설탕","g":1.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.8,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참깨","raw":"참깨, 흰깨, 볶은것","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["쌀은 30분쯤 불렸다가 평소보다 물을 약간 넉넉히 잡아 밥을 짓는다.","우엉은 껍질을 벗겨 새끼손톱보다 작게 잘게 다진 뒤 끓는 물에 2분 데치고 체에 밭쳐 물기를 뺀다.","간장 1작은술, 설탕 반 작은술, 물 2큰술을 섞어 양념을 만든다.","작은 냄비에 우엉과 양념을 넣고 약불에서 5분쯤, 국물이 거의 없어질 때까지 조린다.","큰 볼에 따뜻한 밥과 조린 우엉, 참기름·참깨를 넣고 골고루 섞은 뒤 한 김 식힌다.","아이 한입 크기(탁구공보다 작게)로 동글동글 뭉쳐서 준다."],"steps_public":true,"nutri":{"kcal":329,"protein_g":6.5,"carb_g":69.9,"fat_g":1.4,"calcium_mg":27,"iron_mg":1.38,"sodium_mg":224,"na_flag":"ok"},"allergens":["대두","밀"]}