{"menu":"우동국","title":"우동국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":10,"wait_min":10,"yield_g":50.8,"ings":[{"n":"국수","raw":"국수_우동_생것","g":38.5,"disp":null,"ssn":false,"na":152},{"n":"쑥갓","raw":"쑥갓, 생것","g":6.7,"disp":null,"ssn":false,"na":10},{"n":"간장","raw":"간장, 재래","g":2.4,"disp":"1/2작은술","ssn":true,"na":192},{"n":"파","raw":"파, 대파, 생것","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":1,"disp":null,"ssn":false,"na":21},{"n":"김","raw":"김, 참김, 구운것","g":0.5,"disp":null,"ssn":false,"na":2},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물 2컵과 국물용 멸치 4~5마리를 넣고 중불에서 10분 우린 뒤 멸치는 건져낸다.","그동안 우동면 반 봉지를 끓는 물에 3분 삶아 찬물에 헹구고 체에 받쳐 둔다. 면은 아이가 먹기 쉽게 가위로 4~5cm 길이로 자른다.","파는 송송 썰고 마늘 반 쪽은 곱게 다지며, 김은 가위로 잘게 자르고 쑥갓은 한입 길이로 뜯어 둔다.","멸치 국물에 다진 마늘과 간장 1작은술을 넣어 한소끔 끓이고, 쑥갓과 파를 더해 1분만 더 익힌다.","그릇에 자른 면을 담고 국물을 부은 뒤 한 김 식혀 김 가루를 솔솔 뿌려 마무리한다."],"steps_public":true,"nutri":{"kcal":66,"protein_g":2.3,"carb_g":12.6,"fat_g":0.6,"calcium_mg":32,"iron_mg":0.34,"sodium_mg":377,"na_flag":"review"},"allergens":["대두","밀"]}