{"menu":"오징어무국","title":"오징어무국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":15,"wait_min":0,"yield_g":51.6,"ings":[{"n":"오징어","raw":"오징어, 생것","g":40,"disp":null,"ssn":false,"na":80},{"n":"무","raw":"무, 조선무, 생것","g":7,"disp":null,"ssn":false,"na":1},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["손질한 오징어는 아이가 씹기 쉽게 새끼손톱 크기로 잘게 썰고, 무는 0.5cm 두께의 얇은 네모 모양으로 썬다.","파는 잘게 송송 썰고 마늘은 곱게 다져 둔다.","냄비에 물 2컵을 붓고 무를 넣어 센불에서 끓어오르면 중불로 줄여 5분간 무가 투명해질 때까지 익힌다. 아이용이라 고춧가루는 아주 조금만 넣거나 생략한다.","오징어, 마늘, 파를 넣고 중불에서 2~3분 더 끓인다. 오징어는 오래 끓이면 질겨지니 짧게 익힌다.","소금으로 아주 연하게 간을 맞추고, 그릇에 담아 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":42,"protein_g":7.7,"carb_g":1.1,"fat_g":0.6,"calcium_mg":8,"iron_mg":0.16,"sodium_mg":261,"na_flag":"ok"},"allergens":["오징어"]}