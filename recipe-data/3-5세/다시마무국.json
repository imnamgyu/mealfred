{"menu":"다시마무국","title":"다시마뭇국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":25,"wait_min":0,"yield_g":43.9,"ings":[{"n":"무","raw":"무, 조선무, 생것","g":35,"disp":null,"ssn":false,"na":5},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":2,"disp":null,"ssn":false,"na":44},{"n":"참기름","raw":"참기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"다시마","raw":"다시마, 말린것","g":1,"disp":null,"ssn":false,"na":31},{"n":"간장","raw":"간장_재래","g":0.5,"disp":"약간","ssn":true,"na":40},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":144}],"steps":["냄비에 물 3컵, 멸치, 손바닥만 한 다시마 한 장을 넣고 10분 끓여 육수를 낸 뒤 건더기를 건진다.","건진 다시마는 아이가 씹기 좋게 가늘고 짧게(3cm 이내) 채 썬다.","무는 0.5cm 두께의 얇은 네모 모양으로 썰고, 파는 송송·마늘은 곱게 다진다.","냄비에 참기름을 살짝 두르고 무를 중불에서 2분 볶아 단맛을 끌어낸다.","육수와 채 썬 다시마, 파·마늘을 넣고 무가 투명해질 때까지 7~8분 끓인 뒤 소금과 간장으로 심심하게 간한다.","한 김 식혀 담아낸다."],"steps_public":true,"nutri":{"kcal":30,"protein_g":1.6,"carb_g":2.3,"fat_g":1.7,"calcium_mg":59,"iron_mg":0.42,"sodium_mg":264,"na_flag":"ok"},"allergens":["대두","밀"]}