{"menu":"비엔나소세지볶음","title":"비엔나소세지볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":63.5,"ings":[{"n":"소시지","raw":"소시지, 위너(비엔나)소시지","g":33.7,"disp":null,"ssn":false,"na":246},{"n":"양파","raw":"양파_생것","g":9.6,"disp":null,"ssn":false,"na":0},{"n":"피망","raw":"피망_빨간색_생것","g":6.7,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":4.8,"disp":null,"ssn":false,"na":1},{"n":"토마토케첩","raw":"토마토 케첩","g":2.9,"disp":null,"ssn":false,"na":30},{"n":"간장","raw":"간장_재래","g":1.9,"disp":"1/2작은술","ssn":true,"na":154},{"n":"물엿","raw":"물엿","g":1.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":1.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["비엔나소시지는 통째로 주면 질식 위험이 있으니 세로로 반 가른 뒤 다시 잘게 잘라 새끼손톱 크기로 준비하고, 양파·당근·피망도 같은 크기로 깍둑썬다.","소시지는 끓는 물에 30초 데쳐 기름기와 짠맛을 한 번 빼 준다.","팬에 기름 반 큰술을 두르고 중불에서 다진 마늘을 살짝 볶다가 소시지와 채소를 넣고 3~4분간 당근이 부드러워질 때까지 볶는다.","케첩 1큰술·간장 반 작은술·물엿 조금을 넣고 약불에서 1분 더 버무리듯 볶은 뒤, 참기름 몇 방울을 두르고 한 김 식혀 담는다."],"steps_public":true,"nutri":{"kcal":119,"protein_g":5.5,"carb_g":7.2,"fat_g":7.6,"calcium_mg":15,"iron_mg":0.32,"sodium_mg":432,"na_flag":"review"},"allergens":["대두","밀","돼지고기","토마토","닭고기","쇠고기"]}