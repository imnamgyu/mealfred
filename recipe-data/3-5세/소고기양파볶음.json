{"menu":"소고기양파볶음","title":"쇠고기양파볶음","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":10,"yield_g":56.9,"ings":[{"n":"소고기","raw":"소고기, 한우(1등급), 사태(앞사태), 생것","g":30,"disp":null,"ssn":false,"na":20},{"n":"양파","raw":"양파_생것","g":15,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3,"disp":"1/2작은술","ssn":true,"na":144},{"n":"콩기름","raw":"콩기름","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":36},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["소고기는 새끼손톱 크기로 잘게 자르고, 양파도 아이가 씹기 편한 작은 조각으로 준비한다.","파는 얇게 송송 자르고 마늘은 곱게 다진다.","볼에 자른 고기를 넣고 다진 마늘·간장 1작은술·참기름 반 작은술·소금 한 꼬집을 더해 조물조물 밑간하고 10분 재워 둔다(후춧가루는 아이용이면 생략).","팬에 식용유를 약간 두르고 중불에서 밑간한 고기를 3분쯤 볶다가, 양파와 파를 더해 양파가 투명해질 때까지 2~3분 더 익힌 뒤 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":79,"protein_g":7.5,"carb_g":2.2,"fat_g":4.3,"calcium_mg":7,"iron_mg":0.95,"sodium_mg":201,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}