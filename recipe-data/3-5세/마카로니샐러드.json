{"menu":"마카로니샐러드","title":"마카로니샐러드","band":"3-5세","dish_type":"side","source":"standard","cook_min":15,"wait_min":0,"yield_g":29.1,"ings":[{"n":"오이","raw":"오이_취청_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"마요네즈","raw":"마요네즈, 전란","g":8,"disp":"0.5큰술","ssn":true,"na":39},{"n":"파스타","raw":"파스타_마카로니_말린것","g":7,"disp":"0.5큰술","ssn":true,"na":null},{"n":"당근","raw":"당근_뿌리_생것","g":3,"disp":null,"ssn":false,"na":1},{"n":"설탕","raw":"설탕_백설탕","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금_천일염","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"파슬리","raw":"파슬리_말린것","g":0.1,"disp":"약간","ssn":true,"na":1}],"steps":["냄비에 물을 넉넉히 끓여 마카로니 한 줌을 중불에서 8~10분 삶고, 체에 건져 물기를 뺀 뒤 한 김 식힌다.","오이와 당근은 깨끗이 씻어 새끼손톱 크기(사방 1cm 정도)로 작게 깍둑썬다.","캔 옥수수는 체에 부어 국물을 빼고 흐르는 물에 한 번 헹군다.","작은 그릇에 마요네즈 1큰술, 설탕 약간, 소금 한 꼬집을 섞어 드레싱을 만든다.","볼에 마카로니·오이·당근·옥수수를 담고 드레싱을 넣어 마카로니가 뭉개지지 않게 살살 버무린 뒤, 파슬리 가루를 조금 뿌려 낸다."],"steps_public":true,"nutri":{"kcal":86,"protein_g":1.1,"carb_g":6.8,"fat_g":5.9,"calcium_mg":9,"iron_mg":0.22,"sodium_mg":220,"na_flag":"ok"},"allergens":["난류(계란)","대두"]}