{"menu":"치즈달걀말이","title":"치즈달걀말이","band":"3-5세","dish_type":"etc","source":"standard","cook_min":10,"wait_min":0,"yield_g":42.7,"ings":[{"n":"달걀","raw":"달걀, 생것","g":30,"disp":null,"ssn":false,"na":41},{"n":"치즈","raw":"치즈, 체다","g":5,"disp":null,"ssn":false,"na":46},{"n":"당근","raw":"당근_뿌리_생것","g":3,"disp":null,"ssn":false,"na":1},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"콩기름","raw":"콩기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72}],"steps":["파와 당근을 새끼손톱보다 작게 잘게 다진다.","볼에 달걀 2개를 풀고 다진 채소와 소금 한 꼬집을 넣어 고루 섞는다.","팬에 식용유를 얇게 두르고 약불로 달군 뒤 달걀물을 부어 넓게 편다.","윗면이 반쯤 익으면 체다치즈 한 장을 올리고 뒤집개로 끝에서부터 돌돌 만다.","약불에서 굴려가며 2~3분 더 익혀 속까지 완전히 익힌다.","한 김 식힌 뒤 1.5cm 두께로 썰어 준다. 갓 잘랐을 때 치즈가 뜨거우니 꼭 식었는지 확인한다."],"steps_public":true,"nutri":{"kcal":71,"protein_g":4.9,"carb_g":1,"fat_g":5,"calcium_mg":47,"iron_mg":0.61,"sodium_mg":161,"na_flag":"ok"},"allergens":["난류(계란)","우유","대두"]}