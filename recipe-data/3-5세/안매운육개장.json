{"menu":"안매운육개장","title":"안매운육개장","band":"3-5세","dish_type":"etc","source":"standard","cook_min":35,"wait_min":0,"yield_g":48.5,"ings":[{"n":"소고기","raw":"소고기_한우_양지_생것","g":24,"disp":null,"ssn":false,"na":13},{"n":"고사리","raw":"고사리, 데친것","g":5,"disp":null,"ssn":false,"na":0},{"n":"무","raw":"무, 조선무, 생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"숙주나물","raw":"숙주나물_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"토란대","raw":"토란대_줄기_생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"간장","raw":"간장_재래","g":0.5,"disp":"약간","ssn":true,"na":40},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":144},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물을 넉넉히 붓고 쇠고기 덩어리를 넣어 중불에서 20분쯤 끓여 육수를 낸 뒤, 익은 고기는 건져 아이가 먹기 좋게 잘게 찢는다.","숙주·고사리·토란대는 끓는 물에 살짝 데쳐 물기를 짜고 3cm 길이로 짧게 썬다.","무는 얇은 나박썰기, 파는 송송 썰고 마늘은 다진다.","육수에 무를 먼저 넣고 5분 끓인 다음 찢은 고기, 고사리, 토란대, 숙주, 파를 차례로 넣고 한소끔 더 끓인다.","다진 마늘을 넣고 2~3분 끓인 뒤 소금·간장으로 심심하게 간하고, 후춧가루는 아주 살짝만 넣고 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":66,"protein_g":4.8,"carb_g":1.1,"fat_g":4.5,"calcium_mg":9,"iron_mg":0.57,"sodium_mg":199,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}