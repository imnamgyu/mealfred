{"menu":"돈육두부조림","title":"두부조림","band":"3-5세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":68.7,"ings":[{"n":"두부","raw":"두부","g":60,"disp":null,"ssn":false,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3.5,"disp":"1작은술","ssn":true,"na":167},{"n":"콩기름","raw":"콩기름","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"파","raw":"파, 대파, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.8,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕, 백설탕","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"깨소금","raw":"깨소금, 가루, 볶은것","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":0}],"steps":["두부 반 모는 키친타월로 눌러 물기를 빼고, 아이가 한입에 먹기 좋게 2cm 크기 네모로 자른다.","팬에 기름을 얇게 두르고 중불에서 두부를 앞뒤로 3분씩, 겉이 노릇해질 때까지 굽는다.","작은 그릇에 간장 1작은술, 설탕 반 작은술, 참기름 약간, 다진 파·마늘 조금, 깨소금을 섞어 양념장을 만든다. 아이용이라 고춧가루는 빼거나 아주 살짝만 넣는다.","구운 두부에 양념장과 물 2큰술을 붓고 약불에서 4~5분, 숟가락으로 국물을 끼얹어 가며 촉촉하게 조린다.","불을 끄고 한 김 식힌 뒤 아이 접시에 담는다."],"steps_public":true,"nutri":{"kcal":90,"protein_g":6.2,"carb_g":3.8,"fat_g":5.4,"calcium_mg":42,"iron_mg":1.05,"sodium_mg":168,"na_flag":"ok"},"allergens":["대두","밀"]}