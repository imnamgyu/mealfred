{"menu":"순살닭볶음탕","title":"순살닭볶음탕","band":"3-5세","dish_type":"soup","source":"standard","cook_min":25,"wait_min":0,"yield_g":70.3,"ings":[{"n":"닭고기","raw":"닭고기, 가슴(껍질 제거), 생것","g":40,"disp":null,"ssn":false,"na":18},{"n":"감자","raw":"감자, 대지, 생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근, 뿌리, 생것","g":5,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파, 생것","g":5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":2,"disp":"1/2작은술","ssn":true,"na":96},{"n":"고추장","raw":"고추장, 개량","g":1,"disp":"1/4작은술","ssn":true,"na":25},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕, 백설탕","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.2,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["순살 닭고기는 아이 한입 크기(2~3cm)로 썰어 끓는 물에 2분 데친 뒤 물에 헹궈 기름기와 잡내를 뺀다.","감자·양파·당근은 1.5cm 정도 작은 깍둑 모양으로 썰고, 파는 송송 썰고, 마늘은 다진다.","작은 그릇에 다진 마늘, 고추장 아주 조금, 고춧가루 한 꼬집(맵기는 아이에 맞춰 생략 가능), 설탕·간장 반 작은술씩, 후춧가루 살짝, 물 반 컵을 섞어 순한 양념장을 만든다.","냄비에 닭고기·채소·양념장을 모두 넣고 고루 섞은 뒤 중불에서 15분 정도, 감자가 포크로 쉽게 눌릴 때까지 끓이며 볶는다.","한 김 식혀 뜨겁지 않은지 확인하고 아이 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":64,"protein_g":9.9,"carb_g":4.8,"fat_g":0.4,"calcium_mg":7,"iron_mg":0.32,"sodium_mg":141,"na_flag":"ok"},"allergens":["대두","밀","닭고기"]}