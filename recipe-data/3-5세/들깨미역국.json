{"menu":"들깨미역국","title":"들깨미역국","band":"3-5세","dish_type":"soup","source":"standard","cook_min":20,"wait_min":10,"yield_g":8.9,"ings":[{"n":"들깨","raw":"들깨_말린것","g":3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"미역","raw":"미역, 말린것","g":3,"disp":null,"ssn":false,"na":226},{"n":"참기름","raw":"참기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장_재래","g":0.5,"disp":"약간","ssn":true,"na":40},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":144}],"steps":["마른 미역 한 줌을 찬물에 10분쯤 담가 부드럽게 불린 뒤, 아이가 삼키기 쉽게 2~3cm 길이로 짧게 자르고 마늘 반 쪽은 곱게 다진다.","작은 냄비에 참기름 반 큰술을 두르고 중불에서 미역과 다진 마늘을 2분 정도 달달 볶아 고소한 향을 낸다.","물 2컵을 부어 센불로 끓어오르면 약불로 줄여 10분간 뭉근하게 끓인 뒤 소금과 간장으로 아주 연하게 간을 맞춘다.","불을 끄기 직전에 들깨가루 1큰술을 풀어 넣고 한 번 저은 다음, 한 김 식혀 아이 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":35,"protein_g":1.4,"carb_g":2.3,"fat_g":2.8,"calcium_mg":46,"iron_mg":0.44,"sodium_mg":410,"na_flag":"review"},"allergens":["대두","밀"]}