{"menu":"멸치주먹밥","title":"잔멸치주먹밥","band":"3-5세","dish_type":"rice_main","source":"standard","cook_min":40,"wait_min":0,"yield_g":30.5,"ings":[{"n":"멥쌀","raw":"멥쌀_백미_생것","g":20,"disp":null,"ssn":false,"na":0},{"n":"멸치","raw":"멸치, 잔멸치, 삶아서 말린것","g":3.5,"disp":null,"ssn":false,"na":93},{"n":"당근","raw":"당근_뿌리_생것","g":3,"disp":null,"ssn":false,"na":1},{"n":"참기름","raw":"참기름","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"김","raw":"김, 참김, 구운것","g":0.4,"disp":null,"ssn":false,"na":2},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["쌀을 30분 불려 평소보다 물을 아주 조금 적게 잡아 고슬하게 밥을 짓는다(즉석밥이나 남은 밥 한 공기도 좋다).","당근과 피망을 새끼손톱보다 작게 곱게 다진다.","팬에 식용유를 얇게 두르고 잔멸치를 약불에서 1~2분 바삭하게 볶다가, 다진 당근·피망을 넣고 1분쯤 더 볶는다.","큰 그릇에 따뜻한 밥과 볶은 멸치·채소를 넣고 소금 아주 조금, 참기름 1작은술을 넣어 골고루 섞는다.","한 김 식힌 뒤 손에 물을 살짝 묻혀 아이 한입 크기(탁구공보다 작게)로 동글동글 뭉친다."],"steps_public":true,"nutri":{"kcal":110,"protein_g":3.1,"carb_g":16.2,"fat_g":3.4,"calcium_mg":26,"iron_mg":0.2,"sodium_mg":276,"na_flag":"ok"},"allergens":["대두"]}