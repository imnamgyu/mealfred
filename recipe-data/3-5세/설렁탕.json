{"menu":"설렁탕","title":"설렁탕","band":"3-5세","dish_type":"soup","source":"standard","cook_min":20,"wait_min":60,"yield_g":96.1,"ings":[{"n":"소고기","raw":"소고기_한우(1등급)_양지(업진살)_생것","g":41.5,"disp":null,"ssn":false,"na":23},{"n":"우족국물","raw":"우족국물, 중량3배물","g":41.5,"disp":null,"ssn":false,"na":6},{"n":"파","raw":"파, 생것","g":6.9,"disp":"0.5큰술","ssn":true,"na":1},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":4.2,"disp":"1작은술","ssn":true,"na":1},{"n":"생강","raw":"생강, 뿌리줄기, 생것","g":1.4,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":151},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["우족은 찬물에 하루 정도(중간중간 물을 갈아주며), 양지머리는 1시간쯤 담가 핏물을 뺀다.","냄비에 물을 팔팔 끓여 우족을 살짝 데친 뒤 찬물에 헹궈 불순물을 씻어낸다.","큰 냄비에 우족·양지·대파·마늘·생강을 넣고 물을 넉넉히 부어 센불에서 끓이다가, 끓어오르면 약불로 낮춰 2~3시간 푹 곤다.","국물을 체나 면포에 걸러 위에 뜬 기름을 걷어낸다.","우족의 살은 발라내고, 양지는 건져 결 반대로 얇게(0.5cm 두께) 썬 뒤 아이 한입 크기로 한 번 더 자른다.","그릇에 국물과 고기를 담고 송송 썬 파, 소금, 후춧가루 약간으로 간해 한 김 식혀 내준다."],"steps_public":true,"nutri":{"kcal":130,"protein_g":8.6,"carb_g":1.8,"fat_g":9.3,"calcium_mg":6,"iron_mg":0.97,"sodium_mg":182,"na_flag":"ok"},"allergens":["쇠고기"]}