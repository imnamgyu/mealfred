{"menu":"열대과일샐러드","title":"과일샐러드(요거트드레싱)","band":"3-5세","dish_type":"side","source":"standard","cook_min":15,"wait_min":0,"yield_g":75,"ings":[{"n":"요구르트","raw":"요구르트, 호상, 플레인","g":30,"disp":null,"ssn":false,"na":17},{"n":"사과","raw":"사과, 부사(후지), 생것","g":15,"disp":null,"ssn":false,"na":0},{"n":"참외","raw":"참외_씨 제거_생것","g":15,"disp":null,"ssn":false,"na":0},{"n":"토마토","raw":"토마토_방울토마토_생것","g":15,"disp":null,"ssn":false,"na":1}],"steps":["참외는 껍질을 벗기고 숟가락으로 씨를 긁어낸 뒤 새끼손톱 크기로 깍둑썬다.","사과도 같은 크기로 썰고, 방울토마토는 질식 위험이 있으니 반드시 세로로 4등분한다.","볼에 과일을 모두 담고 떠먹는 요거트 2~3큰술을 넣어 살살 버무린다.","냉장고에 10분 정도 두었다가 시원하게 낸다. 계절에 맞는 제철 과일로 바꿔도 좋다."],"steps_public":true,"nutri":{"kcal":46,"protein_g":1.9,"carb_g":7.1,"fat_g":1.3,"calcium_mg":45,"iron_mg":0.11,"sodium_mg":18,"na_flag":"ok"},"allergens":["우유","토마토"]}