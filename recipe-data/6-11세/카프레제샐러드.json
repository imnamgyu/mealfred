{"menu":"카프레제샐러드","title":"카프레제샐러드","band":"6-11세","dish_type":"side","source":"standard","cook_min":15,"wait_min":0,"yield_g":78.6,"ings":[{"n":"토마토","raw":"토마토, 생것","g":45.5,"disp":null,"ssn":false,"na":1},{"n":"상추","raw":"상추, 적하계, 생것","g":13,"disp":null,"ssn":false,"na":1},{"n":"치즈","raw":"치즈, 모짜렐라","g":13,"disp":null,"ssn":false,"na":32},{"n":"발사믹식초","raw":"발사믹식초","g":2.6,"disp":null,"ssn":false,"na":null},{"n":"올리브유","raw":"올리브유","g":2.6,"disp":"1/2작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕, 백설탕","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 난지형, 깐마늘, 생것","g":0.7,"disp":"약간","ssn":true,"na":0}],"steps":["토마토는 씻어 0.5cm 두께로 썰고, 방울토마토를 쓴다면 반드시 4등분해 자른다.","모짜렐라치즈도 토마토와 비슷한 0.5cm 두께로 썬다.","양상추는 씻어 아이 손바닥 절반 크기로 찢고 물기를 탈탈 턴다.","작은 그릇에 다진 마늘 약간, 발사믹식초 1작은술, 설탕 반 작은술, 올리브유 1큰술을 넣고 섞어 소스를 만든다.","접시에 토마토를 깔고 양상추와 치즈를 올린 뒤 소스를 살짝 뿌려 낸다."],"steps_public":true,"nutri":{"kcal":81,"protein_g":4.4,"carb_g":5,"fat_g":4.9,"calcium_mg":136,"iron_mg":0.3,"sodium_mg":33,"na_flag":"ok"},"allergens":["우유","토마토"]}