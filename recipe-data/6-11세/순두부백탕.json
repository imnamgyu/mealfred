{"menu":"순두부백탕","title":"순두부백탕","band":"6-11세","dish_type":"soup","source":"standard","cook_min":25,"wait_min":0,"yield_g":128.9,"ings":[{"n":"두부","raw":"두부, 순두부","g":100,"disp":null,"ssn":false,"na":4},{"n":"달걀","raw":"달걀, 생것","g":12.5,"disp":null,"ssn":false,"na":17},{"n":"양파","raw":"양파, 생것","g":8.8,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3.8,"disp":"1작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":2.5,"disp":null,"ssn":false,"na":55},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.6,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":223},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["작은 냄비에 물 2컵과 국물용 멸치 4~5마리를 넣고 중불에서 10분 정도 끓여 육수를 낸 뒤 멸치를 건져낸다.","육수가 우러나는 동안 달걀 1개를 그릇에 잘 풀어 두고, 양파는 새끼손톱 크기로 잘게 썰고, 파는 얇게 송송 썰고 마늘은 곱게 다진다.","육수에 순두부를 큰 숟가락으로 떠 넣고 중불에서 2~3분 끓이다가 양파·다진 마늘·파를 넣고 3분 더 끓인다.","풀어둔 달걀을 빙 둘러 붓고 30초쯤 그대로 두었다가 살살 저어 부드러운 달걀꽃을 만든다.","소금으로 아주 연하게 간을 맞추고(후추는 아이용이면 생략하거나 살짝만), 그릇에 담아 한 김 식혀서 낸다."],"steps_public":true,"nutri":{"kcal":71,"protein_g":10,"carb_g":2.2,"fat_g":2.4,"calcium_mg":77,"iron_mg":1.29,"sodium_mg":300,"na_flag":"ok"},"allergens":["난류(계란)","대두"]}