{"menu":"두부조림","title":"두부조림","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":137.4,"ings":[{"n":"두부","raw":"두부","g":120,"disp":null,"ssn":false,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":7,"disp":"0.5큰술","ssn":true,"na":335},{"n":"콩기름","raw":"콩기름","g":4,"disp":"1작은술","ssn":true,"na":0},{"n":"파","raw":"파_대파_생것","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.6,"disp":"1/2작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"깨소금","raw":"깨소금_가루_볶은것","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":0}],"steps":["두부는 키친타월로 물기를 꾹 눌러 없앤 뒤 아이가 먹기 좋게 2cm 크기, 1cm 두께로 자른다.","중불로 달군 팬에 기름을 두르고 두부를 앞뒤 각 2~3분씩 노릇하게 굽는다.","작은 그릇에 간장 1큰술, 설탕 반 큰술, 다진 파·다진 마늘 약간, 참기름과 깨소금 조금을 섞어 양념장을 만든다. 아이용이라면 고춧가루는 빼거나 아주 조금만 넣는다.","구운 두부에 양념장과 물 3큰술을 붓고 약불에서 5분 정도, 숟가락으로 국물을 끼얹어가며 촉촉하게 조린다.","한 김 식혀 밥 위에 올리거나 반찬으로 담아낸다."],"steps_public":true,"nutri":{"kcal":179,"protein_g":12.5,"carb_g":7.5,"fat_g":10.8,"calcium_mg":85,"iron_mg":2.1,"sodium_mg":336,"na_flag":"ok"},"allergens":["대두","밀"]}