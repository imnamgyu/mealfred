{"menu":"비빔만두","title":"비빔만두","band":"6-11세","dish_type":"snack","source":"standard","cook_min":15,"wait_min":0,"yield_g":87.1,"ings":[{"n":"만두","raw":"만두, 고기 만두, 냉동","g":56.3,"disp":null,"ssn":false,"na":160},{"n":"고추장","raw":"고추장, 개량","g":6.3,"disp":"0.4큰술","ssn":true,"na":155},{"n":"당근","raw":"당근, 뿌리, 생것","g":6.3,"disp":null,"ssn":false,"na":2},{"n":"양배추","raw":"양배추, 생것","g":6.3,"disp":null,"ssn":false,"na":1},{"n":"오이","raw":"오이, 다다기, 생것","g":6.3,"disp":null,"ssn":false,"na":0},{"n":"식초","raw":"식초, 사과식초","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":1.3,"disp":"1/4작은술","ssn":true,"na":100},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"설탕","raw":"설탕, 백설탕","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.3,"disp":"약간","ssn":true,"na":0}],"steps":["팬에 식용유를 두르고 중약불에서 작은 만두를 굴려가며 겉이 노릇해질 때까지 6~7분 굽는다.","오이·양배추·당근은 아이가 씹기 좋게 가늘고 짧게(3cm 길이) 채 썰고, 마늘은 곱게 다진다.","작은 그릇에 다진 마늘, 고추장 아주 조금(또는 생략), 간장, 식초, 설탕, 참기름을 섞어 순한 양념장을 만든다. 고춧가루는 아이 입맛에 따라 빼도 좋다.","구운 만두는 한 김 식혀 반으로 잘라 채소와 함께 그릇에 담고, 양념을 조금씩 넣어가며 살살 버무려준다."],"steps_public":true,"nutri":{"kcal":146,"protein_g":5.9,"carb_g":21.2,"fat_g":4.4,"calcium_mg":44,"iron_mg":1.88,"sodium_mg":418,"na_flag":"ok"},"allergens":["대두","밀","돼지고기"]}