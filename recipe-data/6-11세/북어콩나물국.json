{"menu":"북어콩나물국","title":"콩나물국","band":"6-11세","dish_type":"soup","source":"standard","cook_min":15,"wait_min":0,"yield_g":34.1,"ings":[{"n":"콩나물","raw":"콩나물_생것","g":21,"disp":null,"ssn":false,"na":1},{"n":"무","raw":"무, 조선무, 생것","g":7.5,"disp":null,"ssn":false,"na":1},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"참기름","raw":"참기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":108},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":0.2,"disp":null,"ssn":false,"na":3}],"steps":["무는 성냥개비 굵기·2.5cm 길이로 채 썰고, 콩나물은 흐르는 물에 씻어 체에 밭쳐 물기를 뺀다.","파는 송송 썰고 마늘 한 쪽은 곱게 다진다.","냄비에 참기름을 조금 두르고 중불에서 무를 2분쯤 볶아 향을 낸다.","물을 붓고 콩나물을 넣어 뚜껑을 연 채 5~6분 끓인 뒤, 파와 마늘을 넣고 간장과 소금으로 심심하게 간을 하고 후추를 아주 살짝 뿌린다.","콩나물은 아이가 먹기 좋게 가위로 짧게 잘라 주고, 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":25,"protein_g":1.2,"carb_g":1.5,"fat_g":1.8,"calcium_mg":17,"iron_mg":0.23,"sodium_mg":114,"na_flag":"ok"},"allergens":["대두"]}