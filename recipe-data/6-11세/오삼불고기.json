{"menu":"오삼불고기","title":"오삼불고기","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":15,"yield_g":73.8,"ings":[{"n":"돼지고기","raw":"돼지고기, 앞다리(꾸리살), 생것","g":18.8,"disp":null,"ssn":false,"na":9},{"n":"오징어","raw":"오징어, 생것","g":18.8,"disp":null,"ssn":false,"na":37},{"n":"양파","raw":"양파, 생것","g":12.5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":6.3,"disp":"0.4큰술","ssn":true,"na":1},{"n":"고추장","raw":"고추장, 개량","g":3.8,"disp":"1작은술","ssn":true,"na":93},{"n":"물엿","raw":"물엿","g":3.8,"disp":"1작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":3.8,"disp":"1작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":2.5,"disp":"1/2작은술","ssn":true,"na":200},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":1.3,"disp":"1/4작은술","ssn":true,"na":0}],"steps":["돼지고기와 오징어는 아이가 씹기 좋게 새끼손톱 크기로 잘게 썰고, 마늘은 다진다.","양파는 얇게 채 썰고, 파는 얇고 잘게 썬다.","볼에 고기와 오징어를 담고 다진 마늘, 고추장 아주 조금(또는 생략), 간장, 물엿을 넣어 고루 버무려 10분 재운다.","팬에 식용유를 두르고 중불에서 재운 재료를 4~5분, 고기가 완전히 익을 때까지 볶는다.","양파와 파를 넣어 1~2분 더 볶고, 불을 끈 뒤 참기름을 둘러 한 김 식혀서 낸다."],"steps_public":true,"nutri":{"kcal":119,"protein_g":7.7,"carb_g":7.4,"fat_g":6.4,"calcium_mg":9,"iron_mg":0.38,"sodium_mg":341,"na_flag":"ok"},"allergens":["대두","밀","돼지고기","오징어"]}