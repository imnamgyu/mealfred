{"menu":"안동찜닭","title":"안동찜닭(경남)","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":30,"wait_min":10,"yield_g":119.1,"ings":[{"n":"닭고기","raw":"닭고기_가슴(껍질 제거)_생것","g":62.5,"disp":null,"ssn":false,"na":28},{"n":"감자","raw":"감자, 대지, 생것","g":18.8,"disp":null,"ssn":false,"na":0},{"n":"양파","raw":"양파_생것","g":12.5,"disp":null,"ssn":false,"na":0},{"n":"당면","raw":"당면_고구마_말린것","g":8.8,"disp":null,"ssn":false,"na":1},{"n":"간장","raw":"간장, 개량, 산분해","g":6.3,"disp":"0.4큰술","ssn":true,"na":342},{"n":"당근","raw":"당근_뿌리_생것","g":6.3,"disp":null,"ssn":false,"na":2},{"n":"생강","raw":"생강, 뿌리줄기, 생것","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_황설탕","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금_천일염","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":90},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["감자·양파·당근은 아이 한입 크기(2cm 정도)로 썬다.","닭은 껍질과 기름을 떼고 작게 토막 낸 뒤 끓는 물에 1~2분 데쳐 건지고, 생강즙·소금·후춧가루 아주 조금으로 밑간한다.","간장 1큰술, 황설탕 반 큰술, 다진 마늘, 참기름 약간을 섞어 양념장을 만들고 닭에 버무려 10분 재운다.","냄비에 닭과 채소를 담고 재료가 잠길 듯 말 듯 물을 부어 중불에서 15분 끓인다.","물에 불린 당면을 짧게 잘라 넣고 5분 더 끓여 부드럽게 익힌다.","닭뼈를 발라내고 한 김 식혀 아이 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":131,"protein_g":15.5,"carb_g":13.8,"fat_g":1.3,"calcium_mg":19,"iron_mg":0.85,"sodium_mg":464,"na_flag":"ok"},"allergens":["대두","밀","닭고기"]}