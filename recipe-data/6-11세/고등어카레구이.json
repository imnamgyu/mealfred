{"menu":"고등어카레구이","title":"고등어카레구이","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":20,"wait_min":0,"yield_g":50.9,"ings":[{"n":"고등어","raw":"고등어, 생것","g":43.8,"disp":null,"ssn":false,"na":33},{"n":"콩기름","raw":"콩기름","g":3.1,"disp":"1작은술","ssn":true,"na":0},{"n":"카레","raw":"카레, 가루","g":2.5,"disp":null,"ssn":false,"na":102},{"n":"밀","raw":"밀, 중력밀가루","g":1.3,"disp":null,"ssn":false,"na":0},{"n":"소금","raw":"소금","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":90}],"steps":["손질된 고등어 한 토막을 아이 한 입 크기(2~3cm)로 자르고 가시를 꼼꼼히 발라낸 뒤 소금을 아주 살짝 뿌려 10분 둔다.","밀가루 2큰술에 카레가루 1작은술을 섞어, 고등어의 물기를 닦고 앞뒤로 얇게 묻힌다.","팬에 식용유를 넉넉히 두르고 중불로 달군 뒤 고등어를 올려 한 면당 3~4분씩 노릇하게 굽는다.","키친타월에 올려 기름을 빼고 한 김 식힌 뒤, 살을 한 번 더 눌러 가시가 없는지 확인하고 아이 접시에 담는다."],"steps_public":true,"nutri":{"kcal":121,"protein_g":9.2,"carb_g":2.4,"fat_g":8,"calcium_mg":13,"iron_mg":0.82,"sodium_mg":224,"na_flag":"ok"},"allergens":["대두","밀","고등어"]}