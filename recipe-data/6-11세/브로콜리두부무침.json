{"menu":"브로콜리두부무침","title":"브로콜리두부무침","band":"6-11세","dish_type":"side","source":"standard","cook_min":10,"wait_min":0,"yield_g":74.9,"ings":[{"n":"브로콜리","raw":"브로콜리_생것","g":54,"disp":null,"ssn":false,"na":2},{"n":"두부","raw":"두부","g":18,"disp":null,"ssn":false,"na":0},{"n":"참기름","raw":"참기름","g":0.9,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장_재래","g":0.5,"disp":"약간","ssn":true,"na":43},{"n":"소금","raw":"소금, 정제염","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":195},{"n":"참깨","raw":"참깨_흰깨_볶은것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.4,"disp":"약간","ssn":true,"na":0}],"steps":["브로콜리는 흐르는 물에 씻어 새끼손톱 두 개 크기의 작은 송이로 자른다.","끓는 물에 브로콜리를 1~2분 데친 뒤 찬물에 헹궈 체에 밭쳐 물기를 뺀다.","두부는 끓는 물에 30초쯤 살짝 데쳐 건진 다음 숟가락 뒷면으로 곱게 으깬다.","볼에 브로콜리와 으깬 두부, 다진 마늘 약간, 간장 조금을 넣고 살살 무친다.","마지막에 참기름과 참깨를 넣어 한 번 더 버무리고, 간을 본 뒤 심심하면 소금을 아주 조금만 더한다."],"steps_public":true,"nutri":{"kcal":47,"protein_g":3.6,"carb_g":4.3,"fat_g":2.1,"calcium_mg":38,"iron_mg":0.74,"sodium_mg":240,"na_flag":"ok"},"allergens":["대두","밀"]}