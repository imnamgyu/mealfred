{"menu":"도토리묵국","title":"도토리묵국","band":"6-11세","dish_type":"soup","source":"standard","cook_min":15,"wait_min":0,"yield_g":145,"ings":[{"n":"도토리묵","raw":"도토리묵","g":125,"disp":null,"ssn":false,"na":95},{"n":"김치","raw":"김치, 배추 김치","g":10,"disp":null,"ssn":false,"na":55},{"n":"파","raw":"파, 생것","g":3.8,"disp":"1작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":2.5,"disp":null,"ssn":false,"na":55},{"n":"참기름","raw":"참기름","g":1.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":0.6,"disp":"약간","ssn":true,"na":50},{"n":"김","raw":"김, 참김, 말린것","g":0.6,"disp":null,"ssn":false,"na":8},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물 3컵과 국물용 멸치 5~6마리를 넣고 중불에서 10분 끓여 육수를 낸 뒤 멸치를 건지고, 간장 1작은술로 심심하게 간한다.","도토리묵은 아이가 삼키기 좋게 손가락 굵기(폭 1cm, 길이 3cm 정도)로 썰고, 김은 살짝 구워 잘게 부숴 김가루를 만든다.","배추김치는 물에 씻어 양념을 덜어내고 잘게 다지듯 썰고, 파도 잘게 썰고, 마늘은 곱게 다진다.","썰어 둔 김치·파·마늘을 작은 그릇에 모아 참기름 몇 방울로 고루 버무려 고명을 만든다.","그릇에 묵을 담고 한 김 식힌 따뜻한 육수를 부은 뒤, 김치 고명과 김가루를 올려 낸다."],"steps_public":true,"nutri":{"kcal":89,"protein_g":2.4,"carb_g":15.2,"fat_g":2.1,"calcium_mg":81,"iron_mg":0.82,"sodium_mg":263,"na_flag":"ok"},"allergens":["대두","밀","새우"]}