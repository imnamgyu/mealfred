{"menu":"유부초밥","title":"유부초밥","band":"6-11세","dish_type":"etc","source":"standard","cook_min":40,"wait_min":0,"yield_g":104.7,"ings":[{"n":"멥쌀","raw":"멥쌀, 백미, 생것","g":65,"disp":null,"ssn":false,"na":1},{"n":"두부","raw":"두부, 유부","g":19.5,"disp":null,"ssn":false,"na":1},{"n":"피망","raw":"피망, 초록색, 생것","g":6.5,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근, 뿌리, 생것","g":3.3,"disp":null,"ssn":false,"na":1},{"n":"참기름","raw":"참기름","g":3.3,"disp":"1작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":1.3,"disp":"1/4작은술","ssn":true,"na":104},{"n":"설탕","raw":"설탕, 백설탕","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"식초","raw":"식초, 사과식초","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참깨","raw":"참깨, 검정깨, 볶은것","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.7,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":234}],"steps":["쌀 반 컵을 30분 불려 평소보다 물을 약간 적게 잡아 고슬하게 밥을 짓는다.","초밥용 유부는 반으로 어슷하게 잘라 끓는 물에 30초 데친 뒤 찬물에 헹구고 꼭 짜서 기름기와 물기를 뺀다.","당근과 피망은 쌀알 크기로 잘게 다져 기름 두른 팬에 중불로 1~2분 볶는다.","큰 볼에 밥과 볶은 채소를 담고 설탕·식초·간장·소금 약간, 참기름과 검정깨를 넣어 주걱으로 자르듯 골고루 섞는다.","유부 주머니를 벌려 밥을 2/3쯤 채우고, 아이가 한입에 물기 좋게 작게 뭉쳐 마무리한다."],"steps_public":true,"nutri":{"kcal":440,"protein_g":11.1,"carb_g":64.2,"fat_g":13.8,"calcium_mg":161,"iron_mg":2.17,"sodium_mg":342,"na_flag":"ok"},"allergens":["대두","밀"]}