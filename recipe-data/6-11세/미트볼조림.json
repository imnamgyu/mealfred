{"menu":"미트볼조림","title":"미트볼조림","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":20,"wait_min":0,"yield_g":75.1,"ings":[{"n":"미트볼","raw":"미트볼, 냉동","g":56.3,"disp":null,"ssn":false,"na":0},{"n":"양파","raw":"양파, 생것","g":12.5,"disp":null,"ssn":false,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":3.1,"disp":"1작은술","ssn":true,"na":149},{"n":"콩기름","raw":"콩기름","g":1.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["양파 4분의 1개를 1~2cm 크기로 썰고, 마늘 반 쪽은 곱게 다진다.","작은 그릇에 다진 마늘, 간장 1작은술, 물 3큰술을 넣어 양념장을 만든다. 후춧가루는 아이 취향에 따라 아주 조금만 넣거나 뺀다.","팬에 콩기름 1작은술을 두르고 중불에서 미트볼을 4~5분간 굴려 가며 속까지 익힌다.","양파와 양념장을 넣고 약불로 줄여 3분 정도, 국물이 자작하게 배도록 조린다.","미트볼이 크면 반으로 잘라 주고, 한 김 식혀 접시에 담는다."],"steps_public":true,"nutri":{"kcal":163,"protein_g":7.1,"carb_g":8.8,"fat_g":11.1,"calcium_mg":13,"iron_mg":0.81,"sodium_mg":150,"na_flag":"ok"},"allergens":["대두","밀","돼지고기","쇠고기"]}