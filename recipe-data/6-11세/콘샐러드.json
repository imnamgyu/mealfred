{"menu":"콘샐러드","title":"콘샐러드(경남)","band":"6-11세","dish_type":"side","source":"standard","cook_min":10,"wait_min":0,"yield_g":75,"ings":[{"n":"옥수수","raw":"옥수수, 가당, 통조림","g":52.5,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":7.5,"disp":null,"ssn":false,"na":2},{"n":"마요네즈","raw":"마요네즈, 난황","g":7.5,"disp":"0.5큰술","ssn":true,"na":36},{"n":"양파","raw":"양파_생것","g":7.5,"disp":null,"ssn":false,"na":0}],"steps":["통조림 옥수수는 체에 밭쳐 국물을 빼고, 한 번 헹구면 짠맛이 줄어든다.","양파와 당근은 새끼손톱보다 작게 잘게 다진다. 생양파가 매우면 찬물에 5분 담갔다 물기를 짠다.","어린 아이라면 당근을 전자레인지에 30초 돌려 살짝 부드럽게 해도 좋다.","볼에 옥수수와 채소를 담고 마요네즈 1큰술을 넣어 고루 버무린다.","작은 그릇에 소복하게 담아 숟가락으로 떠먹게 내어준다."],"steps_public":true,"nutri":{"kcal":112,"protein_g":1.3,"carb_g":13.1,"fat_g":6.1,"calcium_mg":5,"iron_mg":0.24,"sodium_mg":38,"na_flag":"ok"},"allergens":["난류(계란)","대두"]}