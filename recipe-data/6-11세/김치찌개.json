{"menu":"김치찌개","title":"김치찌개","band":"6-11세","dish_type":"soup","source":"standard","cook_min":20,"wait_min":10,"yield_g":43.1,"ings":[{"n":"김치","raw":"김치, 배추 김치","g":25,"disp":null,"ssn":false,"na":138},{"n":"양파","raw":"양파, 생것","g":8.8,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3.8,"disp":"1작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":2.5,"disp":null,"ssn":false,"na":55},{"n":"참기름","raw":"참기름","g":1.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":137},{"n":"간장","raw":"간장, 개량, 산분해","g":0.3,"disp":"약간","ssn":true,"na":14}],"steps":["국물용 멸치 5~6마리를 물 2컵과 함께 냄비에 넣고 중불에서 10분 우려 육수를 뽑아 둔다.","배추김치는 속양념을 살짝 털고 1cm 폭으로 잘게 자르고, 양파도 아이가 먹기 좋은 작은 크기로 썬다.","파는 얇게 송송 자르고 마늘은 곱게 다져 준비한다.","다른 냄비에 참기름을 반 큰술 둘러 중불에서 김치·양파·다진 마늘을 3분쯤 볶아 향을 낸 다음, 만들어 둔 육수를 부어 센불로 끓어오르게 한다.","중약불로 낮춰 10분간 뭉근하게 끓이고 파를 더한 뒤, 간장과 소금으로 아이 입맛에 맞게 약하게 간하고 한 김 식혀 담아 낸다."],"steps_public":true,"nutri":{"kcal":35,"protein_g":2,"carb_g":2.1,"fat_g":2.1,"calcium_mg":72,"iron_mg":0.6,"sodium_mg":344,"na_flag":"ok"},"allergens":["대두","밀","새우"]}