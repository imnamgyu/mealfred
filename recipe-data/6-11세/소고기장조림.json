{"menu":"소고기장조림","title":"쇠고기장조림","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":50,"wait_min":20,"yield_g":72.5,"ings":[{"n":"소고기","raw":"소고기_한우(1등급)_사태(앞사태)_생것","g":54,"disp":null,"ssn":false,"na":36},{"n":"간장","raw":"간장, 개량, 양조","g":9,"disp":"0.6큰술","ssn":true,"na":431},{"n":"설탕","raw":"설탕_백설탕","g":3.6,"disp":"1작은술","ssn":true,"na":0},{"n":"청주","raw":"청주, 알코올 16%","g":3.6,"disp":"1작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.8,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["소고기는 찬물에 20분쯤 담가 핏물을 빼고 건진다.","작은 그릇에 다진 마늘, 간장 2큰술, 설탕 1작은술, 참기름·청주 약간과 후춧가루 아주 조금을 섞어 양념을 만들어 둔다.","냄비에 고기가 잠길 만큼 물을 붓고 중불로 30분 정도 푹 삶은 뒤 건져, 아이가 씹기 쉽게 결대로 잘게 찢는다.","냄비에 물 1컵과 찢은 고기, 양념을 넣고 약불로 15분쯤 국물이 자작해질 때까지 조린다.","한 김 식혀 짧게 찢은 고기 위주로 밥에 곁들여 낸다."],"steps_public":true,"nutri":{"kcal":113,"protein_g":13.5,"carb_g":5.8,"fat_g":3.2,"calcium_mg":7,"iron_mg":1.64,"sodium_mg":467,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}