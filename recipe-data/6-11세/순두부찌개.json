{"menu":"순두부찌개","title":"순두부찌개","band":"6-11세","dish_type":"soup","source":"standard","cook_min":15,"wait_min":0,"yield_g":222.3,"ings":[{"n":"두부","raw":"두부, 순두부","g":180,"disp":null,"ssn":false,"na":7},{"n":"달걀","raw":"달걀, 생것","g":18,"disp":null,"ssn":false,"na":25},{"n":"양파","raw":"양파_생것","g":12.6,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":5.4,"disp":"1작은술","ssn":true,"na":1},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":3.6,"disp":null,"ssn":false,"na":79},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.9,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.9,"disp":"1/4작은술","ssn":true,"na":324},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["작은 냄비에 물 2컵과 국물용 멸치 4~5마리를 넣고 중불에서 7분쯤 끓여 육수를 낸 뒤 멸치를 건진다.","달걀 1개는 그릇에 풀어두고, 양파는 아이가 먹기 좋게 새끼손톱 크기로 잘게 썬다. 파는 송송 썰고 마늘은 다진다.","육수에 순두부 반 봉지를 큼직하게 떠 넣고 고춧가루를 아주 조금(아이 입맛이면 생략) 넣어 중불에서 끓인다.","국물이 끓어오르면 양파, 다진 마늘, 파를 넣고 3분 더 끓인다.","풀어둔 달걀을 빙 둘러 붓고 30초 뒤 살살 저은 다음, 소금으로 심심하게 간하고 참기름 몇 방울로 마무리한다. 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":126,"protein_g":17.1,"carb_g":3.2,"fat_g":4.5,"calcium_mg":115,"iron_mg":2.18,"sodium_mg":436,"na_flag":"ok"},"allergens":["난류(계란)","대두"]}