{"menu":"수제함박스테이크","title":"함박스테이크","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":96.4,"ings":[{"n":"소고기","raw":"소고기_한우(1등급)_등심_생것","g":22,"disp":null,"ssn":false,"na":10},{"n":"돼지고기","raw":"돼지고기_등심_생것","g":20,"disp":null,"ssn":false,"na":8},{"n":"달걀","raw":"달걀, 생것","g":14,"disp":null,"ssn":false,"na":19},{"n":"양파","raw":"양파_생것","g":12,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":8,"disp":null,"ssn":false,"na":2},{"n":"밀","raw":"밀, 빵가루","g":8,"disp":null,"ssn":false,"na":25},{"n":"돈까스소스","raw":"돈까스 소스","g":6,"disp":null,"ssn":false,"na":null},{"n":"콩기름","raw":"콩기름","g":4,"disp":"1작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":144},{"n":"후추","raw":"후추, 검은후추, 가루","g":0,"disp":"약간","ssn":true,"na":0}],"steps":["다진 소고기와 다진 돼지고기를 같은 양(1:1)으로 준비하고, 양파는 잘게 다진다.","중불로 달군 팬에 기름을 두르고 다진 양파를 3~4분 볶아 수분이 날아가면 불을 끄고 완전히 식힌다.","볼에 고기·볶은 양파·달걀·빵가루를 넣고 소금 한 꼬집(후추는 생략하거나 아주 조금)으로 간한 뒤 끈기가 생기게 치대어, 아이 손바닥만 한 크기로 도톰하고 납작하게 빚는다.","기름 두른 팬에 반죽을 올려 중약불에서 한 면당 4~5분씩, 뚜껑을 덮어 속까지 완전히 익힌다(가운데를 눌러 맑은 육즙이 나오면 완성).","스테이크소스를 조금 끼얹고, 한 입 크기로 잘라 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":200,"protein_g":11.9,"carb_g":10.1,"fat_g":11.6,"calcium_mg":15,"iron_mg":0.98,"sodium_mg":209,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","돼지고기","토마토","쇠고기"]}