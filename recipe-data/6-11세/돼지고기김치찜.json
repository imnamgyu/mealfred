{"menu":"돼지고기김치찜","title":"돼지고기김치찜","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":33,"yield_g":81,"ings":[{"n":"돼지고기","raw":"돼지고기_목심(목심살)_생것","g":54,"disp":null,"ssn":false,"na":35},{"n":"김치","raw":"김치, 배추 김치","g":18,"disp":null,"ssn":false,"na":99},{"n":"파","raw":"파, 생것","g":5.4,"disp":"1작은술","ssn":true,"na":1},{"n":"콩기름","raw":"콩기름","g":1.8,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.9,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":130},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["돼지고기는 아이 한입 크기(2~3cm)로 썰고, 파와 마늘은 곱게 다진다.","썬 고기에 다진 파·마늘, 설탕 약간, 후춧가루를 넣고 버무려 10분쯤 재워둔다.","배추김치는 양념을 살짝 털어 준비하고, 대파는 4~5cm 길이로 큼직하게 썬다. 김치가 매우면 물에 한 번 헹궈도 좋다.","냄비에 식용유를 두르고 중불에서 재운 고기를 2~3분 볶다가, 김치와 대파를 얹고 재료가 잠길 듯 말 듯하게 물을 부어 뚜껑을 덮고 약불로 20분쯤 뭉근히 익힌다.","고기와 김치가 부드러워지면 소금으로 간을 맞추고, 국물이 자작해질 때까지 5분 더 졸인 뒤 한 김 식혀 김치를 가위로 잘게 잘라 내준다."],"steps_public":true,"nutri":{"kcal":151,"protein_g":9.8,"carb_g":2.2,"fat_g":10.7,"calcium_mg":16,"iron_mg":0.56,"sodium_mg":265,"na_flag":"ok"},"allergens":["대두","새우","돼지고기"]}