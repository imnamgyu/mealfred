{"menu":"한우불고기","title":"쇠고기불고기","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":13,"yield_g":90.4,"ings":[{"n":"소고기","raw":"소고기_한우(1등급)_안심(안심살)_생것","g":56.3,"disp":null,"ssn":false,"na":71},{"n":"당근","raw":"당근_뿌리_생것","g":9.4,"disp":null,"ssn":false,"na":2},{"n":"양파","raw":"양파_생것","g":9.4,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":6.3,"disp":"0.4큰술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 양조","g":3.8,"disp":"1작은술","ssn":true,"na":179},{"n":"콩기름","raw":"콩기름","g":3.1,"disp":"1작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["쇠고기는 아이가 씹기 좋게 3cm 길이로 짧게 자르고, 양파와 당근은 0.5cm 두께로 얇게 채 썬다.","대파는 송송 썰어 두고 마늘 반 쪽은 곱게 다진다.","볼에 쇠고기와 다진 마늘, 간장, 설탕 약간, 참기름, 후춧가루 한 꼬집을 넣고 조물조물 무쳐 10분쯤 재운다.","팬에 식용유를 살짝 두르고 중불에서 재운 고기를 2~3분 볶는다.","고기가 거의 익으면 당근·양파·파를 넣고 3분 더 볶아 채소가 부드러워지면 불을 끈다.","접시에 담아 한 김 식힌 뒤 아이에게 준다."],"steps_public":true,"nutri":{"kcal":162,"protein_g":11.5,"carb_g":3.4,"fat_g":10.8,"calcium_mg":10,"iron_mg":1.76,"sodium_mg":255,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}