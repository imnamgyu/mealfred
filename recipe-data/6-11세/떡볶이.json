{"menu":"떡볶이","title":"떡볶이","band":"6-11세","dish_type":"snack","source":"standard","cook_min":10,"wait_min":10,"yield_g":133.2,"ings":[{"n":"멥쌀떡","raw":"멥쌀떡, 가래떡","g":100,"disp":null,"ssn":false,"na":261},{"n":"양배추","raw":"양배추_생것","g":14,"disp":null,"ssn":false,"na":1},{"n":"어묵","raw":"어묵, 튀긴것","g":12,"disp":null,"ssn":false,"na":84},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"고추장","raw":"고추장, 개량","g":2,"disp":"1/2작은술","ssn":true,"na":50},{"n":"간장","raw":"간장, 개량, 양조","g":1,"disp":"1/4작은술","ssn":true,"na":48},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.2,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":72},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["떡볶이 떡은 미지근한 물에 10분 담가 말랑하게 불린다.","양배추는 3cm 조각으로, 어묵은 아이가 씹기 좋게 1.5cm 폭으로 썰고(꼬치는 반드시 뺀다), 파는 송송 썰고 마늘은 다진다.","작은 그릇에 다진 마늘·고추장 조금·간장·소금·설탕·참기름을 섞어 순한 양념장을 만든다.","냄비에 물 1컵을 붓고 양념장을 풀어 중불에서 끓이다가, 끓어오르면 떡과 어묵을 넣는다.","양배추와 파를 넣고 3~4분 끓인 뒤 센불에서 국물을 자작하게 졸이고, 한 김 식혀 떡을 잘라 내준다."],"steps_public":true,"nutri":{"kcal":198,"protein_g":4.4,"carb_g":43.4,"fat_g":0.9,"calcium_mg":19,"iron_mg":0.24,"sodium_mg":516,"na_flag":"ok"},"allergens":["대두","밀"]}