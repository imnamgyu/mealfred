{"menu":"한우미역국","title":"쇠고기미역국","band":"6-11세","dish_type":"soup","source":"standard","cook_min":45,"wait_min":0,"yield_g":22.4,"ings":[{"n":"소고기","raw":"소고기, 한우, 양지, 생것","g":15,"disp":null,"ssn":false,"na":8},{"n":"미역","raw":"미역, 말린것","g":3.8,"disp":null,"ssn":false,"na":283},{"n":"참기름","raw":"참기름","g":1.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":0.6,"disp":"약간","ssn":true,"na":50},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180}],"steps":["냄비에 물 3컵과 국거리용 소고기 한 줌을 넣고 중불에서 15분 정도 끓여 육수를 낸 뒤, 고기만 건져 아이가 씹기 좋게 잘게 찢어 둔다.","마른 미역 한 줌은 물에 10분 불려 부드러워지면 1~2cm 길이로 짧게 자르고, 마늘은 다진다.","빈 냄비에 참기름 1작은술을 두르고 미역과 마늘을 중불에서 2분 볶다가 육수를 붓고 끓인다.","국물이 끓으면 찢어 둔 소고기를 넣고 약불로 줄여 10분 더 푹 끓인 뒤 소금과 간장으로 심심하게 간한다.","한 김 식혀 미지근해지면 아이 그릇에 담아 낸다."],"steps_public":true,"nutri":{"kcal":61,"protein_g":3.6,"carb_g":1.9,"fat_g":4.8,"calcium_mg":44,"iron_mg":0.55,"sodium_mg":521,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}