{"menu":"꽃게탕","title":"꽃게탕","band":"6-11세","dish_type":"soup","source":"standard","cook_min":20,"wait_min":0,"yield_g":94,"ings":[{"n":"게","raw":"게, 꽃게, 생것","g":50,"disp":null,"ssn":false,"na":209},{"n":"무","raw":"무, 조선무, 생것","g":18.8,"disp":null,"ssn":false,"na":2},{"n":"양파","raw":"양파, 생것","g":6.3,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":6.3,"disp":"0.4큰술","ssn":true,"na":1},{"n":"호박","raw":"호박, 애호박, 생것","g":6.3,"disp":null,"ssn":false,"na":0},{"n":"된장","raw":"된장, 개량","g":3.8,"disp":"1작은술","ssn":true,"na":163},{"n":"고춧가루","raw":"고춧가루, 가루","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":90}],"steps":["손질된 꽃게 반 마리는 4조각으로 나누고, 무는 새끼손톱보다 조금 큰 깍둑 모양으로 썬다.","애호박은 반달 모양 0.5cm 두께로, 양파는 한입 크기로 썰고, 파는 송송·마늘은 곱게 다진다.","작은 그릇에 된장 1작은술·다진 마늘·소금 한 꼬집을 섞는다(아이용은 고춧가루를 빼거나 아주 살짝만).","냄비에 물 2컵을 붓고 무와 양념을 넣어 센불에서 끓어오르면 중불로 5분 익힌다.","꽃게·애호박·양파·파를 넣고 7~8분 더 끓여 게가 완전히 익으면 불을 끈다.","살만 발라 껍데기와 잔뼈를 꼼꼼히 빼고, 한 김 식혀 국물과 함께 담아 준다."],"steps_public":true,"nutri":{"kcal":58,"protein_g":9.1,"carb_g":3.8,"fat_g":0.6,"calcium_mg":76,"iron_mg":0.79,"sodium_mg":466,"na_flag":"ok"},"allergens":["대두","밀","게"]}