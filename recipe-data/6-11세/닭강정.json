{"menu":"닭강정","title":"닭강정","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":10,"yield_g":76.9,"ings":[{"n":"닭고기","raw":"닭고기, 가슴(껍질 제거), 생것","g":37.5,"disp":null,"ssn":false,"na":17},{"n":"밀","raw":"밀, 튀김가루","g":12.5,"disp":null,"ssn":false,"na":110},{"n":"콩기름","raw":"콩기름","g":12.5,"disp":"0.8큰술","ssn":true,"na":0},{"n":"달걀","raw":"달걀, 생것","g":6.3,"disp":null,"ssn":false,"na":9},{"n":"토마토케첩","raw":"토마토 케첩","g":3.8,"disp":null,"ssn":false,"na":40},{"n":"고추장","raw":"고추장, 개량","g":2.5,"disp":"1/2작은술","ssn":true,"na":62},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕, 백설탕","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":90},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["닭가슴살을 아이가 한입에 먹기 좋은 2cm 크기로 잘라 소금과 후춧가루를 살짝 뿌려 10분 정도 재워 두고, 마늘 한 쪽은 곱게 다진다.","볼에 튀김가루 3큰술, 달걀 1개, 물 2큰술을 넣고 멍울 없이 풀어 튀김옷을 만든 뒤 닭고기에 고루 묻힌다.","작은 냄비에 식용유를 2cm 깊이로 붓고 중불에서 170도(반죽을 떨어뜨리면 바로 떠오르는 정도)로 달군 뒤, 닭고기를 3~4분 노릇하게 튀겨 키친타월에 올려 기름을 뺀다.","팬에 다진 마늘, 고추장 약간, 케첩 1큰술, 설탕 1작은술, 물 2큰술을 넣고 약불에서 1분 정도 보글보글 끓여 소스를 만든다. 아이용은 고추장을 아주 조금만 넣거나 케첩 위주로 하면 맵지 않다.","불을 끄고 튀긴 닭을 소스에 넣어 골고루 버무린 뒤 한 김 식혀 아이에게 낸다."],"steps_public":true,"nutri":{"kcal":222,"protein_g":10.6,"carb_g":13.2,"fat_g":13.4,"calcium_mg":16,"iron_mg":0.39,"sodium_mg":327,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","토마토","닭고기"]}