{"menu":"돼지고기두루치기","title":"돼지고기두루치기","band":"6-11세","dish_type":"etc","source":"standard","cook_min":15,"wait_min":0,"yield_g":106.2,"ings":[{"n":"돼지고기","raw":"돼지고기_앞다리(꾸리살)_생것","g":54,"disp":null,"ssn":false,"na":26},{"n":"양파","raw":"양파_생것","g":18,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":9,"disp":"0.6큰술","ssn":true,"na":2},{"n":"고추장","raw":"고추장, 개량","g":5.4,"disp":"1작은술","ssn":true,"na":134},{"n":"물엿","raw":"물엿","g":5.4,"disp":"1작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":5.4,"disp":"1작은술","ssn":true,"na":0},{"n":"간장","raw":"간장_재래","g":3.6,"disp":"1작은술","ssn":true,"na":288},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":3.6,"disp":"1작은술","ssn":true,"na":1},{"n":"참기름","raw":"참기름","g":1.8,"disp":"1/2작은술","ssn":true,"na":0}],"steps":["돼지고기는 아이가 씹기 좋게 얇고 작게(새끼손톱 두 개 크기) 썰고, 마늘은 곱게 다진다.","양파는 가늘게 채 썰고 파는 어슷하게 썬다.","볼에 돼지고기와 다진 마늘, 고추장 조금, 간장, 물엿을 넣고 버무려 잠시 재운다.","팬에 기름을 두르고 중불에서 고기를 3분쯤 볶아 겉을 익힌다.","양파와 파를 넣고 2~3분 더 볶아 고기 속까지 완전히 익으면 참기름 한 방울로 마무리한다.","한 김 식혀 맵지 않은지 맛을 보고 담아낸다."],"steps_public":true,"nutri":{"kcal":181,"protein_g":11.1,"carb_g":10.2,"fat_g":10.4,"calcium_mg":12,"iron_mg":0.76,"sodium_mg":451,"na_flag":"ok"},"allergens":["대두","밀","돼지고기"]}