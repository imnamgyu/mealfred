{"menu":"돈육김치찌개","title":"돈육김치찌개","band":"6-11세","dish_type":"soup","source":"standard","cook_min":20,"wait_min":0,"yield_g":64,"ings":[{"n":"돼지고기","raw":"돼지고기_등심_생것","g":37.5,"disp":null,"ssn":false,"na":16},{"n":"김치","raw":"김치, 배추 김치","g":12.5,"disp":null,"ssn":false,"na":69},{"n":"양파","raw":"양파_생것","g":8.8,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3.8,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장, 개량, 산분해","g":0.6,"disp":"약간","ssn":true,"na":34},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":90}],"steps":["돼지고기는 새끼손톱 크기로 잘게 썰고, 배추김치는 양념을 물에 한 번 헹궈 매운기를 줄인 뒤 1cm 폭으로 자르며, 양파도 비슷한 크기로 준비한다.","파는 얇게 어슷하게 자르고, 마늘 반쪽 분량을 곱게 다져 둔다.","냄비를 중불에 올려 돼지고기를 2분쯤 먼저 볶고, 여기에 김치·양파·다진 마늘을 더해 3분 정도 같이 볶아 향을 낸다.","물 2컵을 붓고 센불에서 한소끔 끓인 뒤 중약불로 낮춰 10분간 뭉근히 끓이고, 마지막에 파를 넣고 간장과 소금으로 심심하게 간을 맞춘 다음 한 김 식혀 준다."],"steps_public":true,"nutri":{"kcal":63,"protein_g":9.2,"carb_g":1.8,"fat_g":1.8,"calcium_mg":10,"iron_mg":0.29,"sodium_mg":210,"na_flag":"ok"},"allergens":["대두","밀","새우","돼지고기"]}