{"menu":"멸치아몬드볶음","title":"바삭 멸치아몬드볶음","band":"6-11세","dish_type":"side_main","source":"ai_generated","cook_min":10,"wait_min":0,"yield_g":29.6,"ings":[{"n":"멸치","raw":"멸치, 잔멸치, 삶아서 말린것","g":15,"disp":null,"ssn":false,"na":397},{"n":"아몬드","raw":"아몬드, 말린것","g":8,"disp":null,"ssn":false,"na":1},{"n":"콩기름","raw":"콩기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":2,"disp":"1/2작은술","ssn":true,"na":96},{"n":"물엿","raw":"물엿","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"참깨","raw":"참깨, 흰깨, 볶은것","g":0.3,"disp":"약간","ssn":true,"na":0}],"steps":["아몬드는 통째로 주지 않도록 칼로 새끼손톱 크기 이하로 잘게 다지거나, 슬라이스 아몬드를 반으로 부숴 준비한다.","마른 팬을 약불로 달궈 잔멸치를 2분간 저어 가며 볶아 수분과 비린내를 날린 뒤 체에 쳐서 가루를 털어낸다.","같은 팬에 콩기름을 두르고 약불에서 멸치와 다진 아몬드를 1~2분간 노릇하게 볶는다.","불을 끄고 간장과 물엿을 넣어 잔열로 재빨리 버무려 타거나 딱딱해지지 않게 한다.","참기름과 참깨를 넣고 고루 섞은 뒤 넓은 접시에 펼쳐 식혀 바삭하게 마무리한다."],"steps_public":true,"nutri":{"kcal":108,"protein_g":null,"carb_g":null,"fat_g":null,"calcium_mg":null,"iron_mg":null,"sodium_mg":493,"na_flag":"ok"},"allergens":["대두","밀"]}