{"menu":"함박스테이크","title":"함박스테이크","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":96.4,"ings":[{"n":"소고기","raw":"소고기_한우(1등급)_등심_생것","g":22,"disp":null,"ssn":false,"na":10},{"n":"돼지고기","raw":"돼지고기_등심_생것","g":20,"disp":null,"ssn":false,"na":8},{"n":"달걀","raw":"달걀, 생것","g":14,"disp":null,"ssn":false,"na":19},{"n":"양파","raw":"양파_생것","g":12,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":8,"disp":null,"ssn":false,"na":2},{"n":"밀","raw":"밀, 빵가루","g":8,"disp":null,"ssn":false,"na":25},{"n":"돈까스소스","raw":"돈까스 소스","g":6,"disp":null,"ssn":false,"na":null},{"n":"콩기름","raw":"콩기름","g":4,"disp":"1작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":144},{"n":"후추","raw":"후추, 검은후추, 가루","g":0,"disp":"약간","ssn":true,"na":0}],"steps":["다진 소고기와 다진 돼지고기를 같은 양(각 50g 정도)으로 준비하고, 양파 1/4개는 쌀알 크기로 잘게 다진다.","중불로 달군 팬에 식용유를 살짝 두르고 다진 양파를 2~3분 볶아 수분이 날아가면 불을 끄고 완전히 식힌다.","볼에 고기·식힌 양파·달걀 조금·빵가루 2큰술·소금 한 꼬집·후추 아주 조금을 넣고 끈기가 생기도록 치댄 뒤, 아이 손바닥만 하게 도톰한 원형(두께 1.5cm)으로 빚는다.","팬에 기름을 두르고 중약불에서 앞뒤로 각 4~5분씩, 속까지 완전히 익도록 굽는다. 젓가락으로 찔러 맑은 육즙이 나오면 다 익은 것이다.","스테이크소스를 얇게 바르고 한 김 식힌 뒤, 아이가 먹기 좋게 한입 크기로 잘라 준다."],"steps_public":true,"nutri":{"kcal":200,"protein_g":11.9,"carb_g":10.1,"fat_g":11.6,"calcium_mg":15,"iron_mg":0.98,"sodium_mg":209,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","돼지고기","토마토","쇠고기"]}