{"menu":"달걀장조림","title":"계란장조림","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":25,"wait_min":0,"yield_g":86.9,"ings":[{"n":"달걀","raw":"달걀, 생것","g":72,"disp":null,"ssn":false,"na":99},{"n":"간장","raw":"간장, 개량, 양조","g":9,"disp":"0.6큰술","ssn":true,"na":431},{"n":"설탕","raw":"설탕, 백설탕","g":3.6,"disp":"1작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.8,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["달걀은 찬물에 넣고 끓기 시작한 뒤 10분 정도 완숙으로 삶는다.","삶은 달걀을 찬물에 담가 식힌 뒤 껍질을 깐다.","작은 그릇에 다진 마늘 약간, 간장 1큰술, 설탕 반 작은술, 참기름 몇 방울, 물 반 컵을 섞어 조림장을 만든다. 후춧가루는 아이 입맛에 맞게 아주 조금만 넣거나 생략한다.","냄비에 달걀과 조림장을 넣고 약불에서 10분쯤, 달걀을 굴려 가며 색이 고르게 배도록 조린다.","한 김 식힌 뒤 4등분으로 잘라 아이가 먹기 좋게 담는다."],"steps_public":true,"nutri":{"kcal":127,"protein_g":10.3,"carb_g":6.2,"fat_g":6.3,"calcium_mg":37,"iron_mg":1.57,"sodium_mg":530,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀"]}