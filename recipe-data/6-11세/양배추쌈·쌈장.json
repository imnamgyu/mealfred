{"menu":"양배추쌈/쌈장","title":"찐 양배추쌈과 순한 쌈장 (초등 1인분)","band":"6-11세","dish_type":"etc","source":"ai_generated","cook_min":15,"wait_min":0,"yield_g":56.8,"ings":[{"n":"양배추","raw":"양배추, 생것","g":50,"disp":null,"ssn":false,"na":5},{"n":"된장","raw":"된장","g":3,"disp":"1/2작은술","ssn":true,"na":130},{"n":"고추장","raw":"고추장","g":1.5,"disp":"1/4작은술","ssn":true,"na":30},{"n":"물엿","raw":"물엿","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"참깨","raw":"참깨, 흰깨, 볶은것","g":0.3,"disp":"약간","ssn":true,"na":0}],"steps":["양배추는 잎을 한 장씩 떼어 흐르는 물에 씻고, 두꺼운 심 부분은 칼로 얇게 저며 고르게 익도록 한다.","김이 오른 찜기에 양배추 잎을 넣고 중불에서 5~6분, 잎이 투명하고 부드러워질 때까지 찐다.","찐 양배추는 한 김 식힌 뒤 아이 손바닥에 올리기 좋은 5×5cm 크기로 자른다.","작은 그릇에 된장, 고추장, 물엿, 다진 마늘, 참기름, 물 1작은술을 넣고 곱게 섞은 뒤 참깨를 뿌려 순한 쌈장을 만든다.","양배추 잎에 쌈장을 아주 조금만 올려 밥과 함께 싸 먹을 수 있도록 곁들여 낸다."],"steps_public":true,"nutri":{"kcal":32,"protein_g":null,"carb_g":null,"fat_g":null,"calcium_mg":null,"iron_mg":null,"sodium_mg":165,"na_flag":"ok"},"allergens":["대두","밀"]}