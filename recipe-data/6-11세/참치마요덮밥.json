{"menu":"참치마요덮밥","title":"참치마요덮밥","band":"6-11세","dish_type":"rice_main","source":"standard","cook_min":40,"wait_min":0,"yield_g":174.3,"ings":[{"n":"멥쌀","raw":"멥쌀, 백미, 생것","g":68,"disp":null,"ssn":false,"na":1},{"n":"가다랑어","raw":"가다랑어, 유지통조림","g":51,"disp":null,"ssn":false,"na":22},{"n":"달걀","raw":"달걀, 생것","g":17,"disp":null,"ssn":false,"na":23},{"n":"양파","raw":"양파, 생것","g":17,"disp":null,"ssn":false,"na":0},{"n":"마요네즈","raw":"마요네즈, 난황","g":8.5,"disp":"0.6큰술","ssn":true,"na":41},{"n":"들깻잎","raw":"들깻잎, 생것","g":5.1,"disp":null,"ssn":false,"na":0},{"n":"우스터소스","raw":"우스터 소스","g":5.1,"disp":null,"ssn":false,"na":101},{"n":"콩기름","raw":"콩기름","g":2.6,"disp":"1/2작은술","ssn":true,"na":0}],"steps":["쌀은 30분 불려 평소보다 물을 약간 넉넉히 잡아 부드럽게 밥을 짓는다.","캔참치는 체에 밭쳐 기름을 꼼꼼히 빼고, 양파와 깻잎은 가늘게 채 썬다.","달걀 1개를 풀어 기름 두른 팬에 붓고 약불에서 젓가락으로 저어 보슬보슬한 스크램블을 만들어 덜어 둔다.","같은 팬에 기름을 조금 더 두르고 중불에서 양파를 2분쯤 투명해질 때까지 볶다가 참치를 넣어 살짝 볶는다.","그릇에 밥을 담고 스크램블·참치양파볶음·깻잎채를 올린 뒤 데리야끼소스와 마요네즈를 아주 조금만 뿌리고, 한 김 식혀 골고루 비벼 준다."],"steps_public":true,"nutri":{"kcal":449,"protein_g":21.8,"carb_g":57.7,"fat_g":13,"calcium_mg":45,"iron_mg":5.46,"sodium_mg":189,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","토마토"]}