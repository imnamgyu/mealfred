{"menu":"멸치볶음","title":"멸치볶음","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":16.2,"ings":[{"n":"멸치","raw":"멸치, 잔멸치, 삶아서 말린것","g":11.3,"disp":null,"ssn":false,"na":298},{"n":"간장","raw":"간장, 개량, 양조","g":2.3,"disp":"1/2작은술","ssn":true,"na":108},{"n":"콩기름","raw":"콩기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"물엿","raw":"물엿","g":0.8,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["마른 팬을 중불에 올려 기름 없이 멸치를 1분쯤 저어가며 볶아 비린내를 날린 뒤, 식용유 반 큰술을 두르고 30초 더 볶아 접시에 덜어둔다.","작은 그릇에 다진 마늘 약간, 간장 반 큰술, 물엿 1큰술, 물 1큰술을 넣고 고루 섞어 양념을 만든다.","팬을 약불로 낮추고 양념을 부어 살짝 끓어오르면 멸치를 다시 넣어 1~2분간 고루 버무리며 볶는다.","불을 끄고 참기름 몇 방울을 둘러 섞은 뒤, 한 김 식혀 아이 그릇에 담는다. 큰 멸치라면 아이가 씹기 쉽게 잘게 부숴 준다."],"steps_public":true,"nutri":{"kcal":55,"protein_g":6.1,"carb_g":1.3,"fat_g":2.6,"calcium_mg":84,"iron_mg":0.16,"sodium_mg":405,"na_flag":"ok"},"allergens":["대두","밀"]}