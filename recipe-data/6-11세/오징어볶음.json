{"menu":"오징어볶음","title":"오징어볶음(경남)","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":92.5,"ings":[{"n":"오징어","raw":"오징어, 생것","g":50,"disp":null,"ssn":false,"na":100},{"n":"양파","raw":"양파, 생것","g":12.5,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근, 뿌리, 생것","g":6.3,"disp":null,"ssn":false,"na":2},{"n":"파","raw":"파, 생것","g":6.3,"disp":"0.4큰술","ssn":true,"na":1},{"n":"고추장","raw":"고추장, 개량","g":3.8,"disp":"1작은술","ssn":true,"na":93},{"n":"물엿","raw":"물엿","g":3.8,"disp":"1작은술","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":3.8,"disp":"1작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":2.5,"disp":"1/2작은술","ssn":true,"na":200},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":1.3,"disp":"1/4작은술","ssn":true,"na":0}],"steps":["손질한 오징어는 아이가 씹기 좋게 1~2cm 폭의 작은 조각으로 썰고, 양파와 당근은 얇게 채 썬다.","파는 어슷하게 썰고 마늘은 조금만 다진다.","작은 볼에 다진 마늘, 고추장 아주 조금(또는 아이용은 간장만), 간장 1작은술, 물엿 반 작은술을 섞어 양념을 만든다.","팬에 식용유를 두르고 중불에서 오징어와 양념을 넣어 2~3분 볶다가 양파·당근·파를 넣고 2분 더 볶는다.","참기름 몇 방울로 마무리하고, 한 김 식혀 부드러워졌을 때 담아낸다."],"steps_public":true,"nutri":{"kcal":125,"protein_g":10.1,"carb_g":7.9,"fat_g":5.7,"calcium_mg":13,"iron_mg":0.24,"sodium_mg":396,"na_flag":"ok"},"allergens":["대두","밀","오징어"]}