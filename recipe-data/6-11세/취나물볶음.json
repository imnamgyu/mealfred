{"menu":"취나물볶음","title":"취나물볶음","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":49.3,"ings":[{"n":"취나물","raw":"취나물_참취_생것","g":45.5,"disp":null,"ssn":false,"na":2},{"n":"파","raw":"파, 생것","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":0.7,"disp":"약간","ssn":true,"na":31},{"n":"콩기름","raw":"콩기름","g":0.7,"disp":"약간","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":47},{"n":"참기름","raw":"참기름","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["취나물은 끓는 물에 1분 정도 데친 뒤 찬물에 헹구고 두 손으로 꼭 짜서 물기를 뺀다.","질긴 줄기는 잘라 내고 아이가 씹기 쉽게 3cm 길이로 짧게 썰며, 파와 마늘은 곱게 다진다.","팬에 기름을 두르고 약불에서 다진 파·마늘을 30초 볶아 향을 낸다.","취나물을 넣고 중불에서 2~3분 볶은 뒤 소금과 간장을 아주 조금 넣어 심심하게 간한다.","불을 끄고 참기름 몇 방울로 마무리한 다음, 한 김 식혀 담는다."],"steps_public":true,"nutri":{"kcal":39,"protein_g":1.6,"carb_g":6.9,"fat_g":1.2,"calcium_mg":76,"iron_mg":3.39,"sodium_mg":81,"na_flag":"ok"},"allergens":["대두","밀"]}