{"menu":"동그랑땡","title":"(수제)동그랑땡(경남)","band":"6-11세","dish_type":"etc","source":"standard","cook_min":10,"wait_min":0,"yield_g":104,"ings":[{"n":"돼지고기","raw":"돼지고기, 등심, 생것","g":37.5,"disp":null,"ssn":false,"na":16},{"n":"두부","raw":"두부","g":25,"disp":null,"ssn":false,"na":0},{"n":"달걀","raw":"달걀, 생것","g":12.5,"disp":null,"ssn":false,"na":17},{"n":"양파","raw":"양파, 생것","g":12.5,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근, 뿌리, 생것","g":6.3,"disp":null,"ssn":false,"na":2},{"n":"밀","raw":"밀, 중력밀가루","g":6.3,"disp":null,"ssn":false,"na":0},{"n":"콩기름","raw":"콩기름","g":3.8,"disp":"1작은술","ssn":true,"na":0},{"n":"소금","raw":"소금, 정제염","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":90}],"steps":["다진 돼지고기는 키친타월로 눌러 핏물을 닦아낸다.","두부는 면포나 키친타월로 물기를 꼭 짜고 곱게 으깬다.","양파와 당근은 새끼손톱보다 작게 잘게 다진다.","볼에 고기, 두부, 양파, 당근을 모두 넣고 소금 한 꼬집으로 간해 끈기가 생기게 치대며 섞는다.","반죽을 아이 한입 크기(지름 3cm 정도)로 동글납작하게 빚어 밀가루, 풀어둔 달걀 순으로 옷을 입힌다.","팬에 기름을 두르고 약불에서 앞뒤로 3분씩, 속까지 익도록 노릇하게 구운 뒤 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":155,"protein_g":13.8,"carb_g":7.4,"fat_g":7.2,"calcium_mg":29,"iron_mg":0.81,"sodium_mg":125,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","돼지고기"]}