{"menu":"수제떡갈비","title":"소·돼지고기 반반 수제떡갈비","band":"6-11세","dish_type":"side_main","source":"ai_generated","cook_min":15,"wait_min":0,"yield_g":81.6,"ings":[{"n":"소고기","raw":"소고기, 우둔, 살코기, 생것","g":32,"disp":null,"ssn":false,"na":16},{"n":"돼지고기","raw":"돼지고기, 살코기, 생것","g":32,"disp":null,"ssn":false,"na":16},{"n":"양파","raw":"양파, 생것","g":8,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":2.5,"disp":"1/2작은술","ssn":true,"na":120},{"n":"설탕","raw":"설탕, 백설탕","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.5,"disp":"약간","ssn":true,"na":0},{"n":"콩기름","raw":"콩기름","g":2,"disp":"1/2작은술","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["소고기와 돼지고기는 곱게 다지고, 양파·파·마늘도 아주 잘게 다진다. 양파는 다진 뒤 손으로 꼭 짜 물기를 빼야 반죽이 질어지지 않는다.","볼에 다진 고기와 채소, 간장, 설탕, 후추, 참기름을 넣고 손으로 3분 이상 치대어 반죽에 찰기가 생기게 한다.","반죽을 두 덩이로 나눠 지름 5cm, 두께 1.5cm의 동글납작한 모양으로 빚고, 가운데를 엄지로 살짝 눌러 속까지 고르게 익도록 한다.","팬에 콩기름을 두르고 중불로 달군 뒤 떡갈비를 올려 한 면을 3분 굽고, 뒤집어서 약불로 줄여 뚜껑을 덮고 4분 더 굽는다.","가운데를 눌러 맑은 육즙이 나오면 다 익은 것이다. 한 김 식힌 뒤 아이 한입 크기(2cm 폭)로 잘라 담는다."],"steps_public":true,"nutri":{"kcal":187,"protein_g":null,"carb_g":null,"fat_g":null,"calcium_mg":null,"iron_mg":null,"sodium_mg":153,"na_flag":"ok"},"allergens":["소고기","돼지고기","대두","밀"]}