{"menu":"오징어브로콜리숙회","title":"브로콜리숙회(들깨소스)","band":"6-11세","dish_type":"etc","source":"standard","cook_min":10,"wait_min":0,"yield_g":50.7,"ings":[{"n":"브로콜리","raw":"브로콜리, 생것","g":43.8,"disp":null,"ssn":false,"na":2},{"n":"마요네즈","raw":"마요네즈, 난황","g":3.8,"disp":"1작은술","ssn":true,"na":18},{"n":"간장","raw":"간장, 개량, 양조","g":1.3,"disp":"1/4작은술","ssn":true,"na":60},{"n":"들깨","raw":"들깨, 말린것","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕, 백설탕","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"올리브유","raw":"올리브유","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"들기름","raw":"들기름","g":0.1,"disp":"약간","ssn":true,"na":0},{"n":"식초","raw":"식초, 사과식초","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["브로콜리는 아이 한입 크기(2cm 정도)의 작은 송이로 나눠 흐르는 물에 씻는다.","끓는 물에 브로콜리를 넣고 센불에서 2분 정도 부드럽게 데친 뒤 찬물에 헹궈 체에 밭쳐 물기를 뺀다.","믹서에 들깨 1큰술, 마요네즈 1큰술, 올리브유·간장·설탕·들기름·식초 조금씩과 물 1큰술을 넣고 곱게 갈아 고소한 들깨소스를 만든다.","접시에 브로콜리를 담고 소스를 살짝 끼얹거나, 찍어 먹을 수 있게 작은 종지에 곁들여 낸다."],"steps_public":true,"nutri":{"kcal":53,"protein_g":1.8,"carb_g":3.7,"fat_g":3.8,"calcium_mg":23,"iron_mg":0.45,"sodium_mg":80,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀"]}