{"menu":"짜장떡볶이","title":"짜장떡볶이","band":"6-11세","dish_type":"snack","source":"standard","cook_min":15,"wait_min":10,"yield_g":140.4,"ings":[{"n":"멥쌀떡","raw":"멥쌀떡, 가래떡","g":100,"disp":null,"ssn":false,"na":261},{"n":"양파","raw":"양파, 생것","g":14,"disp":null,"ssn":false,"na":0},{"n":"어묵","raw":"어묵, 튀긴것","g":12,"disp":null,"ssn":false,"na":84},{"n":"짜장소스","raw":"짜장 소스","g":10,"disp":null,"ssn":false,"na":525},{"n":"파","raw":"파, 생것","g":3,"disp":"1/2작은술","ssn":true,"na":1},{"n":"콩기름","raw":"콩기름","g":1,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.4,"disp":"약간","ssn":true,"na":0}],"steps":["떡볶이 떡은 미지근한 물에 10분쯤 담가 말랑하게 불리고, 아이가 씹기 쉽게 세로로 반 갈라 둔다.","어묵은 새끼손톱 크기로 잘게 썰고(꼬치가 있다면 반드시 뺀다), 양파와 파도 잘게 썰고 마늘은 다진다.","팬에 식용유를 두르고 중불에서 어묵·양파·파·마늘을 2~3분 볶는다.","짜장가루 1큰술과 물 1컵을 넣고 잘 풀어준 뒤, 불린 떡을 넣고 중불에서 4~5분 저어가며 소스가 걸쭉해질 때까지 익힌다.","한 김 식혀 떡이 뜨겁지 않은지 확인한 뒤 아이에게 준다."],"steps_public":true,"nutri":{"kcal":306,"protein_g":7.5,"carb_g":63.2,"fat_g":2.6,"calcium_mg":28,"iron_mg":0.55,"sodium_mg":871,"na_flag":"review"},"allergens":["대두","밀"]}