{"menu":"오이양파무침","title":"오이양파무침","band":"6-11세","dish_type":"side","source":"standard","cook_min":15,"wait_min":0,"yield_g":73.8,"ings":[{"n":"오이","raw":"오이, 다다기, 생것","g":52.5,"disp":null,"ssn":false,"na":2},{"n":"양파","raw":"양파, 생것","g":15,"disp":null,"ssn":false,"na":0},{"n":"간장","raw":"간장, 재래","g":3,"disp":"1/2작은술","ssn":true,"na":240},{"n":"파","raw":"파, 생것","g":2.3,"disp":"1/2작은술","ssn":true,"na":0},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"식초","raw":"식초, 사과식초","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"참깨","raw":"참깨, 흰깨, 볶은것","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["오이는 반달 모양으로 0.5cm 두께로 얇게 썰고, 양파는 아이가 씹기 쉽게 가늘게 채 썬다.","쪽파는 잘게 송송 썰고, 마늘은 곱게 다져 준비한다.","작은 볼에 썰어 둔 파와 다진 마늘을 넣고 간장 1작은술, 식초 반 작은술을 섞어 양념을 만든다. 매운맛에 약한 아이라면 고춧가루는 아주 조금만 넣거나 뺀다.","오이와 양파에 양념을 부어 조물조물 무친 뒤, 참깨를 손으로 비벼 살짝 뿌려 마무리한다."],"steps_public":true,"nutri":{"kcal":17,"protein_g":1,"carb_g":3.6,"fat_g":0.1,"calcium_mg":14,"iron_mg":0.18,"sodium_mg":242,"na_flag":"ok"},"allergens":["대두","밀"]}