{"menu":"소고기무국","title":"소고기뭇국(경남)","band":"6-11세","dish_type":"soup","source":"standard","cook_min":25,"wait_min":0,"yield_g":60.2,"ings":[{"n":"무","raw":"무, 조선무, 생것","g":30,"disp":null,"ssn":false,"na":4},{"n":"소고기","raw":"소고기_한우_양지_생것","g":22.5,"disp":null,"ssn":false,"na":12},{"n":"파","raw":"파, 생것","g":4.5,"disp":"1작은술","ssn":true,"na":1},{"n":"참기름","raw":"참기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.8,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.8,"disp":"1/4작은술","ssn":true,"na":270},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["국거리 소고기는 아이 한입 크기로 잘게 썰고, 무는 새끼손톱보다 조금 큰 얇은 네모(나박썰기)로 썬다.","파는 송송 썰고 마늘은 반 작은술만 다져 둔다.","냄비에 참기름을 조금 두르고 중불에서 소고기와 무를 3분쯤 볶아 고기 겉면을 익힌다.","물 3컵을 붓고 센불로 끓어오르면 중약불로 줄여 15분, 무가 투명해질 때까지 끓인다.","파와 마늘을 넣고 2분 더 끓인 뒤 소금으로 심심하게 간한다(후추는 생략 가능).","한 김 식혀 미지근할 때 아이 그릇에 담는다."],"steps_public":true,"nutri":{"kcal":79,"protein_g":4.5,"carb_g":1.9,"fat_g":5.7,"calcium_mg":11,"iron_mg":0.57,"sodium_mg":287,"na_flag":"ok"},"allergens":["쇠고기"]}