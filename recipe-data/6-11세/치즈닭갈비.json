{"menu":"치즈닭갈비","title":"치즈닭갈비","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":14,"yield_g":109.3,"ings":[{"n":"닭고기","raw":"닭고기_살코기_생것","g":50,"disp":null,"ssn":false,"na":29},{"n":"고구마","raw":"고구마_신자미_생것","g":10,"disp":null,"ssn":false,"na":1},{"n":"양배추","raw":"양배추_생것","g":10,"disp":null,"ssn":false,"na":1},{"n":"양파","raw":"양파_생것","g":10,"disp":null,"ssn":false,"na":0},{"n":"당근","raw":"당근_뿌리_생것","g":6.3,"disp":null,"ssn":false,"na":2},{"n":"치즈","raw":"치즈, 모차렐라","g":6.3,"disp":null,"ssn":false,"na":15},{"n":"콩기름","raw":"콩기름","g":3.8,"disp":"1작은술","ssn":true,"na":0},{"n":"들깻잎","raw":"들깻잎, 생것","g":2.5,"disp":null,"ssn":false,"na":0},{"n":"물엿","raw":"물엿","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"파","raw":"파, 생것","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":1.5,"disp":"1/4작은술","ssn":true,"na":0},{"n":"고추장","raw":"고추장, 재래","g":1.3,"disp":"1/4작은술","ssn":true,"na":38},{"n":"간장","raw":"간장_재래","g":0.5,"disp":"약간","ssn":true,"na":40},{"n":"참깨","raw":"참깨_흰깨_볶은것","g":0.4,"disp":"약간","ssn":true,"na":0}],"steps":["닭다리살은 아이 한입 크기(새끼손톱 두 배 정도)로 잘라 끓는 물에 1~2분 데쳐 기름기를 뺀다.","양파·당근·고구마·양배추는 얇고 작게, 당근과 고구마는 0.5cm 두께로 썰어 잘 익게 준비한다.","고추장 대신 간장 1큰술·물엿 반 큰술·물 2큰술·다진 마늘 약간·참기름을 섞은 순한 양념장에 닭고기를 10분 재운다(큰 아이는 고추장을 조금 섞어도 좋다).","팬에 기름을 두르고 중불에서 재운 닭을 3~4분 볶다가, 반쯤 익으면 채소를 넣어 함께 볶는다.","남은 양념과 잘게 찢은 깻잎을 넣고 채소가 부드러워질 때까지 3~4분 더 볶는다.","피자치즈를 뿌리고 뚜껑을 덮어 약불에서 치즈가 녹으면 불을 끄고, 한 김 식혀 아이에게 준다."],"steps_public":true,"nutri":{"kcal":156,"protein_g":14,"carb_g":8.2,"fat_g":7.2,"calcium_mg":52,"iron_mg":0.89,"sodium_mg":126,"na_flag":"ok"},"allergens":["우유","대두","밀","닭고기"]}