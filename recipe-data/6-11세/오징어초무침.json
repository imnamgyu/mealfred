{"menu":"오징어초무침","title":"오징어초무침","band":"6-11세","dish_type":"side","source":"standard","cook_min":10,"wait_min":0,"yield_g":98.1,"ings":[{"n":"오징어","raw":"오징어, 생것","g":50,"disp":null,"ssn":false,"na":100},{"n":"배","raw":"배, 만풍, 생것","g":18.8,"disp":null,"ssn":false,"na":0},{"n":"오이","raw":"오이, 다다기, 생것","g":18.8,"disp":null,"ssn":false,"na":1},{"n":"당근","raw":"당근, 뿌리, 생것","g":6.3,"disp":null,"ssn":false,"na":2},{"n":"파","raw":"파, 생것","g":1.9,"disp":"1/2작은술","ssn":true,"na":0},{"n":"고춧가루","raw":"고춧가루, 가루","g":1.3,"disp":"1/4작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 재래","g":0.6,"disp":"약간","ssn":true,"na":50},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"식초","raw":"식초, 사과식초","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"설탕","raw":"설탕, 백설탕","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["손질된 오징어를 팔팔 끓는 물에 2~3분간 데쳐 익히고, 체에 받쳐 식힌 뒤 아이가 씹기 쉽게 새끼손톱 크기로 잘게 자른다.","오이·당근·배는 3cm 길이의 가는 채로 썰어 두고, 파는 잘게 다지고 마늘도 곱게 다진다.","작은 볼에 간장 1작은술, 식초·설탕 각 1작은술, 고춧가루 아주 조금(아이용은 생략 가능), 다진 파·마늘을 넣고 고루 저어 새콤한 양념장을 완성한다.","큰 그릇에 데친 오징어와 채 썬 채소를 모아 담고 양념장을 끼얹어 조물조물 무친 다음, 통깨를 살짝 뿌려 낸다."],"steps_public":true,"nutri":{"kcal":66,"protein_g":9.9,"carb_g":4.5,"fat_g":0.8,"calcium_mg":12,"iron_mg":0.21,"sodium_mg":152,"na_flag":"ok"},"allergens":["대두","밀","오징어"]}