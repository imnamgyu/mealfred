{"menu":"오이도라지무침","title":"도라지무침","band":"6-11세","dish_type":"side","source":"standard","cook_min":15,"wait_min":0,"yield_g":48.5,"ings":[{"n":"도라지","raw":"도라지, 뿌리, 생것","g":43.8,"disp":null,"ssn":false,"na":1},{"n":"고추장","raw":"고추장, 개량","g":1.3,"disp":"1/4작은술","ssn":true,"na":31},{"n":"설탕","raw":"설탕, 가루","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"식초","raw":"식초, 사과식초","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"파","raw":"파, 실파, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"물엿","raw":"물엿","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"깨소금","raw":"깨소금, 가루, 볶은것","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.1,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":43}],"steps":["손질된 도라지를 0.5cm 두께로 가늘게 채 썬 뒤, 소금 한 큰술을 뿌려 손으로 조물조물 문지르고 물에 헹궈 쓴맛을 빼준다.","실파는 새끼손톱 크기(0.5cm 길이)로 잘게 송송 썬다.","작은 그릇에 다진 마늘 약간, 고추장 반 작은술, 식초·올리고당·설탕 조금씩, 깨소금과 참기름을 섞어 순한 양념장을 만든다. 아이용이니 고추장은 아주 조금만 넣는다.","물기를 꼭 짠 도라지에 양념장을 넣어 골고루 무친 다음, 마지막에 실파를 넣고 가볍게 한 번 더 섞어 담아낸다."],"steps_public":true,"nutri":{"kcal":38,"protein_g":0.8,"carb_g":7.5,"fat_g":0.8,"calcium_mg":20,"iron_mg":0.19,"sodium_mg":76,"na_flag":"ok"},"allergens":["대두","밀"]}