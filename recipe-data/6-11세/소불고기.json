{"menu":"소불고기","title":"소불고기(경남)","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":13,"yield_g":115.4,"ings":[{"n":"소고기","raw":"소고기_한우(1등급)_목심(목심살)_생것","g":72,"disp":null,"ssn":false,"na":48},{"n":"당근","raw":"당근_뿌리_생것","g":9,"disp":null,"ssn":false,"na":2},{"n":"양파","raw":"양파_생것","g":9,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":9,"disp":"0.6큰술","ssn":true,"na":2},{"n":"간장","raw":"간장, 개량, 양조","g":5.4,"disp":"1작은술","ssn":true,"na":258},{"n":"콩기름","raw":"콩기름","g":4.5,"disp":"1작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":3.6,"disp":"1작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.8,"disp":"1/2작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.9,"disp":"1/4작은술","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["불고기용 쇠고기는 아이 한입 크기(3cm 정도)로 자르고, 양파와 당근은 0.5cm 두께로 얇게 채 썬다.","파는 송송 썰고 마늘은 곱게 다져 준비한다.","볼에 쇠고기를 넣고 다진 마늘, 간장 1작은술, 설탕 약간, 참기름, 후춧가루 한 꼬집을 넣어 조물조물 무친 뒤 10분쯤 재워둔다.","팬에 식용유를 살짝 두르고 중불에서 재운 고기를 3분 정도 볶는다.","고기가 거의 익으면 당근·양파·파를 넣고 채소가 부드러워질 때까지 2~3분 더 볶은 뒤, 한 김 식혀 담아준다."],"steps_public":true,"nutri":{"kcal":268,"protein_g":18.3,"carb_g":4.7,"fat_g":18.6,"calcium_mg":18,"iron_mg":2.46,"sodium_mg":311,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}