{"menu":"돈까스","title":"돈까스","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":10,"yield_g":121.1,"ings":[{"n":"돼지고기","raw":"돼지고기_등심_생것","g":54,"disp":null,"ssn":false,"na":23},{"n":"달걀","raw":"달걀, 생것","g":21.6,"disp":null,"ssn":false,"na":30},{"n":"콩기름","raw":"콩기름","g":18,"disp":null,"ssn":true,"na":0},{"n":"밀","raw":"밀, 중력밀가루","g":12.6,"disp":null,"ssn":false,"na":0},{"n":"돈까스소스","raw":"돈까스 소스","g":9,"disp":null,"ssn":false,"na":null},{"n":"밀","raw":"밀, 빵가루","g":5.4,"disp":null,"ssn":false,"na":17},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":130},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["돼지고기 등심 1장을 손바닥 크기로 준비해 칼등으로 두드리고 힘줄에 칼집을 몇 군데 넣은 뒤, 소금·후추를 아주 살짝 뿌려 10분 재운다.","넓은 그릇 셋에 밀가루, 잘 푼 달걀, 빵가루를 각각 담아 튀김옷 준비를 한다.","고기에 밀가루→달걀물→빵가루 순서로 꾹꾹 눌러가며 골고루 입힌다.","팬에 기름을 1.5cm 깊이로 붓고 중불로 달군 뒤(빵가루가 바로 떠오르면 적당), 고기를 넣어 앞뒤 3분씩 노릇하게 튀기고 키친타월에 올려 기름을 뺀다.","한 김 식으면 아이가 씹기 좋게 1.5cm 폭으로 썰고, 돈까스소스를 조금 곁들여 낸다."],"steps_public":true,"nutri":{"kcal":352,"protein_g":17.4,"carb_g":17.2,"fat_g":22.4,"calcium_mg":18,"iron_mg":0.81,"sodium_mg":199,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","돼지고기","토마토","쇠고기"]}