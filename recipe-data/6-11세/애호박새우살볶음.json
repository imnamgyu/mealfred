{"menu":"애호박새우살볶음","title":"새우살볶음","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":10,"wait_min":0,"yield_g":93.2,"ings":[{"n":"새우","raw":"새우, 시바새우, 생것","g":72,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":9,"disp":"0.6큰술","ssn":true,"na":2},{"n":"간장","raw":"간장, 개량, 양조","g":5.4,"disp":"1작은술","ssn":true,"na":258},{"n":"콩기름","raw":"콩기름","g":4.5,"disp":"1작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":1.8,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["새우살은 씻어 물기를 키친타월로 눌러 빼고, 큰 것은 아이가 씹기 좋게 새끼손톱 크기로 자른다.","대파는 잘게 썰고 마늘은 곱게 다져 둔다.","팬에 식용유를 한 큰술 두르고 중불에서 파와 마늘을 30초쯤 볶아 향을 낸다.","새우를 넣고 중불에서 속까지 완전히 익도록 2~3분 볶는다.","간장을 반 작은술 넣어 심심하게 간하고 참기름 몇 방울로 마무리한 뒤(후춧가루는 생략 가능), 한 김 식혀 담아낸다."],"steps_public":true,"nutri":{"kcal":157,"protein_g":19.5,"carb_g":2.8,"fat_g":7,"calcium_mg":77,"iron_mg":2.67,"sodium_mg":260,"na_flag":"ok"},"allergens":["대두","밀","새우"]}