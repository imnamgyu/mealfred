{"menu":"탕수육","title":"탕수육","band":"6-11세","dish_type":"side_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":132.3,"ings":[{"n":"돼지고기","raw":"돼지고기_등심_생것","g":54,"disp":null,"ssn":false,"na":23},{"n":"콩기름","raw":"콩기름","g":18,"disp":null,"ssn":true,"na":0},{"n":"달걀","raw":"달걀, 생것","g":9,"disp":null,"ssn":false,"na":12},{"n":"당근","raw":"당근_뿌리_생것","g":9,"disp":null,"ssn":false,"na":2},{"n":"밀","raw":"밀, 튀김가루","g":9,"disp":null,"ssn":false,"na":79},{"n":"양파","raw":"양파_생것","g":9,"disp":null,"ssn":false,"na":0},{"n":"오이","raw":"오이, 다다기, 생것","g":9,"disp":null,"ssn":false,"na":0},{"n":"간장","raw":"간장, 개량, 양조","g":5.4,"disp":"1작은술","ssn":true,"na":258},{"n":"전분","raw":"전분, 감자, 가루","g":5.4,"disp":"1작은술","ssn":true,"na":1},{"n":"식초","raw":"식초, 사과식초","g":3.6,"disp":"1작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.4,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.4,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":130},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["돼지고기는 아이가 씹기 좋게 새끼손톱 두 개 크기로 썰고, 당근·양파·오이도 0.5cm 두께로 얇게 썬다.","볼에 튀김가루 3큰술, 달걀 1개, 후춧가루 약간, 물 2큰술을 섞어 튀김옷을 만들고 고기에 골고루 입힌다.","작은 냄비에 식용유를 넉넉히 붓고 중불로 170도쯤(반죽을 떨어뜨리면 바로 떠오르는 정도) 데운 뒤 고기를 3~4분 노릇하게 튀겨 키친타월에 기름을 뺀다.","작은 그릇에 간장 1작은술, 설탕 1큰술, 소금 약간, 식초 1큰술, 물 반 컵을 섞어 소스 베이스를 만든다.","팬에 기름을 살짝 두르고 중불에서 당근·양파·오이를 2분 볶다가 소스 베이스를 부어 끓이고, 감자전분과 물을 1:1로 갠 전분물을 조금씩 넣어 걸쭉하게 만든다.","튀긴 고기에 소스를 끼얹고 한 김 식혀 아이 접시에 낸다."],"steps_public":true,"nutri":{"kcal":355,"protein_g":16.9,"carb_g":16.3,"fat_g":23.5,"calcium_mg":23,"iron_mg":0.74,"sodium_mg":506,"na_flag":"ok"},"allergens":["난류(계란)","대두","밀","돼지고기"]}