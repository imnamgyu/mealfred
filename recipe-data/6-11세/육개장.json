{"menu":"육개장","title":"육개장","band":"6-11세","dish_type":"etc","source":"standard","cook_min":45,"wait_min":0,"yield_g":77.9,"ings":[{"n":"소고기","raw":"소고기_한우_양지_생것","g":38.4,"disp":null,"ssn":false,"na":21},{"n":"고사리","raw":"고사리, 데친것","g":8,"disp":null,"ssn":false,"na":0},{"n":"무","raw":"무, 조선무, 생것","g":8,"disp":null,"ssn":false,"na":1},{"n":"숙주나물","raw":"숙주나물_생것","g":8,"disp":null,"ssn":false,"na":0},{"n":"토란대","raw":"토란대_줄기_생것","g":8,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":4.8,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장_재래","g":0.8,"disp":"1/4작은술","ssn":true,"na":64},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.8,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.6,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":231},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물 4컵과 쇠고기를 넣고 중불에서 20~30분 끓여 육수를 내고, 익은 고기는 건져 아이가 씹기 좋게 잘게 결대로 찢는다.","숙주·고사리·토란대는 끓는 물에 살짝 데쳐 물기를 짜고 2~3cm 길이로 짧게 썬다.","무는 얇게 나박 썰고 파는 송송, 마늘은 다져 준비한다.","육수에 무를 넣고 5분 끓인 뒤 찢은 고기, 고사리, 토란대, 숙주, 파 순서로 넣고 다시 한소끔 끓인다.","다진 마늘과 고춧가루(아이용은 아주 조금만, 매우면 생략)를 넣고 소금·간장으로 연하게 간해 5분 더 끓인 뒤 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":107,"protein_g":7.8,"carb_g":2,"fat_g":7.2,"calcium_mg":14,"iron_mg":0.93,"sodium_mg":318,"na_flag":"ok"},"allergens":["대두","밀","쇠고기"]}