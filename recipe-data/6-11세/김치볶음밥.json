{"menu":"김치볶음밥","title":"참치김치볶음밥","band":"6-11세","dish_type":"rice_main","source":"standard","cook_min":15,"wait_min":0,"yield_g":146.7,"ings":[{"n":"멥쌀","raw":"멥쌀, 백미, 생것","g":60,"disp":null,"ssn":false,"na":1},{"n":"가다랑어","raw":"가다랑어, 유지통조림","g":37.5,"disp":null,"ssn":false,"na":17},{"n":"김치","raw":"김치, 배추 김치","g":30,"disp":null,"ssn":false,"na":165},{"n":"양파","raw":"양파, 생것","g":7.5,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":7.5,"disp":"0.5큰술","ssn":true,"na":1},{"n":"콩기름","raw":"콩기름","g":3.8,"disp":"1작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.2,"disp":"약간","ssn":true,"na":0}],"steps":["밥은 미리 지어 두거나, 남은 밥이라면 아이 밥공기 1개 분량을 준비한다.","통조림 참치는 체에 올려 숟가락으로 살짝 눌러 기름을 충분히 빼 둔다.","배추김치는 양념을 털어내고 물기를 꼭 짠 뒤 아이가 씹기 쉽게 새끼손톱 크기로 잘게 썰고, 양파와 파도 곱게 다진다.","팬에 식용유를 두르고 중불에서 김치를 2분 정도 볶다가 양파·파·참치를 넣고 1~2분 더 볶는다.","밥을 넣고 중불에서 3분 정도 골고루 섞어가며 볶은 뒤 참기름 한두 방울로 마무리하고, 접시에 담아 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":352,"protein_g":16.3,"carb_g":53.6,"fat_g":6.5,"calcium_mg":37,"iron_mg":4.42,"sodium_mg":185,"na_flag":"ok"},"allergens":["대두","새우"]}