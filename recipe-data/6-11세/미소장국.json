{"menu":"미소장국","title":"미소장국","band":"6-11세","dish_type":"soup","source":"standard","cook_min":25,"wait_min":0,"yield_g":33.7,"ings":[{"n":"두부","raw":"두부","g":18.8,"disp":null,"ssn":false,"na":0},{"n":"된장","raw":"된장, 일식(미소)","g":6.3,"disp":"0.4큰술","ssn":true,"na":271},{"n":"멸치","raw":"멸치, 대멸치, 삶아서 말린것","g":2.5,"disp":null,"ssn":false,"na":55},{"n":"파","raw":"파, 생것","g":2.5,"disp":"1/2작은술","ssn":true,"na":0},{"n":"참다랑어","raw":"참다랑어, 마른것","g":1.9,"disp":null,"ssn":false,"na":8},{"n":"다시마","raw":"다시마, 생것","g":1.3,"disp":null,"ssn":false,"na":1},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물 3컵과 국물용 멸치, 다시마 한 조각을 넣고 중불로 15분 끓인 뒤 건더기를 건지고, 가쓰오부시를 넣어 30초만 우렸다가 바로 건져낸다.","두부는 아이 한입 크기(1cm 깍둑)로 썰고, 대파는 송송 썰고, 마늘은 조금 다진다.","육수에 두부·대파·마늘을 넣고 중불로 2~3분 끓인다.","미소된장 1큰술을 국물에 풀고 약불에서 1분만 살짝 끓인 뒤 바로 불을 끈다(오래 끓이면 떫은맛이 나니 주의한다).","한 김 식혀 두부가 뜨겁지 않은지 확인하고 아이에게 낸다."],"steps_public":true,"nutri":{"kcal":45,"protein_g":5.5,"carb_g":2.5,"fat_g":1.4,"calcium_mg":74,"iron_mg":1.04,"sodium_mg":335,"na_flag":"ok"},"allergens":["대두","밀"]}