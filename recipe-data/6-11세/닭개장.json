{"menu":"닭개장","title":"닭개장","band":"6-11세","dish_type":"etc","source":"standard","cook_min":30,"wait_min":0,"yield_g":60.9,"ings":[{"n":"닭고기","raw":"닭고기_가슴(껍질 제거)_생것","g":30,"disp":null,"ssn":false,"na":14},{"n":"고사리","raw":"고사리, 데친것","g":6.3,"disp":null,"ssn":false,"na":0},{"n":"무","raw":"무, 조선무, 생것","g":6.3,"disp":null,"ssn":false,"na":1},{"n":"숙주나물","raw":"숙주나물_생것","g":6.3,"disp":null,"ssn":false,"na":0},{"n":"토란대","raw":"토란대_줄기_데친것","g":6.3,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":3.8,"disp":"1작은술","ssn":true,"na":1},{"n":"간장","raw":"간장_재래","g":0.6,"disp":"약간","ssn":true,"na":50},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.6,"disp":"약간","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.5,"disp":"두 꼬집(≈0.5g)","ssn":true,"na":180},{"n":"고춧가루","raw":"고춧가루, 가루","g":0.3,"disp":"약간","ssn":true,"na":0},{"n":"후추","raw":"후추, 검은후추, 가루","g":0.1,"disp":"약간","ssn":true,"na":0}],"steps":["냄비에 물 3컵과 닭가슴살 1덩이를 넣고 중불에서 15분간 삶아 육수를 내고, 익은 닭은 건져 한 김 식힌 뒤 아이 손가락 굵기보다 가늘게 잘게 찢는다.","숙주·고사리·토란대는 끓는 물에 1~2분 데쳐 물기를 짜고, 질기지 않게 2cm 길이로 짧게 썬다.","무는 0.5cm 두께로 얇게 나박썰고 파는 송송 썰고 마늘은 곱게 다진다.","닭 육수에 무를 먼저 넣어 중불에서 5분 끓인 뒤, 찢은 닭살·고사리·토란대·숙주·파를 차례로 넣고 한소끔 더 끓인다.","다진 마늘을 넣고(고춧가루는 아이용이라면 빼거나 아주 조금만) 소금과 간장으로 연하게 간한 다음, 한 김 식혀 낸다."],"steps_public":true,"nutri":{"kcal":40,"protein_g":7.4,"carb_g":1.6,"fat_g":0.4,"calcium_mg":12,"iron_mg":0.21,"sodium_mg":245,"na_flag":"ok"},"allergens":["대두","밀","닭고기"]}