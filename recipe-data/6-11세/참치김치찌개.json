{"menu":"참치김치찌개","title":"참치김치찌개","band":"6-11세","dish_type":"soup","source":"standard","cook_min":20,"wait_min":0,"yield_g":84.3,"ings":[{"n":"가다랑어","raw":"가다랑어, 유지통조림","g":48,"disp":null,"ssn":false,"na":21},{"n":"김치","raw":"김치, 배추 김치","g":16,"disp":null,"ssn":false,"na":88},{"n":"양파","raw":"양파_생것","g":11.2,"disp":null,"ssn":false,"na":0},{"n":"파","raw":"파, 생것","g":4.8,"disp":"1작은술","ssn":true,"na":1},{"n":"참기름","raw":"참기름","g":2.4,"disp":"1/2작은술","ssn":true,"na":0},{"n":"간장","raw":"간장, 개량, 산분해","g":0.8,"disp":"1/4작은술","ssn":true,"na":44},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.8,"disp":"1/4작은술","ssn":true,"na":0},{"n":"소금","raw":"소금","g":0.3,"disp":"한 꼬집(≈0.3g)","ssn":true,"na":115}],"steps":["통조림 참치는 체에 올려 기름을 빼고, 배추김치는 양념을 살짝 털어 물에 한 번 헹군 뒤 새끼손톱 크기로 잘게 썬다. 양파도 잘게 썬다.","파는 송송 썰고 마늘은 조금만 다져 준비한다.","냄비에 참기름을 살짝 두르고 중불에서 김치·마늘·양파를 2~3분 볶다가 물 2컵을 붓고 끓인다.","국물이 끓어오르면 참치와 파를 넣고 약불에서 10분 정도 더 끓여 김치가 푹 무르게 한다.","간을 보고 싱거우면 간장을 아주 조금만 더한 뒤, 그릇에 담아 한 김 식혀 아이에게 낸다."],"steps_public":true,"nutri":{"kcal":143,"protein_g":18.1,"carb_g":3.1,"fat_g":6,"calcium_mg":28,"iron_mg":5.06,"sodium_mg":270,"na_flag":"ok"},"allergens":["대두","밀","새우"]}