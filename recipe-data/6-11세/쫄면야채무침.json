{"menu":"쫄면야채무침","title":"(지역아동)쫄면야채무침","band":"6-11세","dish_type":"side","source":"standard","cook_min":10,"wait_min":0,"yield_g":117.6,"ings":[{"n":"국수","raw":"국수_쫄면_말린것","g":48,"disp":null,"ssn":false,"na":614},{"n":"양배추","raw":"양배추_생것","g":32,"disp":null,"ssn":false,"na":3},{"n":"오이","raw":"오이_개량종_생것","g":16,"disp":null,"ssn":false,"na":0},{"n":"고추장","raw":"고추장, 개량","g":8,"disp":"0.5큰술","ssn":true,"na":199},{"n":"당근","raw":"당근_뿌리_생것","g":8,"disp":null,"ssn":false,"na":2},{"n":"식초","raw":"식초, 사과식초","g":3.2,"disp":"1작은술","ssn":true,"na":0},{"n":"마늘","raw":"마늘, 깐마늘, 생것","g":0.8,"disp":"1/4작은술","ssn":true,"na":0},{"n":"설탕","raw":"설탕_백설탕","g":0.8,"disp":"1/4작은술","ssn":true,"na":0},{"n":"참기름","raw":"참기름","g":0.8,"disp":"1/4작은술","ssn":true,"na":0}],"steps":["끓는 물에 쫄면을 4~5분 삶아 건진 뒤 찬물에 헹궈 물기를 뺀다. 먹기 좋게 가위로 5cm 길이로 몇 번 잘라 준다.","오이·당근·양배추는 3cm 길이로 얇게 채 썰고, 마늘 반 쪽은 곱게 다진다.","그릇에 다진 마늘, 고추장 반 작은술(맵기는 아이에 맞춰 조절), 식초 1작은술, 설탕 1작은술, 참기름 반 작은술을 섞어 양념을 만든다.","큰 볼에 쫄면과 채소를 담고 양념을 넣어 손이나 젓가락으로 골고루 버무린다.","접시에 담아 바로 내어 준다."],"steps_public":true,"nutri":{"kcal":210,"protein_g":5.5,"carb_g":43,"fat_g":1.5,"calcium_mg":31,"iron_mg":0.51,"sodium_mg":818,"na_flag":"review"},"allergens":["대두","밀"]}