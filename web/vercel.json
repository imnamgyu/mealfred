{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/community-rewards",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/coach",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/coach-selfcheck",
      "schedule": "30 18 * * *"
    }
  ]
}
