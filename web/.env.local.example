# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 밀프레드 Next.js (deploy/web) — 환경변수 완전 템플릿
# 이 파일을 .env.local 로 복사해 실제 값 입력. .env.local 은 git에 절대 commit 안 됨(.gitignore).
# 배포본(Vercel mealfred-app)에도 동일하게 등록해야 작동.
#
# 🔒 보안 규칙: 'NEXT_PUBLIC_' 접두사 = 브라우저 번들에 공개됨.
#   → URL·publishable(anon)·JS SDK 키만 허용. SERVICE_ROLE·*_SECRET·ANTHROPIC 등 비밀은 절대 NEXT_PUBLIC 금지!
#   점검: cd web && node scripts/rls-audit.mjs  (anon 슬롯에 secret 키 들어가면 경고)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── [필수] Supabase ── 프로젝트 spopsngwvpxvbokoefem · Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://spopsngwvpxvbokoefem.supabase.co
SUPABASE_URL=https://spopsngwvpxvbokoefem.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxx   # publishable(공개 OK)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxx       # 🔒 service · 서버 전용

# ── [필수] Anthropic Claude (OCR 분해·코칭 편지·질문) ── console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxx                 # 🔒

# ── [필수] CLOVA OCR (식단표 사진 → 글자) ── NCP 콘솔 → CLOVA OCR → APIGW Invoke URL + Secret
CLOVA_OCR_URL=https://xxxxx.apigw.ntruss.com/custom/v1/00000/xxxxx/general
CLOVA_OCR_SECRET=xxxxxxxxxxxxxxxxxx                               # 🔒

# ── [필수] 카카오 로그인 ── developers.kakao.com → 앱 키 / 보안
KAKAO_REST_API_KEY=xxxxxxxxxxxxxxxx                               # 🔒 서버 OAuth(토큰 교환)
KAKAO_CLIENT_SECRET=xxxxxxxxxxxxxxxx                              # 🔒 (사용 시)
NEXT_PUBLIC_KAKAO_REST_KEY=xxxxxxxxxxxxxxxx                       # JS SDK 초기화용(준공개)

# ── [권장] 크론 보호 ── 설정 시 Vercel Cron이 자동으로 Bearer 헤더로 호출(외부 무단호출 차단)
CRON_SECRET=아무-긴-랜덤-문자열로-바꾸세요

# ── [선택] 어드민 ── 평소엔 @mealfred.com 도메인 로그인으로 게이트. 아래는 break-glass/정적기능용
# ADMIN_UIDS=uid1,uid2          # 도메인 로그인 막힐 때 비상 어드민(콤마 구분)
# ADMIN_PASSWORD=xxxx           # 정적 api/admin/issue-coupon(쿠폰 발급) 쓸 때만

# ── [선택·알림톡 켤 때] 네이버 SENS 알림톡 ── 코칭편지 2줄·가입환영 활성화 시 (+템플릿 심사 4~7일)
# NCP_ACCESS_KEY=xxxx           # 🔒
# NCP_SECRET_KEY=xxxx           # 🔒
# NCP_SENS_PROJECT_ID=xxxx
# NCP_KAKAO_PF_ID=xxxx          # 카카오 비즈채널 ID
# NCP_ALIMTALK_TEMPLATE_CODE=xxxx   # 정적 api/_lib/ncloud-alimtalk 용
# NCP_UPGRADE_TEMPLATE_CODE=xxxx

# ── [로컬 전용·Vercel에 넣지 말 것] 도감 아이콘 생성 스크립트(gen-icons.mjs) ──
# OPENAI_API_KEY=sk-xxxx        # gpt-image-1 아이콘 생성(로컬 1회성). Vercel 불필요
# ICON_MODEL=gpt-image-1  ICON_SIZE=  ICON_QUALITY=  ICON_LIMIT=  ICON_DRYRUN=1
