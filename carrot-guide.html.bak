              </div>
              <div style="display:flex;gap:10px;align-items:flex-start;">
                <div style="min-width:36px;height:36px;border-radius:50%;background:#2D8B4E;color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;">선생님</div>
                <div style="background:#e8f5ec;border-radius:0 14px 14px 14px;padding:10px 14px;font-size:13px;line-height:1.7;max-width:85%;">
