<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🥕 당근 코스 — 5주 21회 상세 가이드 | 밀프레드</title>
<meta name="description" content="밀프레드 당근 코스 5주 21회 상세 커리큘럼. 어린이집·유치원 기관용 편식개선 프로그램 가이드.">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ===== RESET & BASE ===== */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Noto Sans KR', -apple-system, BlinkMacSystemFont, sans-serif;
  background: #FFF8E1;
  color: #333;
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ===== LAYOUT ===== */
.container {
  max-width: 640px;
  margin: 0 auto;
  padding: 0 16px 80px;
}

/* ===== HEADER ===== */
.header {
  background: linear-gradient(135deg, #F57C00 0%, #FF9800 40%, #FFB74D 100%);
  padding: 48px 24px 40px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.header::before {
  content: '';
  position: absolute;
  top: -60%;
  left: -20%;
  width: 140%;
  height: 200%;
  background: radial-gradient(circle at 30% 80%, rgba(255,255,255,0.15) 0%, transparent 50%),
              radial-gradient(circle at 80% 20%, rgba(255,255,255,0.1) 0%, transparent 40%);
  pointer-events: none;
}
.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6px;
  background: linear-gradient(90deg, #E65100, #F57C00, #FFB74D, #F57C00, #E65100);
}
.header-inner {
  position: relative;
  z-index: 1;
  max-width: 640px;
  margin: 0 auto;
}
.header-emoji {
  font-size: 64px;
  display: block;
  margin-bottom: 16px;
  filter: drop-shadow(0 4px 8px rgba(0,0,0,0.15));
}
.header h1 {
  font-size: 28px;
  font-weight: 900;
  color: #fff;
  letter-spacing: -0.5px;
  margin-bottom: 8px;
  text-shadow: 0 2px 8px rgba(0,0,0,0.15);
}
.header-sub {
  font-size: 14px;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
  margin-bottom: 24px;
}
.header-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 30px;
  padding: 6px 18px;
  font-size: 12px;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.5px;
}
.btn-pdf {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 20px;
  padding: 12px 28px;
  background: #fff;
  color: #E65100;
  border: none;
  border-radius: 30px;
  font-size: 14px;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  transition: all 0.2s;
}
.btn-pdf:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(0,0,0,0.2);
}
.btn-pdf:active { transform: translateY(0); }

/* ===== OVERVIEW CARD ===== */
.overview-card {
  background: #fff;
  border-radius: 20px;
  padding: 28px 24px;
  margin-top: -20px;
  position: relative;
  z-index: 2;
  box-shadow: 0 4px 24px rgba(230,81,0,0.08);
  border: 1px solid rgba(245,124,0,0.1);
}
.overview-title {
  font-size: 16px;
  font-weight: 800;
  color: #E65100;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
.overview-item {
  background: #FFF8E1;
  border-radius: 12px;
  padding: 14px 16px;
  text-align: center;
}
.overview-item .num {
  font-size: 24px;
  font-weight: 900;
  color: #F57C00;
  display: block;
  line-height: 1.2;
}
.overview-item .label {
  font-size: 11px;
  color: #888;
  font-weight: 500;
  margin-top: 2px;
}

/* ===== WEEK TOC ===== */
.toc {
  background: #fff;
  border-radius: 20px;
  padding: 24px;
  margin-top: 16px;
  box-shadow: 0 2px 16px rgba(230,81,0,0.06);
  border: 1px solid rgba(245,124,0,0.08);
}
.toc-title {
  font-size: 14px;
  font-weight: 800;
  color: #333;
  margin-bottom: 14px;
}
.toc-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.toc-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  background: #FFF8E1;
  border-radius: 12px;
  text-decoration: none;
  color: #333;
  font-size: 13px;
  font-weight: 600;
  transition: all 0.2s;
}
.toc-item:hover {
  background: #FFE0B2;
  transform: translateX(4px);
}
.toc-num {
  width: 28px;
  height: 28px;
  background: linear-gradient(135deg, #F57C00, #FFB74D);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 800;
  flex-shrink: 0;
}
.toc-text { flex: 1; }
.toc-days {
  font-size: 11px;
  color: #999;
  font-weight: 500;
}

/* ===== WEEK SECTION ===== */
.week-section {
  margin-top: 40px;
}
.week-header {
  background: #fff;
  border-radius: 20px;
  padding: 28px 24px;
  box-shadow: 0 4px 24px rgba(230,81,0,0.08);
  border: 1px solid rgba(245,124,0,0.1);
  position: relative;
  overflow: hidden;
}
.week-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, #E65100, #F57C00, #FFB74D);
}
.week-label {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 12px;
}
.week-circle {
  width: 52px;
  height: 52px;
  background: linear-gradient(135deg, #F57C00, #E65100);
  color: #fff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4px 12px rgba(245,124,0,0.3);
}
.week-circle-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  line-height: 1;
  text-transform: uppercase;
}
.week-circle-num {
  font-size: 22px;
  font-weight: 900;
  line-height: 1;
}
.week-title-group { flex: 1; }
.week-title {
  font-size: 20px;
  font-weight: 800;
  color: #222;
  line-height: 1.3;
}
.week-subtitle {
  font-size: 13px;
  color: #888;
  font-weight: 500;
  margin-top: 2px;
}
.week-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 14px;
  margin-bottom: 16px;
}
.week-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
}
.tag-sos {
  background: #FFF3E0;
  color: #E65100;
  border: 1px solid #FFE0B2;
}
.tag-bridge {
  background: #FBE9E7;
  color: #BF360C;
  border: 1px solid #FFCCBC;
}
.tag-type {
  background: #F3E5F5;
  color: #7B1FA2;
  border: 1px solid #E1BEE7;
}

/* ===== INGREDIENTS ===== */
.ingredients-label {
  font-size: 12px;
  font-weight: 700;
  color: #999;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 10px;
}
.ingredient-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.ingredient-pill {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 6px 14px;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  border: 1px solid #FFD180;
  border-radius: 30px;
  font-size: 12px;
  font-weight: 600;
  color: #E65100;
  white-space: nowrap;
}

/* ===== DAY CARD ===== */
.day-cards {
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-top: 16px;
}
.day-card {
  background: #fff;
  border-radius: 18px;
  padding: 24px 22px;
  box-shadow: 0 2px 16px rgba(230,81,0,0.06);
  border: 1px solid rgba(245,124,0,0.08);
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}
.day-card:hover {
  box-shadow: 0 6px 28px rgba(230,81,0,0.12);
  transform: translateY(-2px);
}
.day-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: linear-gradient(180deg, #F57C00, #FFB74D);
  border-radius: 2px;
}
.day-top {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
}
.day-num {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, #FFE0B2, #FFF3E0);
  border: 2px solid #FFB74D;
  color: #E65100;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 900;
  flex-shrink: 0;
}
.day-title-group { flex: 1; }
.day-title {
  font-size: 17px;
  font-weight: 800;
  color: #222;
  line-height: 1.3;
}
.day-time {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  color: #999;
  font-weight: 500;
  margin-top: 2px;
}

.day-divider {
  height: 1px;
  background: linear-gradient(90deg, #FFE0B2, transparent);
  margin-bottom: 14px;
}

.day-section {
  margin-bottom: 14px;
}
.day-section:last-child { margin-bottom: 0; }
.day-section-label {
  font-size: 12px;
  font-weight: 700;
  color: #F57C00;
  margin-bottom: 4px;
  display: flex;
  align-items: center;
  gap: 4px;
}
.day-section-content {
  font-size: 13px;
  color: #555;
  line-height: 1.7;
  padding-left: 2px;
}
.day-quote {
  background: linear-gradient(135deg, #FFF8E1, #FFF3E0);
  border-left: 3px solid #FFB74D;
  border-radius: 0 10px 10px 0;
  padding: 10px 14px;
  font-size: 13px;
  color: #E65100;
  font-weight: 600;
  font-style: italic;
  line-height: 1.6;
}
.day-warning {
  display: flex;
  align-items: flex-start;
  gap: 6px;
  background: #FFF8E1;
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 12px;
  color: #F57C00;
  font-weight: 500;
  line-height: 1.5;
}

/* ===== WEEK DIVIDER ===== */
.week-divider {
  display: flex;
  align-items: center;
  gap: 16px;
  margin: 48px 0 0;
  padding: 0 20px;
}
.week-divider-line {
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, transparent, #FFB74D, transparent);
}
.week-divider-dot {
  width: 8px;
  height: 8px;
  background: #F57C00;
  border-radius: 50%;
}

/* ===== GRADUATION CARD ===== */
.graduation-card {
  background: linear-gradient(135deg, #F57C00 0%, #FF9800 50%, #FFB74D 100%);
  border-radius: 20px;
  padding: 32px 24px;
  text-align: center;
  color: #fff;
  margin-top: 16px;
  box-shadow: 0 8px 32px rgba(245,124,0,0.25);
  position: relative;
  overflow: hidden;
}
.graduation-card::before {
  content: '🎓';
  position: absolute;
  font-size: 120px;
  opacity: 0.1;
  top: -20px;
  right: -10px;
}
.graduation-card .grad-emoji {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
}
.graduation-card h3 {
  font-size: 22px;
  font-weight: 900;
  margin-bottom: 8px;
}
.graduation-card p {
  font-size: 14px;
  opacity: 0.9;
  line-height: 1.6;
}

/* ===== FOOTER ===== */
.footer {
  margin-top: 48px;
  text-align: center;
  padding: 32px 24px;
  background: #fff;
  border-radius: 20px;
  box-shadow: 0 2px 16px rgba(230,81,0,0.06);
  border: 1px solid rgba(245,124,0,0.08);
}
.footer-brand {
  font-size: 20px;
  font-weight: 900;
  color: #F57C00;
  letter-spacing: 2px;
  margin-bottom: 4px;
}
.footer-brand-sub {
  font-size: 11px;
  color: #999;
  font-weight: 500;
  margin-bottom: 16px;
}
.footer-links {
  display: flex;
  flex-direction: column;
  gap: 8px;
  align-items: center;
}
.footer-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #666;
  text-decoration: none;
  font-weight: 500;
  transition: color 0.2s;
}
.footer-link:hover { color: #F57C00; }
.footer-copy {
  margin-top: 20px;
  font-size: 11px;
  color: #bbb;
}

/* ===== PRINT ===== */
@media print {
  @page {
    size: A4;
    margin: 12mm 10mm;
  }
  body { background: #fff; }
  .container { max-width: 100%; padding: 0; }
  .btn-pdf { display: none !important; }
  .header {
    background: #F57C00 !important;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
  .week-circle, .day-num, .ingredient-pill, .week-tag, .day-quote, .day-warning, .toc-num, .overview-item {
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
  .day-card, .week-header, .overview-card, .toc, .footer {
    box-shadow: none;
    border: 1px solid #eee;
    break-inside: avoid;
    page-break-inside: avoid;
  }
  .week-section {
    break-before: page;
    page-break-before: always;
  }
  .week-divider { display: none; }
  .day-card:hover {
    transform: none;
    box-shadow: none;
  }
}

/* ===== RESPONSIVE ===== */
@media (max-width: 400px) {
  .header h1 { font-size: 22px; }
  .overview-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
  .day-card { padding: 18px 16px; }
  .week-header { padding: 22px 18px; }
  .ingredient-pills { gap: 6px; }
  .ingredient-pill { font-size: 11px; padding: 5px 10px; }
}

/* ===== SCROLL TO TOP ===== */
.scroll-top {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, #F57C00, #FF9800);
  color: #fff;
  border: none;
  border-radius: 50%;
  font-size: 20px;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(245,124,0,0.3);
  transition: all 0.3s;
  opacity: 0;
  pointer-events: none;
  z-index: 100;
}
.scroll-top.visible {
  opacity: 1;
  pointer-events: auto;
}
.scroll-top:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 24px rgba(245,124,0,0.4);
}
</style>
</head>
<body>

<!-- ===== COURSE NAV ===== -->
<div id="course-nav" style="position:sticky;top:0;z-index:100;background:rgba(245,124,0,0.95);backdrop-filter:blur(10px);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;max-width:640px;margin:0 auto;">
  <button onclick="navCourse(-1)" style="background:rgba(255,255,255,0.2);border:none;color:#fff;font-size:14px;font-weight:700;padding:8px 14px;border-radius:8px;cursor:pointer;" id="btn-prev">◀ 두부</button>
  <div style="text-align:center;">
    <span id="nav-emoji" style="font-size:20px;">🥕</span>
    <span id="nav-title" style="color:#fff;font-weight:800;font-size:15px;margin-left:4px;">당근</span>
    <div style="font-size:10px;color:rgba(255,255,255,0.7);" id="nav-count">1 / 9</div>
  </div>
  <button onclick="navCourse(1)" style="background:rgba(255,255,255,0.2);border:none;color:#fff;font-size:14px;font-weight:700;padding:8px 14px;border-radius:8px;cursor:pointer;" id="btn-next">토마토 ▶</button>
</div>

<!-- ===== HEADER ===== -->
<div class="header">
  <div class="header-inner">
    <span class="header-emoji" id="header-emoji">🥕</span>
    <h1 id="header-title">당근 코스 — 5주 21회 커리큘럼 소개서</h1>
    <p class="header-sub">어린이집 · 유치원 기관용 | 밀프레드</p>
    <span class="header-badge">🧑‍🏫 선생님용 커리큘럼 소개서</span>
    <br>
    <button class="btn-pdf" onclick="window.print()">🖨️ PDF로 저장</button>
  </div>
</div>

<script>
var courses = [
  {id:'carrot',emoji:'🥕',name:'당근',color:'#F57C00'},
  {id:'tomato',emoji:'🍅',name:'토마토',color:'#E53935'},
  {id:'broccoli',emoji:'🥦',name:'브로콜리',color:'#2E7D32'},
  {id:'eggplant',emoji:'🍆',name:'가지',color:'#7B1FA2'},
  {id:'mushroom',emoji:'🍄',name:'버섯',color:'#795548'},
  {id:'onion',emoji:'🧅',name:'양파',color:'#F9A825'},
  {id:'paprika',emoji:'🫑',name:'파프리카',color:'#E64A19'},
  {id:'spinach',emoji:'🥬',name:'시금치',color:'#388E3C'},
  {id:'tofu',emoji:'🧊',name:'두부',color:'#D4A017'}
];
var ci=0;
function navCourse(d){
  var ni=(ci+d+9)%9;
  var c=courses[ni];
  window.location.href='/'+c.id+'-guide.html';
}
function hexToRgb(h){var r=parseInt(h.slice(1,3),16),g=parseInt(h.slice(3,5),16),b=parseInt(h.slice(5,7),16);return r+','+g+','+b;}
function adjustColor(h,a){var r=Math.min(255,parseInt(h.slice(1,3),16)+a),g=Math.min(255,parseInt(h.slice(3,5),16)+a),b=Math.min(255,parseInt(h.slice(5,7),16)+a);return'#'+r.toString(16).padStart(2,'0')+g.toString(16).padStart(2,'0')+b.toString(16).padStart(2,'0');}
</script>

<div class="container">

  <!-- ===== OVERVIEW ===== -->
  <div class="overview-card">
    <div class="overview-title">📊 코스 한눈에 보기</div>
    <div class="overview-grid">
      <div class="overview-item">
        <span class="num">5주</span>
        <span class="label">총 기간</span>
      </div>
      <div class="overview-item">
        <span class="num">21회</span>
        <span class="label">총 수업 횟수</span>
      </div>
      <div class="overview-item">
        <span class="num">30분</span>
        <span class="label">회당 소요시간</span>
      </div>
      <div class="overview-item">
        <span class="num">🥕</span>
        <span class="label">메인 식재료</span>
      </div>
    </div>
  </div>

  <!-- ===== TOC ===== -->
  <div class="toc">
    <div class="toc-title">📋 주차별 목차</div>
    <ul class="toc-list">
      <li><a class="toc-item" href="#week1">
        <span class="toc-num">1</span>
        <span class="toc-text">시각 탐색 — 친해지기 · 눈으로 탐색</span>
        <span class="toc-days">Day 1-5</span>
      </a></li>
      <li><a class="toc-item" href="#week2">
        <span class="toc-num">2</span>
        <span class="toc-text">촉각/후각 탐색 — 손으로 만지기</span>
        <span class="toc-days">Day 6-10</span>
      </a></li>
      <li><a class="toc-item" href="#week3">
        <span class="toc-num">3</span>
        <span class="toc-text">입 근처 접근 — 가까워지기</span>
        <span class="toc-days">Day 11-15</span>
      </a></li>
      <li><a class="toc-item" href="#week4">
        <span class="toc-num">4</span>
        <span class="toc-text">한 입 도전 — 조리완료 + 토핑</span>
        <span class="toc-days">Day 16-18</span>
      </a></li>
      <li><a class="toc-item" href="#week5">
