          <div class="day-num">D15</div>
          <div class="day-title-group">
            <div class="day-title">🫕 디핑소스 찍기 놀이</div>
            <div class="day-time">⏱ 30분 (준비5 + 활동20 + 정리5)</div>
          </div>
        </div>
        <div class="day-divider"></div>
